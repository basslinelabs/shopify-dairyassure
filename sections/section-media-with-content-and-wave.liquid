{%- liquid
  assign show_top_divider = section.settings.show_top_divider

  case section.settings.image_width
    when '33.3333%'
      assign media_width = '500'
    when '50%'
      assign media_width = '750'
    when '66.6666%'
      assign media_width = '1000'
  endcase

  assign wave_text_blocks = section.blocks | where: "type", "wave_text"
  if section.settings.show_accent_image and section.settings.accent_image
    assign show_accent_image = true
  endif
-%}

{%- style -%}
  {% if show_accent_image %}
    {% render 'styling-section',
      section_id: section.id,
      accent_image: section.settings.accent_image,
      accent_vertical_anchor: section.settings.accent_vertical_anchor,
      accent_horizontal_anchor: section.settings.accent_horizontal_anchor,
      accent_size: section.settings.accent_size,
      hide_accent_on_mobile: section.settings.hide_accent_on_mobile,
      accent_cover: section.settings.accent_cover
    %}
  {% endif %}
  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} .media-with-content-media {
      width: {{ section.settings.image_width }};
    }
    #shopify-section-{{ section.id }} .media-with-content-text {
      width: calc(100% - {{ section.settings.image_width }});
    }
  }
  {% if section.settings.image_position == "right" %}
    #shopify-section-{{ section.id }} .media-with-content {
      flex-direction: row-reverse;
    }
  {% endif %}
{%- endstyle -%}

{%- if show_top_divider -%}
  <div class="top-divider color-{{ section.settings.divider_color_scheme }}"></div>
{%- endif -%}

<div class="section-outer{% if show_top_divider %} has-divider{% endif %}">
  <div class="section-{% if section.settings.full_width_layout %}wide{% else %}standard{% endif %} section--media-with-content section-content bg-default color-{{ section.settings.color_scheme }}{%- if wave_text_blocks.size > 0 %} relative{% endif -%}">
    <div class="media-with-content multi-columns{% unless section.settings.full_width_layout %} contained-section{% endunless %}">
      <div class="media-with-content-media{% unless section.settings.full_width_layout %} in-front-of-accent-image column{% endunless %}">
        {%- if section.settings.video_dt != blank or section.settings.video_mob != blank -%}
          {% assign video_image_size = media_width | append: 'x' %}
          {% liquid
            assign controls = true
            if section.settings.autoplay_video
              assign controls = false
            endif
          %}
          {%- if section.settings.video_dt != blank -%}
            <div class="{% if section.settings.video_mob != blank %}small-hide{% endif %}">
              {{
                section.settings.video_dt
                | video_tag:
                image_size: video_image_size,
                autoplay: section.settings.autoplay_video,
                loop: section.settings.autoplay_video,
                muted: section.settings.autoplay_video,
                controls: controls
              }}
            </div>
          {%- endif -%}
          {%- if section.settings.video_mob != blank -%}
            <div class="medium-up-hide">
              {{
                section.settings.video_mob
                | video_tag:
                image_size: video_image_size,
                autoplay: section.settings.autoplay_video,
                loop: section.settings.autoplay_video,
                muted: section.settings.autoplay_video,
                controls: controls
              }}
            </div>
          {%- endif -%}
        {%- elsif section.settings.image_dt != blank or section.settings.image_mob != blank -%}
          {% assign widths = '600, ' | append: media_width %}
          {%- if section.settings.image_dt != blank -%}
            <div class="{% if section.settings.image_mob != blank %}small-hide{% endif %}">
              {{ section.settings.image_dt | image_url: width: media_width | image_tag: loading: 'lazy', widths: widths }}
            </div>
          {%- endif -%}
          {%- if section.settings.image_mob != blank -%}
            <div class="medium-up-hide">
              {{ section.settings.image_mob | image_url: width: media_width | image_tag: loading: 'lazy', widths: widths }}
            </div>
          {%- endif -%}
        {%- else -%}
          {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
        {%- endif -%}
      </div>
      <div class="media-with-content-text column">
        {%- for block in section.blocks -%}
          {%- case block.type -%}
            {%- when 'header' -%}
              {%- if block.settings.header != blank -%}
                {%- liquid
                  if block.settings.override_default_styles
                    assign header_font_size = block.settings.override_font_size
                  else
                    assign header_font_size = 0
                  endif
                -%}
                <{{ block.settings.header_tag }}
                  class="{% if show_accent_image and block.settings.show_in_front_of_accent_image %}in-front-of-accent-image{% endif %}"
                  {% if header_font_size %} style="--override-font-size: {{ header_font_size }}px;"{% endif %}
                  {{ block.shopify_attributes }}
                >
                  {{- block.settings.header | escape -}}
                </{{ block.settings.header_tag }}>
              {%- endif -%}
            {%- when 'text' -%}
              {%- if block.settings.text != blank -%}
                {%- liquid
                  if block.settings.override_default_styles
                    assign text_font_size = block.settings.override_font_size
                  else
                    assign text_font_size = 0
                  endif
                -%}
                <div
                  class="block rte{% if show_accent_image and block.settings.show_in_front_of_accent_image %} in-front-of-accent-image{% endif %}"
                  {% if text_font_size %} style="--override-font-size: {{ text_font_size }}px;"{% endif %}
                  {{ block.shopify_attributes }}
                >
                  {{ block.settings.text }}
                </div>
              {%- endif -%}
            {%- when 'button' -%}
              {% if block.settings.button_text != blank or block.settings.button_two_text != blank %}
                <div class="banner__block two-buttons" {{ block.shopify_attributes }}>
                  {%- if block.settings.button_link != blank and block.settings.button_text != blank -%}
                    <a href="{{ block.settings.button_link }}" class="button--styled in-front-of-accent-image {{ block.settings.button_style }}{% unless block.settings.button_style == "link" %} button{% endunless %}">
                      {{ block.settings.button_text }}
                    </a>
                  {%- endif -%}
                  {%- if block.settings.button_two_link != blank and block.settings.button_two_text != blank -%}
                    <a href="{{ block.settings.button_two_link }}" class="button--styled in-front-of-accent-image {{ block.settings.button_two_style }}{% unless block.settings.button_two_style == "link" %} button{% endunless %}">
                      {{ block.settings.button_two_text }}
                    </a>
                  {%- endif -%}
                </div>
              {% endif %}
            {%- when 'countdown' -%}
              {%- liquid
                if block.settings.override_default_styles
                  assign countdown_number_font_size = block.settings.override_number_font_size
                  assign countdown_text_font_size = block.settings.override_text_font_size
                else
                  assign countdown_number_font_size = 0
                  assign countdown_text_font_size = 0
                endif
              -%}
              <div
                class="block countdown{% if show_accent_image and block.settings.show_in_front_of_accent_image %} in-front-of-accent-image{% endif %}"
                {{ block.shopify_attributes }}
              >
                {% render 'block-countdown',
                  end_date: block.settings.end_date,
                  end_time: block.settings.end_time,
                  show_after: block.settings.show_after,
                  after_message: block.settings.after_message,
                  number_font_size: countdown_number_font_size,
                  text_font_size: countdown_text_font_size
                %}
              </div>
            {%- when 'collapsible-row' -%}
              {%- liquid
                if block.settings.override_default_styles
                  assign question_font_size = block.settings.override_header_font_size
                  assign answer_font_size = block.settings.override_content_font_size
                else
                  assign question_font_size = 0
                  assign answer_font_size = 0
                endif
              -%}
              {% assign custom_id = section.id | append: '-' | append: block.id %}
              <div
                class="block accordion{% if show_accent_image and block.settings.show_in_front_of_accent_image %} in-front-of-accent-image{% endif %}"
                {{ block.shopify_attributes }}
              >
                {% render 'block-accordion',
                  heading: block.settings.heading,
                  row_content: block.settings.row_content,
                  page_content: block.settings.page.content,
                  open_tab: block.settings.open_tab,
                  id: custom_id,
                  question_font_size: question_font_size,
                  answer_font_size: answer_font_size
                %}
              </div>
            {%- when 'icon-with-text' -%}
              {%- liquid
                if block.settings.override_default_styles
                  assign icon_header_font_size = block.settings.override_header_font_size
                  assign icon_text_font_size = block.settings.override_text_font_size
                else
                  assign icon_header_font_size = 0
                  assign icon_text_font_size = 0
                endif
              -%}
              <div
                class="block icon-with-text{% if show_accent_image and block.settings.show_in_front_of_accent_image %} in-front-of-accent-image{% endif %}"
                {{ block.shopify_attributes }}
              >
                {% render 'block-icon-with-text',
                  icon: block.settings.icon,
                  header: block.settings.header,
                  text: block.settings.text,
                  header_font_size: icon_header_font_size,
                  text_font_size: icon_text_font_size
                %}
              </div>
            {%- when 'divider' -%}
              <hr class="block border-{{ block.settings.color }}{% if show_accent_image and block.settings.show_in_front_of_accent_image %} in-front-of-accent-image{% endif %}" {{ block.shopify_attributes }}>
            {%- when 'sticker' -%}
              <div
                class="block sticker{% unless block.settings.animation_style == "static" %} sticker-animated{% endunless %}{% if show_accent_image and block.settings.show_in_front_of_accent_image %} in-front-of-accent-image{% endif %}"
                id="sticker-{{ block.id }}"
                {{ block.shopify_attributes }}
              >
                {%- unless block.settings.animation_style == "static" -%}
                  {%- liquid
                    case block.settings.animation_style
                      when 'bounce'
                        case block.settings.animation_speed
                          when 'slow'
                            assign animation_speed = 4
                          when 'medium'
                            assign animation_speed = 3
                          when 'fast'
                            assign animation_speed = 2
                        endcase

                        assign animation = "stickerBounce " | append: animation_speed | append: "s step-end infinite normal"
                      when 'rotate_clockwise', 'rotate_anticlockwise'
                        case block.settings.animation_speed
                          when 'slow' 
                            assign animation_speed = 25
                          when 'medium'
                            assign animation_speed = 15
                          when 'fast'
                            assign animation_speed = 7
                        endcase

                        if block.settings.animation_style == 'rotate_clockwise'
                          assign animation_direction = 'normal'
                        else
                          assign animation_direction = 'reverse'
                        endif

                        assign animation = "rotate " | append: animation_speed | append: "s linear infinite " | append: animation_direction
                    endcase
                  -%}
                {%- endunless -%}

                {% style %}
                  #shopify-section-{{ section.id }} #sticker-{{ block.id }} .sticker-wrapper {
                    width: {{ block.settings.size | append: 'px'}};
                    {%- unless block.settings.animation_style == "static" -%}
                      margin: {{ block.settings.size | divided_by: 10 | append: 'px'}};
                    {%- endunless -%}
                  }

                  {%- unless block.settings.animation_style == "static" -%}
                    #shopify-section-{{ section.id }} #sticker-{{ block.id }} img,
                    #shopify-section-{{ section.id }} #sticker-{{ block.id }} svg {
                      animation: {{ animation }};
                    }
                  {%- endunless -%}
                {% endstyle %}

                <div class="sticker-wrapper">
                  {%- if block.settings.image != blank -%}
                    {% assign widths = '' | append: block.settings.size %}
                    {{ block.settings.image | image_url: width: block.settings.size | image_tag: loading: 'lazy', widths: widths }}
                  {%- else -%}
                    {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                  {%- endif -%}
                </div>
              </div>
            {% when 'custom_liquid' %}
              <div class="{% if show_accent_image and block.settings.show_in_front_of_accent_image %}in-front-of-accent-image{% endif %}" {{ block.shopify_attributes }}>
                {{ block.settings.custom_liquid }}
              </div>
            {% when '@app' %}
              {% render block %}
          {%- endcase -%}
        {%- endfor -%}
      </div>
    </div>
    {%- if wave_text_blocks.size > 0 -%}
      {%- liquid
        case section.settings.scroll_speed
          when 'slow'
            assign animation_duration = 20
          when 'medium'
            assign animation_duration = 15
          when 'fast'
            assign animation_duration = 10
        endcase
    
        if section.settings.font_style == "body"
          assign font_class = 'p'
        else
          assign font_class = 'h4'
        endif

        if section.settings.font_size > 110
          assign wave_height = 2
        else
          assign wave_height = 2.5
        endif
      -%}

      {% style %}
        #shopify-section-{{ section.id }} textPath {
          font-size: {{ section.settings.font_size }}%;
        }

        {% if section.settings.font_style == "body" %}
          /* body */
          #shopify-section-{{ section.id }} .horizontally-scrolling-content--wavy use {
            stroke-width: calc(1.5rem * {{ section.settings.font_size | divided_by: 100.0 }} * {{ wave_height }});
          }

          @media screen and (min-width: 750px) {
            #shopify-section-{{ section.id }} .horizontally-scrolling-content--wavy use {
              stroke-width: calc(1.6rem * {{ section.settings.font_size | divided_by: 100.0 }} * {{ wave_height }});
            }
          }
        {% else %}
          #shopify-section-{{ section.id }} .horizontally-scrolling-content--wavy use {
            /* .h4 */
            stroke-width: calc(var(--font-header-scale) * 1.8rem * {{ section.settings.font_size | divided_by: 100.0 }} * {{ wave_height }});
          }
        {% endif %}
      {% endstyle %}
    
      {%- assign total_chars = 0 -%}
      {%- capture wavy_scrolling_content -%}
        {% unless section.settings.wave_custom_text_separator == blank %}
          {% assign separator = section.settings.wave_custom_text_separator %}
        {% else %}
          {% assign separator = "" %}
          {% if section.settings.wave_text_separator == 'vertical_line' %}
            {% assign separator = '|' %}
          {% elsif section.settings.wave_text_separator == 'horizontal_line' %}
            {% assign separator = '-' %}
          {% endif %}
        {% endunless %}

        {%- for block in wave_text_blocks -%}
          {%- if block.settings.text -%}
            {%- assign total_chars = total_chars | plus: block.settings.text.size -%}
            {%- if block.settings.link -%}<a href="{{ block.settings.link }}" class="link-reduce"  {{ block.shopify_attributes }}>{%- endif -%}
              {{ block.settings.text | append: " " | append: separator | append: " " }}
            {%- if block.settings.link -%}</a>{%- endif -%}
          {%- endif -%}
        {%- endfor -%}
      {%- endcapture -%}
    
      {%- if wave_text_blocks.size < 5 -%}
        {%- assign num = 70 | times: 100 | divided_by: section.settings.font_size | divided_by: total_chars | round | times: 3 -%}
    
        {%- capture wavy_scrolling_content -%}
          {{- wavy_scrolling_content -}}
          {%- for i in (1..num) -%}
            {{- wavy_scrolling_content -}}
          {%- endfor -%}
        {%- endcapture -%}
      {%- endif -%}
    
      <div class="wave-component color-{{ section.settings.color_scheme }} align-{{ section.settings.wave_position }} mobile-static">
        {% if section.settings.wave_animation_style == "play_on_scroll" or section.settings.wave_animation_style == "pause_on_hover" %}
          <wave-scrolling-content data-animation-style="{{ section.settings.wave_animation_style }}" data-direction="{{ section.settings.scroll_direction }}" data-speed="10" class="horizontally-scrolling-content--wrapper {{ section.settings.scroll_direction }}">
        {% else %}
          <div class="horizontally-scrolling-content--wrapper">
        {% endif %}
          <div class="horizontally-scrolling-content--wavy">
            <svg xmlns="http://www.w3.org/2000/svg" width="100%" height="100%" viewBox="0 0 1090 100" class="wave wave-bg-{{ section.settings.color }}">
              <defs>
                <path id="curve" fill="transparent" d="M -10 28 S 97 64 262.46 71.2 S 508 18 667.589 31.448 C 859.631 40.177 860 101 1095 54.366"></path>
              </defs>

              <use href="#curve" xlink:href="#curve" fill="none"/>

              <text dominant-baseline="middle">
                <textPath href="#curve" alignment-baseline="middle" startOffset="{%- if section.settings.scroll_direction == "reverse" -%}0%{%- else -%}-100%{%- endif -%}" lengthAdjust="spacing" class="{{ font_class }}">
                  {{ wavy_scrolling_content }}
                  {% unless section.settings.wave_animation_style == "play_on_scroll" %}
                    <animate attributeName="startOffset" from="{%- if section.settings.scroll_direction == "reverse" -%}0%{%- else -%}-100%{%- endif -%}" to ="{%- if section.settings.scroll_direction == "reverse" -%}-100%{%- else -%}0%{%- endif -%}" begin="0s" dur="{{ animation_duration }}s" repeatCount="indefinite" calcMode="linear" />
                  {% endunless %}
                </textPath>
              </text>
            </svg>
          </div>
        {% if section.settings.wave_animation_style == "play_on_scroll" or section.settings.wave_animation_style == "pause_on_hover" %}
          </wave-scrolling-content>
        {% else %}
          </div>
        {% endif %}
      </div>
    {%- endif -%}
    
    {% if section.settings.wave_animation_style == "play_on_scroll" or section.settings.wave_animation_style == "pause_on_hover" %} 
      <script src="{{ 'wave-scrolling-content.js' | asset_url }}" defer="defer"></script>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "t:sections.media-with-content-and-wave.name",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.all.section_content"
    },
    {
      "type": "header",
      "content": "t:sections.all.desktop.label"
    },
    {
      "type": "image_picker",
      "id": "image_dt",
      "label": "t:sections.banner.settings.image_dt.label"
    },
    {
      "type": "video",
      "id": "video_dt",
      "label": "t:sections.banner.settings.video_dt.label"
    },
    {
      "type": "header",
      "content": "t:sections.all.mobile.label"
    },
    {
      "type": "image_picker",
      "id": "image_mob",
      "label": "t:sections.banner.settings.image_mob.label"
    },
    {
      "type": "video",
      "id": "video_mob",
      "label": "t:sections.banner.settings.video_mob.label"
    },
    {
      "type": "header",
      "content": "t:sections.all.media_settings"
    },
    {
      "type": "checkbox",
      "id": "autoplay_video",
      "label": "t:sections.all.autoplay_video.label",
      "info": "t:sections.all.autoplay_video.info",
      "default": true
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "t:sections.media-with-content.settings.media_position.label",
      "options": [
        {
          "value": "left",
          "label": "t:sections.media-with-content.settings.media_position.left.label"
        },
        {
          "value": "right",
          "label": "t:sections.media-with-content.settings.media_position.right.label"
        }
      ],
      "default": "left"
    },
    {
      "type": "select",
      "id": "image_width",
      "label": "t:sections.media-with-content.settings.media_width.label",
      "info": "t:sections.media-with-content.settings.media_width.info",
      "options": [
        {
          "value": "33.3333%",
          "label": "t:sections.media-with-content.settings.media_width.one_third.label"
        },
        {
          "value": "50%",
          "label": "t:sections.media-with-content.settings.media_width.one_half.label"
        },
        {
          "value": "66.6666%",
          "label": "t:sections.media-with-content.settings.media_width.two_thirds.label"
        }
      ],
      "default": "50%"
    },
    {
      "type": "header",
      "content": "t:sections.all.wave.header"
    },
    {
      "type": "select",
      "id": "scroll_direction",
      "label": "t:sections.all.horizontally_scrolling_content.scroll_direction.label",
      "options": [
        {
          "value": "normal",
          "label": "t:sections.all.horizontally_scrolling_content.scroll_direction.options__1.label"
        },
        {
          "value": "reverse",
          "label": "t:sections.all.horizontally_scrolling_content.scroll_direction.options__2.label"
        }
      ],
      "default": "reverse"
    },
    {
      "type": "select",
      "id": "scroll_speed",
      "label": "t:sections.all.horizontally_scrolling_content.scroll_speed.label",
      "info": "t:sections.all.horizontally_scrolling_content.scroll_speed.info",
      "options": [
        {
          "value": "slow",
          "label": "t:sections.all.animations.animation_speed.options__1.label"
        },
        {
          "value": "medium",
          "label": "t:sections.all.animations.animation_speed.options__2.label"
        },
        {
          "value": "fast",
          "label": "t:sections.all.animations.animation_speed.options__3.label"
        }
      ],
      "default": "medium"
    },
    {
      "type": "select",
      "id": "wave_animation_style",
      "label": "t:sections.all.horizontally_scrolling_content.animation_style.label",
      "options": [
        {
          "value": "constant",
          "label": "t:sections.all.horizontally_scrolling_content.animation_style.options__1.label"
        },
        {
          "value": "pause_on_hover",
          "label": "t:sections.all.horizontally_scrolling_content.animation_style.options__2.label"
        },
        {
          "value": "play_on_scroll",
          "label": "t:sections.all.horizontally_scrolling_content.animation_style.options__3.label"
        }
      ],
      "default": "constant"
    },
    {
      "type": "select",
      "id": "wave_text_separator",
      "label": "t:sections.all.wave.separator.label",
      "options": [
        {
          "value": "none",
          "label": "t:sections.all.wave.separator.options__1.label"
        },
        {
          "value": "vertical_line",
          "label": "t:sections.all.wave.separator.options__2.label"
        },
        {
          "value": "horizontal_line",
          "label": "t:sections.all.wave.separator.options__3.label"
        }
      ],
      "default": "vertical_line"
    },
    {
      "type": "text",
      "id": "wave_custom_text_separator",
      "label": "t:sections.all.wave.custom_separator.label",
      "info": "t:sections.all.wave.custom_separator.info"
    },
    {
      "type": "select",
      "id": "wave_position",
      "label": "t:sections.all.wave.position.label",
      "options": [
        {
          "value": "top",
          "label": "t:sections.all.wave.position.options__1.label"
        },
        {
          "value": "bottom",
          "label": "t:sections.all.wave.position.options__2.label"
        }
      ],
      "default": "bottom"
    },
    {
      "type": "select",
      "id": "font_style",
      "label": "t:sections.all.horizontally_scrolling_content.font_style.label",
      "options": [
        {
          "value": "header",
          "label": "t:sections.all.horizontally_scrolling_content.font_style.options__1.label"
        },
        {
          "value": "body",
          "label": "t:sections.all.horizontally_scrolling_content.font_style.options__2.label"
        }
      ],
      "default": "header"
    },
    {
      "type": "range",
      "id": "font_size",
      "min": 80,
      "max": 120,
      "step": 5,
      "unit": "%",
      "label": "t:sections.all.horizontally_scrolling_content.font_size.label",
      "default": 110
    },
    {
      "type": "select",
      "id": "color",
      "label": "t:sections.all.colors.color.label",
      "options": [
        {
          "value": "accent",
