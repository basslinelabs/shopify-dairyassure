{%- liquid
  for block in section.blocks
    case block.type
      when 'banner'
        assign has_banner = true
        assign banner_height = block.settings.height
        assign banner_overlay = block.settings.overlay
        assign banner_horizontal_alignment = block.settings.horizontal_alignment
        assign banner_vertical_alignment = block.settings.vertical_alignment
        assign banner_show_date = block.settings.show_date
        assign banner_show_author = block.settings.show_author
        assign banner_hide_image = block.settings.hide_image
        assign banner_attributes = block.shopify_attributes
      when 'content'
        assign content_show_title = block.settings.show_title
    endcase
  endfor
-%}

{%- if has_banner -%}
  {%- style -%}
    #shopify-section-{{ section.id }} .main-article__banner {
      {% if article.image != blank and banner_hide_image == false %}
        background-image: url({{ article.image | image_url: width: 2000 }});
      {% endif %}
      justify-content: {{ banner_horizontal_alignment }};
      align-items: {{ banner_vertical_alignment }};
      height: {{ banner_height }}vh;
    }
    {% if banner_overlay != blank %}
      #shopify-section-{{ section.id }} .main-article__banner::before {
        background: {{ banner_overlay }};
      }
    {% endif %}
    #shopify-section-{{ section.id }} .main-article__banner {
      text-align: {{ banner_horizontal_alignment }};
    }
  {%- endstyle -%}
{%- endif -%}

<div class="bg-default color-{{ section.settings.color_scheme }}">
  {% if has_banner %}
    <div class="main-article__banner" {{ banner_attributes }}>
      <div class="main-article__banner-inner contained-inner-section">
        {%- unless content_show_title -%}
          <h1 class="main-article__title">{{ article.title }}</h1>
        {%- endunless -%}
        {%- if banner_show_date -%}
          <span class="main-article__date" itemprop="dateCreated pubdate datePublished">
            {{- article.published_at | time_tag: format: 'date' -}}
          </span>
        {%- endif -%}
        {%- if banner_show_date and banner_show_author -%}
          <span class="main-article__divider">//</span>
        {%- endif -%}
        {%- if banner_show_author -%}
          <span class="main-article__author" itemprop="author" itemscope itemtype="http://schema.org/Person">
            <span itemprop="name">{{ article.author }}</span>
          </span>
        {%- endif -%}
      </div>
    </div>
  {% endif %}
  <div class="contained-section">
    {% for block in section.blocks %}
      {% case block.type %}
        {% when 'content' %}
          <div
            class="main-article__content rte contained-section--narrow"
            itemprop="articleBody"
            {{ block.shopify_attributes }}
          >
            {%- if content_show_title -%}
              <h1 class="main-article__title">{{ article.title }}</h1>
            {%- endif -%}
            {{ article.content }}
            {%- if blog.comments_enabled? -%}
              <div class="article-template__comment-wrapper">
                <hr>
                <div id="comments" class="contained-section--narrow">
                  {%- if article.comments_count > 0 -%}
                    {%- assign anchorId = '#Comments-' | append: article.id -%}

                    <h2 id="Comments-{{ article.id }}" tabindex="-1">
                      {{ 'blogs.article.comments' | t: count: article.comments_count }}
                    </h2>
                    {% paginate article.comments by 5 %}
                      <div class="article-template__comments">
                        {%- if comment.status == 'pending' and comment.content -%}
                          <article id="{{ comment.id }}" class="article-template__comments-comment">
                            {{ comment.content }}
                            <footer>
                              <span>{{ comment.author }}</span>
                            </footer>
                          </article>
                        {%- endif -%}

                        {%- for comment in article.comments -%}
                          <article id="{{ comment.id }}" class="article-template__comments-comment">
                            {{ comment.content }}
                            <footer>
                              <span>{{ comment.author }}</span
                              ><span class="caption-with-letter-spacing">
                                {{- comment.created_at | time_tag: format: 'date' -}}
                              </span>
                            </footer>
                          </article>
                        {%- endfor -%}
                        {% render 'pagination', paginate: paginate, anchor: anchorId %}
                      </div>
                    {% endpaginate %}
                  {%- endif -%}
                  {% form 'new_comment', article %}
                    {%- liquid
                      assign post_message = 'blogs.article.success'
                      if blog.moderated? and comment.status == 'unapproved'
                        assign post_message = 'blogs.article.success_moderated'
                      endif
                    -%}
                    <h2>{{ 'blogs.article.comment_form_title' | t }}</h2>
                    {%- if form.errors -%}
                      <div class="form__message" role="alert">
                        <h3 class="form-status caption-large text-body" tabindex="-1" autofocus>
                          {% render 'icons-main', icon: 'cross' %}
                          {{ 'templates.contact.form.error_heading' | t }}
                        </h3>
                      </div>
                      <ul class="form-status-list caption-large">
                        {%- for field in form.errors -%}
                          <li>
                            <a href="#CommentForm-{{ field }}" class="link">
                              {%- if form.errors.translated_fields[field] contains 'author' -%}
                                {{ 'blogs.article.name' | t }}
                              {%- elsif form.errors.translated_fields[field] contains 'body' -%}
                                {{ 'blogs.article.message' | t }}
                              {%- else -%}
                                {{ form.errors.translated_fields[field] }}
                              {%- endif -%}
                              {{ form.errors.messages[field] }}
                            </a>
                          </li>
                        {%- endfor -%}
                      </ul>
                    {%- elsif form.posted_successfully? -%}
                      <div class="form-status-list form__message" role="status">
                        <h3 class="form-status" tabindex="-1" autofocus>
                          {% render 'icons-main', icon: 'tick' %}
                          {{ post_message | t }}
                        </h3>
                      </div>
                    {%- endif -%}
                    <div
                      {% if blog.moderated? == false %}
                        class="article-template__comments-fields default"
                      {% endif %}
                    >
                      <div class="article-template__comment-fields">
                        <div class="field field--with-error">
                          <input
                            type="text"
                            name="comment[author]"
                            id="CommentForm-author"
                            class="field__input"
                            autocomplete="name"
                            value="{{ form.author }}"
                            aria-required="true"
                            required
                            {% if form.errors contains 'author' %}
                              aria-invalid="true"
                              aria-describedby="CommentForm-author-error"
                            {% endif %}
                            placeholder="{{ 'blogs.article.name' | t }}"
                          >
                          <label class="field__label" for="CommentForm-author">
                            {{- 'blogs.article.name' | t }}
                            <span aria-hidden="true">*</span></label
                          >
                          {%- if form.errors contains 'author' -%}
                            <small id="CommentForm-author-error">
                              <span class="form__message">
                                {% render 'icons-main', icon: 'cross' %}
                                {{- 'blogs.article.name' | t }}
                                {{ form.errors.messages.author }}.</span
                              >
                            </small>
                          {%- endif -%}
                        </div>
                        <div class="field field--with-error">
                          <input
                            type="email"
                            name="comment[email]"
                            id="CommentForm-email"
                            autocomplete="email"
                            class="field__input"
                            value="{{ form.email }}"
                            autocorrect="off"
                            autocapitalize="off"
                            aria-required="true"
                            required
                            {% if form.errors contains 'email' %}
                              aria-invalid="true"
                              aria-describedby="CommentForm-email-error"
                            {% endif %}
                            placeholder="{{ 'blogs.article.email' | t }}"
                          >
                          <label class="field__label" for="CommentForm-email">
                            {{- 'blogs.article.email' | t }}
                            <span aria-hidden="true">*</span></label
                          >
                          {%- if form.errors contains 'email' -%}
                            <small id="CommentForm-email-error">
                              <span class="form__message">
                                {% render 'icons-main', icon: 'cross' %}
                                {{- 'blogs.article.email' | t }}
                                {{ form.errors.messages.email }}.</span
                              >
                            </small>
                          {%- endif -%}
                        </div>
                      </div>
                      <div class="field field--with-error">
                        <textarea
                          rows="5"
                          name="comment[body]"
                          id="CommentForm-body"
                          class="text-area field__input"
                          aria-required="true"
                          required
                          {% if form.errors contains 'body' %}
                            aria-invalid="true"
                            aria-describedby="CommentForm-body-error"
                          {% endif %}
                          placeholder="{{ 'blogs.article.message' | t }}"
                        >{{ form.body }}</textarea>
                        <label class="form__label field__label" for="CommentForm-body">
                          {{- 'blogs.article.message' | t }}
                          <span aria-hidden="true">*</span></label
                        >
                      </div>
                      {%- if form.errors contains 'body' -%}
                        <small id="CommentForm-body-error">
                          <span class="form__message">
                            {% render 'icons-main', icon: 'cross' %}
                            {{- 'blogs.article.message' | t }}
                            {{ form.errors.messages.body }}.</span
                          >
                        </small>
                      {%- endif -%}
                    </div>
                    {%- if blog.moderated? -%}
                      <p class="article-template__comment-warning caption">{{ 'blogs.article.moderated' | t }}</p>
                    {%- endif -%}
                    <input
                      type="submit"
                      class="button button--styled article-template__comment-submit"
                      value="{{ 'blogs.article.post' | t }}"
                    >
                  {% endform %}
                </div>
              </div>
            {%- endif -%}
          </div>
        {% when 'author_bio' %}
          <div class="main-article__author-bio block block--contained">
            <div class="main-article__author-bio-photo">
              {% if article.user.image != blank %}
                {{
                  article.user.image
                  | image_url: width: 150
                  | image_tag: loading: 'lazy', alt: article.user.image.alt
                }}
              {% endif %}
            </div>
            <div class="main-article__author-bio-text">
              <div class="main-article__author-bio-text-name">
                <h4 class="h5">
                  {{ article.author }}
                </h4>
              </div>
              <div class="main-article__author-bio-text-bio">
                {{ article.user.bio }}
              </div>
            </div>
          </div>
        {% when 'share_icons' %}
          <div class="main-article__share-icons" {{ block.shopify_attributes }}>
            {% render 'share-icons', object: article %}
          </div>
        {% when 'return_button' %}
          {%- if block.settings.button_text != blank -%}
            <div class="main-article__return-button" {{ block.shopify_attributes }}>
              <a
                href="{{ blog.url }}"
                class="{{ block.settings.button_style }}{% unless block.settings.button_style == "link" %} button{% endunless %}"
              >
                {{ block.settings.button_text }}
              </a>
            </div>
          {%- endif -%}
      {% endcase %}
    {% endfor %}
  </div>
</div>

<script type="application/ld+json">
  {
    "@context": "http://schema.org",
    "@type": "Article",
    "articleBody": {{ article.content | strip_html | json }},
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": {{ request.origin | append: page.url | json }}
    },
    "headline": {{ article.title | json }},
    {% if article.excerpt != blank %}
      "description": {{ article.excerpt | strip_html | json }},
    {% endif %}
    {% if article.image %}
      {% assign image_size = article.image.width | append: 'x' %}
      "image": [
        {{ article | image_url: width: image_size | prepend: "https:" | json }}
      ],
    {% endif %}
    "datePublished": {{ article.published_at | date: '%Y-%m-%dT%H:%M:%SZ' | json }},
    "dateCreated": {{ article.created_at | date: '%Y-%m-%dT%H:%M:%SZ' | json }},
    "author": {
      "@type": "Person",
      "name": {{ article.author | json }}
    },
    "publisher": {
      "@type": "Organization",
      {% if settings.share_image %}
        {% assign image_size = settings.share_image.width | append: 'x' %}
        "logo": {
          "@type": "ImageObject",
          "height": {{ settings.share_image.height | json }},
          "url": {{ settings.share_image | image_url: width: image_size | prepend: "https:" | json }},
          "width": {{ settings.share_image.width | json }}
        },
      {% endif %}
      "name": {{ shop.name | json }}
    }
  }
</script>

{% schema %}
{
  "name": "t:sections.main-article.name",
  "tag": "section",
  "class": "section",
  "blocks": [
    {
      "type": "banner",
      "name": "t:sections.main-article.blocks.banner.name",
      "limit": 1,
      "settings": [
        {
          "type": "range",
          "id": "height",
          "label": "t:sections.main-article.blocks.banner.settings.height.label",
          "min": 25,
          "max": 100,
          "unit": "%",
          "default": 50
        },
        {
          "type": "color_background",
          "id": "overlay",
          "label": "t:sections.main-article.blocks.banner.settings.overlay.label"
        },
        {
          "type": "select",
          "id": "horizontal_alignment",
          "label": "t:sections.banner.settings.horizontal_alignment.label",
          "options": [
            {
              "value": "left",
              "label": "t:sections.banner.settings.horizontal_alignment.left.label"
            },
            {
              "value": "center",
              "label": "t:sections.banner.settings.horizontal_alignment.middle.label"
            },
            {
              "value": "right",
              "label": "t:sections.banner.settings.horizontal_alignment.right.label"
            }
          ],
          "default": "center"
        },
        {
          "type": "select",
          "id": "vertical_alignment",
          "label": "t:sections.banner.settings.vertical_alignment.label",
          "options": [
            {
              "value": "start",
              "label": "t:sections.banner.settings.vertical_alignment.top.label"
            },
            {
              "value": "center",
              "label": "t:sections.banner.settings.vertical_alignment.middle.label"
            },
            {
              "value": "end",
              "label": "t:sections.banner.settings.vertical_alignment.bottom.label"
            }
          ],
          "default": "center"
        },
        {
          "type": "checkbox",
          "id": "show_author",
          "label": "t:sections.main-article.blocks.banner.settings.show_author.label",
          "default": true
        },
        {
          "type": "checkbox",
          "id": "show_date",
          "label": "t:sections.main-article.blocks.banner.settings.show_date.label",
          "default": true
        },
        {
          "type": "checkbox",
          "id": "hide_image",
          "label": "t:sections.main-article.blocks.banner.settings.hide_image.label",
          "info": "t:sections.main-article.blocks.banner.settings.hide_image.info",
          "default": false
        }
      ]
    },
    {
      "type": "content",
      "name": "t:sections.main-article.blocks.content.name",
      "settings": [
        {
          "type": "checkbox",
          "id": "show_title",
          "label": "t:sections.main-article.blocks.banner.settings.show_title.label",
          "default": false
        }
      ],
      "limit": 1,
    },
    {
      "type": "author_bio",
      "name": "t:sections.main-article.blocks.author_bio.name",
      "settings": [
        {
          "type": "paragraph",
          "content": "t:sections.main-article.blocks.author_bio.info"
        }
      ],
      "limit": 1
    },
    {
      "type": "share_icons",
      "name": "t:sections.main-article.blocks.share_icons.name",
      "settings": [
        {
          "type": "paragraph",
          "content": "t:sections.main-article.blocks.share_icons.info"
        }
      ],
      "limit": 1
    },
    {
      "type": "return_button",
      "name": "t:sections.main-article.blocks.return_button.name",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "button_text",
          "default": "Return to blog",
          "label": "t:sections.all.buttons.button_text.label"
        },
        {
          "type": "select",
          "id": "button_style",
          "label": "t:sections.all.buttons.style.label",
          "options": [
            {
              "value": "solid",
              "label": "t:sections.all.buttons.solid.label"
            },
            {
              "value": "outline",
              "label": "t:sections.all.buttons.outline.label"
            },
            {
              "value": "link",
              "label": "t:sections.all.buttons.link.label"
            }
          ],
          "default": "link"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "header",
      "content": "t:sections.all.section_styling"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "default": "scheme_1",
      "label": "t:sections.all.color_scheme.label"
    }
  ]
}
{% endschema %}
