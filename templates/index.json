    "faq": {
      "type": "section-faq",
      "blocks": {
        "faq_1": {
          "type": "faq_item",
          "settings": {
            "question": "What exactly is DairyAssure?",
            "answer": "<p>Pure lactase enzyme powder in portable stick packs. Lactase is the enzyme your body needs to digest dairy, and we just give you more of it. One ingredient, nothing else added. Sprinkle it on your food or mix it into your drink.</p>"
          }
        },
        "faq_2": {
          "type": "faq_item",
          "settings": {
            "question": "How is this different from lactase pills?",
            "answer": "<p>Pills are loaded with fillers, binders, and coatings your body doesn't need. DairyAssure is just the enzyme, nothing else. And because it's a powder you add directly to food there's no timing to worry about, you don't have to swallow anything 30 minutes before eating. Sprinkle it on and eat.</p>"
          }
        },
        "faq_3": {
          "type": "faq_item",
          "settings": {
            "question": "How do I use it?",
            "answer": "<p>Tear open a stick pack and sprinkle the powder on your food or mix it into your drink right before you eat. That's it. No water needed, no pills to swallow, no planning ahead.</p>"
          }
        },
        "faq_4": {
          "type": "faq_item",
          "settings": {
            "question": "Is DairyAssure safe for children?",
            "answer": "<p>Yes. It's a single-ingredient powder suitable for children, adults, and seniors. It supplements the lactase enzyme your body doesn't produce enough of. Sprinkle it on their food, it's flavorless so they won't even notice it's there.</p>"
          }
        },
        "faq_5": {
          "type": "faq_item",
          "settings": {
            "question": "How long does it last?",
            "answer": "<p>90+ minutes per dose. That's enough to get through your entire meal and then some.</p>"
          }
        },
        "faq_6": {
          "type": "faq_item",
          "settings": {
            "question": "Can I use it with any dairy product?",
            "answer": "<p>Yes. Coffee, pizza, ice cream, cheese, yogurt, protein shakes. It works with all dairy and it's completely flavorless so it won't change the taste of your food.</p>"
          }
        },
        "faq_7": {
          "type": "faq_item",
          "settings": {
            "question": "Is it really just one ingredient?",
            "answer": "<p>Yes. Lactase enzyme. That's the full ingredient list, you can read it in about two seconds. We think one problem needs one solution and the rest is just unnecessary filler that can actually make things worse.</p>"
          }
        },
        "faq_8": {
          "type": "faq_item",
          "settings": {
            "question": "Some brands have multiple enzymes. Why does DairyAssure only have one?",
            "answer": "<p>Lactose causes the discomfort and lactase breaks it down. That's the whole equation. Other brands add extra enzymes to justify a higher price but your body only needs one thing here, pure lactase at the right dose.</p>"
          }
        },
        "faq_9": {
          "type": "faq_item",
          "settings": {
            "question": "Is it worth the cost compared to generic pills?",
            "answer": "<p>About the price of a coffee per meal. Generic pills are cheaper because they're packed with binders and additives your body doesn't need, so you're comparing a pure enzyme to a cocktail of filler ingredients and hoping for the best.</p>"
          }
        },
        "faq_10": {
          "type": "faq_item",
          "settings": {
            "question": "What does 'doctor recommended' mean?",
            "answer": "<p>Gastroenterologists recommend lactase enzyme supplements to patients with lactose intolerance. That's not us saying it, that's standard medical guidance. We just made the cleanest version possible so there's nothing in it a doctor would raise an eyebrow at.</p>"
          }
        }
