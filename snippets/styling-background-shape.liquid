{% comment %}
    Renders the background shape that sits behind a media item

    Accepts:
    - section_id: {String} Unique section id.
    - section_color: {String} Section color.
    - target_class: {String} Class to target for displaying the border.
    - background_shape_color: {String} Border color.
    - background_shape_top {Object} Top border position.
    - background_shape_right {String} Right border position.
    - background_shape_bottom {String} Bottom border position.
    - background_shape_left {Integer} Left border position.

    Usage:
    {% render 'styling-background-shape',
        section_id: section.id,
        section_color: background_color,
        target_class: "media",
        background_shape_color: section.settings.background_shape_color,
        background_shape_top: section.settings.background_shape_top,
        background_shape_right: section.settings.background_shape_right,
        background_shape_bottom: section.settings.background_shape_bottom,
        background_shape_left: section.settings.background_shape_left,
    %}
{% endcomment %}

#shopify-section-{{ section_id }} .bg-shape {
    border-radius: {{ background_shape_top }}% {{ 100 | minus: background_shape_top }}% {{ background_shape_bottom }}% {{ 100 | minus: background_shape_bottom }}%/
                    {{ background_shape_left }}% {{ background_shape_right }}% {{ 100 | minus: background_shape_right }}% {{ 100 | minus: background_shape_left }}% 
}