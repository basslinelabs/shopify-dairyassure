                                                    {{ grandchildlink.title | escape }}
                                                  </a>
                                                </li>
                                              {%- endfor -%}
                                            </ul>
                                          </details>
                                      {%- endif -%}
                                    </li>
                                  {%- endfor -%}
                                </ul>
                              {% endif %}
                            </details>
                          </header-menu>
                        {%- else -%}
                          <a href="{{ link.url }}" class="header__menu-item link-reduce"{% if link.current %} aria-current="page"{% endif %}>
                            <span>{{ link.title | escape }}</span>
                          </a>
                        {%- endif -%}
                      </li>
                    {%- endfor -%}
                  </ul>
                </nav>
              {%- else -%}
                <nav class="header__inline-menu">
                  <ul class="list-menu list-menu--inline" role="list">
                    {%- for link in block.settings.menu.links -%}
                      <li>
                        {%- if link.links != blank -%}
                          <header-menu>
                            <details id="Details-HeaderMenu-{{ forloop.index }}"{% if mega_menu %} class="mega-menu"{% endif %}>
                              <summary class="header__menu-item">
                                <a href="{{ link.url }}" class="link-reduce">{{ link.title | escape }}
                                </a>
                              </summary>
                              <ul id="HeaderMenu-MenuList-{{ forloop.index }}" class="header__submenu list-menu list-menu--disclosure motion-reduce global-settings-popup bg-default" role="list" tabindex="-1">
                                {%- for childlink in link.links -%}
                                  <li>
                                    {%- if childlink.links == blank -%}
                                      <a href="{{ childlink.url }}" class="header__menu-item list-menu__item link-reduce"{% if childlink.current %} aria-current="page"{% endif %}>
                                        {{ childlink.title | escape }}
                                      </a>
                                    {%- else -%}
                                        <details id="Details-HeaderSubMenu-{{ forloop.index }}">
                                          <summary class="header__menu-item link-reduce">
                                            <span>{{ childlink.title | escape }}</span>
                                            {% render 'icons-main', icon: 'caret' %}
                                          </summary>
                                          <ul id="HeaderMenu-SubMenuList-{{ forloop.index }}" class="header__submenu list-menu motion-reduce bg-default">
                                            {%- for grandchildlink in childlink.links -%}
                                              <li>
                                                <a href="{{ grandchildlink.url }}" class="header__menu-item list-menu__item link-reduce"{% if grandchildlink.current %} aria-current="page"{% endif %}>
                                                  {{ grandchildlink.title | escape }}
                                                </a>
                                              </li>
                                            {%- endfor -%}
                                          </ul>
                                        </details>
                                    {%- endif -%}
                                  </li>
                                {%- endfor -%}
                              </ul>
                            </details>
                          </header-menu>
                        {%- else -%}
                          <a href="{{ link.url }}" class="header__menu-item list-menu__item link-reduce"{% if link.current %} aria-current="page"{% endif %}>
                            <span>{{ link.title | escape }}</span>
                          </a>
                        {%- endif -%}
                      </li>
                    {%- endfor -%}
                  </ul>
                </nav>                
              {%- endif -%}
            {%- endif -%}

            <div class="header__icons">
              {%- if show_search == true -%}
                <a href="{{ routes.search_url }}" class="header__heading-search header__icon{% if position == "top-center" %} large-up-hide{% endif %}" aria-label="{{ 'general.search.search' | t }}">
                  <svg class="icon icon-search" aria-hidden="true">
                    <use href="#icon-search">
                  </svg>
                </a>
              {%- endif -%}
              {%- if shop.customer_accounts_enabled -%}
                <a href="{%- if customer -%}{{ routes.account_url }}{%- else -%}{{ routes.account_login_url }}{%- endif -%}" class="header__icon header__icon--account{% if section.settings.menu != blank %} small-hide{% endif %}">
                  {% render 'icons-main', icon: 'account' %}
                  <span class="visually-hidden">
                    {%- liquid
                      if customer
                        echo 'customer.account_fallback' | t
