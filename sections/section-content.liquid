{%- liquid
  assign button_style = section.settings.button_style
  assign show_top_divider = section.settings.show_top_divider
  if section.settings.show_accent_image and section.settings.accent_image
    assign show_accent_image = true
  endif
-%}

{%- style -%}
  {% if show_accent_image %}
    {% render 'styling-section',
      section_id: section.id,
      accent_image: section.settings.accent_image,
      accent_vertical_anchor: section.settings.accent_vertical_anchor,
      accent_horizontal_anchor: section.settings.accent_horizontal_anchor,
      accent_size: section.settings.accent_size,
      hide_accent_on_mobile: section.settings.hide_accent_on_mobile,
      accent_cover: section.settings.accent_cover
    %}
  {% endif %}
{%- endstyle -%}

{%- if show_top_divider -%}
  <div class="top-divider color-{{ section.settings.divider_color_scheme }}"></div>
{%- endif -%}

<div class="section-outer alignment{% if show_top_divider %} has-divider{% endif %}">
  <div class="section-standard section--content  bg-default color-{{ section.settings.color_scheme }}">
    <div class="contained-section">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'heading' -%}
            {%- liquid
              if block.settings.override_default_styles
                assign heading_font_size = block.settings.override_font_size
              else
                assign heading_font_size = 0
              endif
            -%}
            <{{ block.settings.header_tag }} class="{% if show_accent_image and block.settings.show_in_front_of_accent_image %}in-front-of-accent-image{% endif %}{% if block.settings.contain_width %} block--contained{% endif %}"{% if heading_font_size %} style="--override-font-size: {{ heading_font_size }}px;"{% endif %} {{ block.shopify_attributes }}>{{ block.settings.heading | escape }}</{{ block.settings.header_tag }}>
          {%- when 'text' -%}
            {%- liquid
              if block.settings.override_default_styles
                assign text_font_size = block.settings.override_font_size
              else
                assign text_font_size = 0
              endif
            -%}
            <div class="rte block{% if show_accent_image and block.settings.show_in_front_of_accent_image %} in-front-of-accent-image{% endif %}{% if block.settings.contain_width %} block--contained{% endif %}"{% if text_font_size %} style="--override-font-size: {{ text_font_size }}px;"{% endif %} {{ block.shopify_attributes }}>{{ block.settings.text }}</div>
          {%- when 'button' -%}
            {%- if block.settings.button_text != blank and block.settings.button_link -%}
              <div class="block{% if show_accent_image and block.settings.show_in_front_of_accent_image %} in-front-of-accent-image{% endif %}" {{ block.shopify_attributes }}>
                <a href="{{ block.settings.button_link }}" class="{{ button_style }} button--styled{% unless button_style == "link" %} button{% endunless %}">
                  {{ block.settings.button_text }}
                </a>
              </div>
            {%- endif -%}
          {%- when 'countdown' -%}
            {%- liquid
              if block.settings.override_default_styles
                assign countdown_number_font_size = block.settings.override_number_font_size
                assign countdown_text_font_size = block.settings.override_text_font_size
              else
                assign countdown_number_font_size = 0
                assign countdown_text_font_size = 0
              endif
            -%}
            <div class="block countdown{% if show_accent_image and block.settings.show_in_front_of_accent_image %} in-front-of-accent-image{% endif %}" {{ block.shopify_attributes }}>
              {% render 'block-countdown',
                end_date: block.settings.end_date,
                end_time: block.settings.end_time,
                show_after: block.settings.show_after,
                after_message: block.settings.after_message,
                number_font_size: countdown_number_font_size,
                text_font_size: countdown_text_font_size
              %}
            </div>
          {%- when 'collapsible-row' -%}
            {%- liquid
              if block.settings.override_default_styles
                assign collapsible_header_font_size = block.settings.override_header_font_size
                assign collapsible_content_font_size = block.settings.override_content_font_size
              else
                assign collapsible_header_font_size = 0
                assign collapsible_content_font_size = 0
              endif
            -%}
            {% assign custom_id = section.id | append: "-" | append: block.id %}
            <div class="block accordion {% if block.settings.contain_width %} block--contained{% endif %}{% if show_accent_image and block.settings.show_in_front_of_accent_image %} in-front-of-accent-image{% endif %}" {{ block.shopify_attributes }}>
              {% render 'block-accordion',
                  heading: block.settings.heading,
                  row_content: block.settings.row_content,
                  page_content: block.settings.page.content,
                  open_tab: block.settings.open_tab,
                  id: custom_id,
                  question_font_size: collapsible_header_font_size,
                  answer_font_size: collapsible_content_font_size
              %}
            </div>
          {%- when 'icon-with-text' -%}
            {%- liquid
              if block.settings.override_default_styles
                assign icon_header_font_size = block.settings.override_header_font_size
                assign icon_text_font_size = block.settings.override_text_font_size
              else
                assign icon_header_font_size = 0
                assign icon_text_font_size = 0
              endif
            -%}
            <div class="block icon-with-text{% if block.settings.contain_width %} block--contained{% endif %}{% if show_accent_image and block.settings.show_in_front_of_accent_image %} in-front-of-accent-image{% endif %}" {{ block.shopify_attributes }}>
              {% render 'block-icon-with-text',
                icon: block.settings.icon,
                header: block.settings.header,
                text: block.settings.text,
                header_font_size: icon_header_font_size,
                text_font_size: icon_text_font_size
              %}
            </div>
          {%- when 'divider' -%}
            <hr class="block border-{{ block.settings.color }}{% if show_accent_image and block.settings.show_in_front_of_accent_image %} in-front-of-accent-image{% endif %}{% if block.settings.contain_width %} block--contained{% endif %}" {{ block.shopify_attributes }}>
          {%- when 'sticker' -%}
            <div
              class="block sticker block--contained{% unless block.settings.animation_style == "static" %} sticker-animated{% endunless %}{% if show_accent_image and block.settings.show_in_front_of_accent_image %} in-front-of-accent-image{% endif %}"
              id="sticker-{{ block.id }}"
              {{ block.shopify_attributes }}
            >
              {%- unless block.settings.animation_style == "static" -%}
                {%- liquid
                  case block.settings.animation_style
                    when 'bounce'
                      case block.settings.animation_speed
                        when 'slow'
                          assign animation_speed = 4
                        when 'medium'
                          assign animation_speed = 3
                        when 'fast'
                          assign animation_speed = 2
                      endcase

                      assign animation = "stickerBounce " | append: animation_speed | append: "s step-end infinite normal"
                    when 'rotate_clockwise', 'rotate_anticlockwise'
                      case block.settings.animation_speed
                        when 'slow' 
                          assign animation_speed = 25
                        when 'medium'
                          assign animation_speed = 15
                        when 'fast'
                          assign animation_speed = 7
                      endcase

                      if block.settings.animation_style == 'rotate_clockwise'
                        assign animation_direction = 'normal'
                      else
                        assign animation_direction = 'reverse'
                      endif

                      assign animation = "rotate " | append: animation_speed | append: "s linear infinite " | append: animation_direction
                  endcase
                -%}
              {%- endunless -%}

              {% style %}
                #shopify-section-{{ section.id }} #sticker-{{ block.id }} .sticker-wrapper {
                  width: {{ block.settings.size | append: 'px'}};
                  {%- unless block.settings.animation_style == "static" -%}
                    margin: {{ block.settings.size | divided_by: 10 | append: 'px'}};
                  {%- endunless -%}
                }

                {%- unless block.settings.animation_style == "static" -%}
                  #shopify-section-{{ section.id }} #sticker-{{ block.id }} img,
                  #shopify-section-{{ section.id }} #sticker-{{ block.id }} svg {
                    animation: {{ animation }};
                  }
                {%- endunless -%}
              {% endstyle %}

              <div class="sticker-wrapper">
                {%- if block.settings.image != blank -%}
                  {% assign widths = '' | append: block.settings.size %}
                  {{ block.settings.image | image_url: width: block.settings.size | image_tag: loading: 'lazy', widths: widths }}
                {%- else -%}
                  {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                {%- endif -%}
              </div>
            </div>
          {% when 'custom_liquid' %}
            <div class="{% if show_accent_image and block.settings.show_in_front_of_accent_image %}in-front-of-accent-image{% endif %}" {{ block.shopify_attributes }}>
              {{ block.settings.custom_liquid }}
            </div>
          {% when '@app' %}
            {% render block %}
        {%- endcase -%}
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "t:sections.content.name",
  "tag": "section",
  "class": "section section-content",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.all.section_styling"
    },
    
    {
      "type": "checkbox",
      "id": "show_top_divider",
      "label": "t:sections.all.show_top_divider.label",
      "default": false
    },
    {
      "type": "color_scheme",
      "id": "divider_color_scheme",
      "default": "scheme-2",
      "label": "t:sections.all.top_divider_color_scheme.label",
      "info": "t:sections.all.top_divider_color_scheme.info",
      "visible_if": "{{ section.settings.show_top_divider }}"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "default": "scheme-1",
      "label": "t:sections.all.color_scheme.label"
    },
    {
      "type": "select",
      "id": "button_style",
      "label": "t:sections.all.buttons.style.label",
      "options": [
        {
          "value": "solid",
          "label": "t:sections.all.buttons.solid.label"
        },
        {
          "value": "outline",
          "label": "t:sections.all.buttons.outline.label"
        },
        {
          "value": "link",
          "label": "t:sections.all.buttons.link.label"
        }
      ],
      "default": "link"
    },
    {
      "type": "header",
      "content": "t:sections.all.accent_image.header.content"
    },
    {
      "type": "checkbox",
      "id": "show_accent_image",
      "label": "t:sections.all.accent_image.show_image.label",
      "default": false
    },
    {
      "type": "image_picker",
      "id": "accent_image",
      "label": "t:sections.all.image.label",
      "info": "t:sections.all.image.info",
      "visible_if": "{{ section.settings.show_accent_image }}"
    },
    {
      "type": "range",
      "id": "accent_vertical_anchor",
      "label": "t:sections.all.accent_image.vertical_anchor.label",
      "info": "t:sections.all.accent_image.vertical_anchor.info",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 0,
      "visible_if": "{{ section.settings.show_accent_image }}"
    },
    {
      "type": "range",
      "id": "accent_horizontal_anchor",
      "label": "t:sections.all.accent_image.horizontal_anchor.label",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 0,
      "visible_if": "{{ section.settings.show_accent_image }}"
    },
    {
      "type": "range",
      "id": "accent_size",
      "min": 10,
      "max": 100,
      "step": 1,
      "unit": "%",
      "label": "t:sections.all.accent_image.image_size.label",
      "info": "t:sections.all.accent_image.image_size.info",
      "default": 30,
      "visible_if": "{{ section.settings.show_accent_image }}"
    },
    {
      "type": "checkbox",
      "id": "hide_accent_on_mobile",
      "label": "t:sections.all.accent_image.hide_on_mobile.label",
      "default": true,
      "visible_if": "{{ section.settings.show_accent_image }}"
    },
    {
      "type": "checkbox",
      "id": "accent_cover",
      "label": "t:sections.all.accent_image.image_cover.label",
      "info": "t:sections.all.accent_image.image_cover.info",
      "default": false,
      "visible_if": "{{ section.settings.show_accent_image }}"
    }
  ],
  "blocks": [
    {
      "type": "heading",
      "name": "t:sections.all.header.label",
      "limit": 3,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "default": "Introduce your brand",
          "label": "t:sections.all.header.label"
        },
        {
          "type": "select",
          "id": "header_tag",
          "label": "t:sections.all.header.header_tag.label",
          "options": [
            {
              "value": "h1",
              "label": "t:sections.all.header.header_tag.h1.label"
            },
            {
              "value": "h2",
              "label": "t:sections.all.header.header_tag.h2.label"
            },
            {
              "value": "h3",
              "label": "t:sections.all.header.header_tag.h3.label"
            },
            {
              "value": "h4",
              "label": "t:sections.all.header.header_tag.h4.label"
            },
            {
              "value": "h5",
              "label": "t:sections.all.header.header_tag.h5.label"
            },
            {
              "value": "h6",
              "label": "t:sections.all.header.header_tag.h6.label"
            }
          ],
          "default": "h2"
        },
        {
          "type": "checkbox",
          "id": "contain_width",
          "label": "t:sections.all.contain_width.label",
          "default": true
        },
        {
          "type": "checkbox",
          "id": "show_in_front_of_accent_image",
          "label": "t:sections.all.accent_image.show_in_front_of_image.label",
          "default": true
        },
        {
          "type": "header",
          "content": "t:sections.all.overrides.header"
        },
        {
          "type": "checkbox",
          "id": "override_default_styles",
          "label": "t:sections.all.overrides.override_default_styles.label",
          "default": false
        },
        {
          "type": "range",
          "id": "override_font_size",
          "min": -10,
          "max": 30,
          "step": 2,
          "label": "t:sections.all.overrides.override_header_font_size.label",
          "default": 0,
          "visible_if": "{{ block.settings.override_default_styles }}"
        }
      ]
    },
    {
      "type": "text",
      "name": "t:sections.all.text.label",
      "limit": 1,
      "settings": [
        {
          "type": "richtext",
          "id": "text",
          "default": "<p>Share your brand story, an important announcement, or something else your customers need to know.</p>",
          "label": "t:sections.all.text.label"
        },
        {
          "type": "checkbox",
          "id": "contain_width",
          "label": "t:sections.all.contain_width.label",
          "default": true
        },
        {
          "type": "checkbox",
          "id": "show_in_front_of_accent_image",
          "label": "t:sections.all.accent_image.show_in_front_of_image.label",
          "default": true
        },
        {
          "type": "header",
          "content": "t:sections.all.overrides.header"
        },
        {
          "type": "checkbox",
          "id": "override_default_styles",
          "label": "t:sections.all.overrides.override_default_styles.label",
          "default": false
        },
        {
          "type": "range",
          "id": "override_font_size",
