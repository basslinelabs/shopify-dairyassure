{%- liquid
  assign show_top_divider = section.settings.show_top_divider
  assign number_of_icons = section.blocks | size
  assign grid_class = 'grid--' | append: number_of_icons
  assign bottom_bar_justify_content = "center"
  if section.settings.show_social == true 
    assign bottom_bar_justify_content = "space-between"
  endif
-%}

{%- style -%}
  {% if section.settings.show_accent_image and section.settings.accent_image %}
    {% render 'styling-section',
      section_id: section.id,
      accent_image: section.settings.accent_image,
      accent_vertical_anchor: section.settings.accent_vertical_anchor,
      accent_horizontal_anchor: section.settings.accent_horizontal_anchor,
      accent_size: section.settings.accent_size,
      hide_accent_on_mobile: section.settings.hide_accent_on_mobile,
      accent_cover: section.settings.accent_cover
    %}
  {% endif %}

  .footer__content-bottom-bar .contained-section {
    justify-content: {{ bottom_bar_justify_content }};
  }
{%- endstyle -%}

<footer id="section-{{ section.id }}" class="footer section-outer">
  {%- if show_top_divider -%}
    <div class="top-divider color-{{ section.settings.divider_color_scheme }}"></div>
  {%- endif -%}
  <div class="section-footer section-content bg-default color-{{ section.settings.color_scheme }}{% if show_top_divider %} has-divider{% endif %}">
    <div class="in-front-of-accent-image">
      {%- if section.blocks.size > 0 -%}
        <div class="footer__content-top grid {{ grid_class }} contained-section">
          {%- for block in section.blocks -%}
            {%- case block.type -%}
              {%- when 'text' -%}
                {%- if block.settings.header or block.settings.subtext -%}
                  <div class="footer-block__item footer-block__details-content rte" {{ block.shopify_attributes }}>
                    {%- if block.settings.header != blank -%}
                      <h4>{{- block.settings.header | escape -}}</h4>
                    {%- endif -%}
                    {%- if block.settings.subtext != blank -%}
                      {{ block.settings.subtext }}
                    {%- endif -%}
                  </div>
                {%- endif -%}
              {%- when 'link_list' -%}
                {%- if block.settings.menu != blank -%}
                  <div class="footer-block__item" {{ block.shopify_attributes }}>
                    {%- if block.settings.header != blank -%}
                      <h4>{{- block.settings.header | escape -}}</h4>
                    {%- endif -%}
                    <ul class="footer-block__details-content list-unstyled">
                      {%- for link in block.settings.menu.links -%}
                        <li>
                          <a href="{{ link.url }}" class="link-reduce">
                            {{ link.title }}
                          </a>
                        </li>
                      {%- endfor -%}
                    </ul>
                  </div>
                {%- endif -%}
              {%- when 'image' -%}
                <div class="footer-block__item footer-block__item-image" {{ block.shopify_attributes }}>
                  {%- if block.settings.image != blank -%}
                    {%- liquid
                      assign size = block.settings.size
                      case size
                        when 'small'
                          assign original_width = 125
                          assign image_width = 125
                          assign image_width_2x = 250
                        when 'large'
                          assign original_width = 300
                          assign image_width = 300
                          assign image_width_2x = 600
                      endcase
                    -%}
                    <img
                      srcset="{{ block.settings.image | image_url: width: image_width }} 1x, {{ block.settings.image | image_url: width: image_width_2x }} 2x"
                      src="{{ block.settings.image | image_url: width: image_width }}"
                      alt="{{ block.settings.image.alt | escape }}"
                      loading="lazy"
                      width="{{ original_width }}"
                      height="auto"
                      style="max-width: min(100%, {{ image_width }}px); height: auto;"
                      class="no-border-radius"
                    >
                  {%- else -%}
                    {{ 'image' | placeholder_svg_tag: 'placeholder-svg placeholder no-border-radius' }}
                  {%- endif -%}
                </div>
              {%- when 'newsletter' -%}
                <div class="footer-block__item" {{ block.shopify_attributes }}>
                  {%- if block.settings.header != blank -%}
                    <h4>{{- block.settings.header | escape -}}</h4>
                  {%- endif -%}
                  {%- if block.settings.subtext != blank -%}
                    {{ block.settings.subtext }}
                  {%- endif -%}
                  <div class="footer-block__newsletter">
                    {%- form 'customer', id: 'ContactFooter', class: 'footer__newsletter newsletter-form' -%}
                      <input type="hidden" name="contact[tags]" value="newsletter">
                      <div class="newsletter-form__field-wrapper">
                        {%- if block.settings.show_name_field -%}
                          <div class="field">
                            <input
                              id="NewsletterForm--{{ section.id }}"
                              type="text"
                              name="contact[first_name]"
                              class="field__input"
                              value="{{ form.name }}"
                              aria-required="true"
                              autocorrect="off"
                              autocapitalize="off"
                              {% if form.errors %}
                                autofocus
                                aria-invalid="true"
                                aria-describedby="ContactFooter-error"
                              {% elsif form.posted_successfully? %}
                                aria-describedby="ContactFooter-success"
                              {% endif %}
                              placeholder="{{ 'newsletter.name' | t }}"
                              required
                            >
                            <label class="field__label" for="NewsletterForm--{{ section.id }}">
                              {{ 'newsletter.name' | t }}
                            </label>
                          </div>
                        {%- endif -%}
                        <div class="field">
                          <input
                            id="NewsletterForm--{{ section.id }}"
                            type="email"
                            name="contact[email]"
                            class="field__input"
                            value="{{ form.email }}"
                            aria-required="true"
                            autocorrect="off"
                            autocapitalize="off"
                            autocomplete="email"
                            {% if form.errors %}
                              autofocus
                              aria-invalid="true"
                              aria-describedby="ContactFooter-error"
                            {% elsif form.posted_successfully? %}
                              aria-describedby="ContactFooter-success"
                            {% endif %}
                            placeholder="{{ 'newsletter.email' | t }}"
                            required
                          >
                          <label class="field__label" for="NewsletterForm--{{ section.id }}">
                            {{ 'newsletter.email' | t }}
                          </label>
                          <button
                            type="submit"
                            class="newsletter-form__button field__button"
                            name="commit"
                            id="Subscribe"
                            aria-label="{{ 'newsletter.button_label' | t }}"
                          >
                            {% render 'icons-main', icon: 'caret' %}
                          </button>
                        </div>
                        {%- if form.errors -%}
                          <small class="newsletter-form__message form__message" id="ContactFooter-error">
                            {%- render 'icons-main', icon: 'cross' -%}
                            {{- form.errors.translated_fields.email | capitalize }}
                            {{ form.errors.messages.email -}}
                          </small>
                        {%- endif -%}
                      </div>
                      {%- if form.posted_successfully? -%}
                        <h3
                          class="newsletter-form__message newsletter-form__message--success form__message"
                          id="ContactFooter-success"
                          tabindex="-1"
                          autofocus
                        >
                          {% render 'icons-main', icon: 'tick' -%}
                          {{- 'newsletter.success' | t }}
                        </h3>
                      {%- endif -%}
                    {%- endform -%}
                  </div>
                </div>
            {%- endcase -%}
          {%- endfor -%}
        </div>
      {%- endif -%}

      <div class="footer__content-bottom">
        <div class="footer__content-bottom-bar{% if section.settings.show_dividers %} footer__content-bottom-bar--dividers{% endif %}">
          <div class="contained-section">
            <div class="footer__content-bottom-bar--links">
              <small class="copyright__content"
                >&copy; {{ 'now' | date: '%Y' }}, {{ shop.name | link_to: routes.root_url -}}
              </small>
              <small class="copyright__content copyright__content--powered_by">{{ powered_by_link }}</small>
              {%- for link in section.settings.bottom_bar_menu.links -%}
                <small>
                  |
                  <a href="{{ link.url }}" class="link">
                    {{ link.title }}
                  </a>
                </small>
              {%- endfor -%}
              {%- if section.settings.show_policy_links -%}
                {%- for policy in shop.policies -%}
                  {%- if policy != blank -%}
                    <small>
                      |
                      <a href="{{ policy.url }}" class="link">
                        {{ policy.title | escape }}
                      </a>
                    </small >
                  {%- endif -%}
                {%- endfor -%}
              {%- endif -%}
            </div>
            {%- if section.settings.show_social -%}
              <div class="footer__content-bottom-bar--social-media-icons">
                {% render 'social-media-icons' %}
              </div>
            {%- endif -%}
          </div>
        </div>
        {%- if shop.features.follow_on_shop? and section.settings.show_follow_on_shop -%}
          <div class="footer__follow-on-shop">
            {{ shop | login_button: action: 'follow' }}
          </div>
        {%- endif -%}
        <div class="footer__content-admin">
          {%- if section.settings.enable_payment_icons -%}
            <div class="footer__content-admin--payment">
              <span class="visually-hidden">{{ 'sections.footer.payment' | t }}</span>
              {% render 'payment-icons' %}
            </div>
          {%- endif -%}
        </div>
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "t:sections.footer.name",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.all.section_content"
    },
    {
      "type": "link_list",
      "id": "bottom_bar_menu",
      "default": "footer",
      "label": "t:sections.footer.settings.bottom_bar_menu.label",
      "info": "t:sections.footer.settings.bottom_bar_menu.info"
    },
    {
      "type": "checkbox",
      "id": "show_policy_links",
      "default": false,
      "label": "t:sections.footer.settings.show_policy_links.label"
    },
    {
      "type": "checkbox",
      "id": "show_dividers",
      "default": true,
      "label": "t:sections.footer.settings.show_dividers.label"
    },
    {
      "type": "checkbox",
      "id": "enable_payment_icons",
      "default": true,
      "label": "t:sections.footer.settings.enable_payment_icons.label"
    },
    {
      "type": "checkbox",
      "id": "show_social",
      "default": true,
      "label": "t:sections.footer.settings.show_social.label",
      "info": "t:sections.footer.settings.show_social.info"
    },
    {
      "type": "checkbox",
      "id": "show_follow_on_shop",
      "default": true,
      "label": "t:sections.footer.settings.show_follow_on_shop.label",
      "info": "t:sections.footer.settings.show_follow_on_shop.info"
    },
    {
      "type": "header",
      "content": "t:sections.all.section_styling"
    },
    {
      "type": "checkbox",
      "id": "show_top_divider",
      "label": "t:sections.all.show_top_divider.label",
      "default": false
    },
    {
      "type": "color_scheme",
      "id": "divider_color_scheme",
      "default": "scheme-1",
      "label": "t:sections.all.top_divider_color_scheme.label",
      "info": "t:sections.all.top_divider_color_scheme.info",
      "visible_if": "{{ section.settings.show_top_divider }}"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "default": "scheme_1",
      "label": "t:sections.all.color_scheme.label"
    },
    {
      "type": "header",
      "content": "t:sections.all.accent_image.header.content"
    },
    {
      "type": "checkbox",
      "id": "show_accent_image",
      "label": "t:sections.all.accent_image.show_image.label",
      "default": false
    },
    {
      "type": "image_picker",
      "id": "accent_image",
      "label": "t:sections.all.image.label",
      "info": "t:sections.all.image.info",
      "visible_if": "{{ section.settings.show_accent_image }}"
    },
    {
      "type": "range",
      "id": "accent_horizontal_anchor",
      "label": "t:sections.all.accent_image.horizontal_anchor.label",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 0,
      "visible_if": "{{ section.settings.show_accent_image }}"
    },
    {
      "type": "range",
      "id": "accent_vertical_anchor",
      "label": "t:sections.all.accent_image.vertical_anchor.label",
      "info": "t:sections.all.accent_image.vertical_anchor.info",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 0,
      "visible_if": "{{ section.settings.show_accent_image }}"
    },
    {
      "type": "range",
      "id": "accent_size",
      "min": 10,
      "max": 100,
      "step": 1,
      "unit": "%",
      "label": "t:sections.all.accent_image.image_size.label",
      "info": "t:sections.all.accent_image.image_size.info",
      "default": 30,
      "visible_if": "{{ section.settings.show_accent_image }}"
    },
    {
      "type": "checkbox",
      "id": "hide_accent_on_mobile",
      "label": "t:sections.all.accent_image.hide_on_mobile.label",
      "default": true,
      "visible_if": "{{ section.settings.show_accent_image }}"
    },
    {
      "type": "checkbox",
      "id": "accent_cover",
      "label": "t:sections.all.accent_image.image_cover.label",
      "info": "t:sections.all.accent_image.image_cover.info",
      "default": false,
      "visible_if": "{{ section.settings.show_accent_image }}"
    }
  ],
  "max_blocks": 4,
  "blocks": [
    {
      "type": "link_list",
      "name": "t:sections.footer.blocks.link_list.name",
      "settings": [
        {
          "type": "text",
          "id": "header",
          "default": "Customer Service",
          "label": "t:sections.footer.blocks.link_list.settings.header.label",
          "info": "t:sections.footer.blocks.link_list.settings.header.info"
        },
        {
          "type": "link_list",
          "id": "menu",
          "default": "footer",
          "label": "t:sections.footer.blocks.link_list.settings.menu.label",
          "info": "t:sections.footer.blocks.link_list.settings.menu.info"
        }
      ]
    },
    {
      "type": "text",
      "name": "t:sections.footer.blocks.text.name",
      "settings": [
        {
          "type": "text",
          "id": "header",
          "default": "About the brand",
          "label": "t:sections.footer.blocks.text.settings.header.label"
        },
        {
          "type": "richtext",
          "id": "subtext",
          "default": "<p>Tell customers about your brand, and what makes it special.</p>",
          "label": "t:sections.footer.blocks.text.settings.subtext.label"
        }
      ]
    },
    {
      "type": "image",
      "name": "t:sections.footer.blocks.image.name",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:sections.footer.blocks.image.settings.image.label",
          "info": "t:sections.footer.blocks.image.settings.image.info"
        },
        {
          "type": "select",
          "id": "size",
          "label": "t:sections.footer.blocks.image.settings.size.label",
          "options": [
            {
              "value": "small",
              "label": "t:sections.footer.blocks.image.settings.size.options__small"
            },
            {
              "value": "large",
              "label": "t:sections.footer.blocks.image.settings.size.options__large"
            }
          ],
          "default": "small"
        }
      ]
    },
    {
      "type": "newsletter",
      "name": "t:sections.footer.blocks.newsletter.name",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "header",
          "default": "Join our newsletter",
          "label": "t:sections.footer.blocks.newsletter.settings.header.label"
        },
        {
          "type": "richtext",
          "id": "subtext",
          "default": "<p>and enjoy 10% off your first purchase!</p>",
          "label": "t:sections.footer.blocks.newsletter.settings.subtext.label"
        },
        {
          "type": "checkbox",
          "id": "show_name_field",
          "default": false,
          "label": "t:sections.footer.blocks.newsletter.settings.show_name_field.label"
        }
      ]
    }
  ],
  "default": {
    "blocks": [
      {
        "type": "image"
      },
      {
        "type": "link_list"
      },
      {
        "type": "text"
      },
      {
        "type": "newsletter"
      }
    ]
  }
}
{% endschema %}
