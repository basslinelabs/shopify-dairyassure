                                      {%- if childlink.links == blank -%}
                                        <a href="{{ childlink.url }}" class="header__menu-item list-menu__item link-reduce"{% if childlink.current %} aria-current="page"{% endif %}>
                                          {{ childlink.title | escape }}
                                        </a>
                                      {%- else -%}
