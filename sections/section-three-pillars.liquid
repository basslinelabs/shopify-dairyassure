{{ 'section-three-pillars.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div
  class="da-pillars section-{{ section.id }}-padding{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
>
  <div class="page-width">
    <div class="da-pillars__header">
      <h2 class="da-pillars__heading">{{ section.settings.heading }}</h2>
      <p class="da-pillars__subheading">{{ section.settings.subheading }}</p>
    </div>

    <div class="da-pillars__grid">
      {%- for block in section.blocks -%}
        <div
          class="da-pillars__card-wrapper{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
          {{ block.shopify_attributes }}
          {% if settings.animations_reveal_on_scroll %}
            data-cascade
            style="--animation-order: {{ forloop.index }};"
          {% endif %}
        >
          <div class="da-pillars__card">
            {%- if block.settings.icon != blank -%}
              {{
                block.settings.icon
                | image_url: width: 96
                | image_tag:
                  class: 'da-pillars__icon',
                  loading: 'lazy',
                  alt: block.settings.title
              }}
            {%- endif -%}
            <p class="da-pillars__number">{{ block.settings.number }}</p>
            <h3 class="da-pillars__title">{{ block.settings.title }}</h3>
            <p class="da-pillars__description">{{ block.settings.description }}</p>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "DA How It Works",
  "tag": "section",
  "class": "section section--three-pillars",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "How It Works" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Three steps. Zero effort." },
    { "type": "header", "content": "Section padding" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding top", "default": 48 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding bottom", "default": 48 }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "limit": 4,
      "settings": [
        { "type": "text", "id": "number", "label": "Step number", "default": "1" },
        { "type": "text", "id": "title", "label": "Title", "default": "Sprinkle" },
        { "type": "textarea", "id": "description", "label": "Description", "default": "Add to any dairy food or drink." },
        { "type": "image_picker", "id": "icon", "label": "Icon image (optional)" }
      ]
    }
  ],
  "presets": [
    {
      "name": "DA How It Works",
      "blocks": [
        { "type": "step", "settings": { "number": "1", "title": "Sprinkle", "description": "Add to any dairy food or drink." } },
        { "type": "step", "settings": { "number": "2", "title": "Eat", "description": "Eat your meal as you normally would." } },
        { "type": "step", "settings": { "number": "3", "title": "Enjoy", "description": "No discomfort. No drama. Just joy." } }
      ]
    }
  ],
  "enabled_on": { "templates": ["index"] }
}
{% endschema %}
