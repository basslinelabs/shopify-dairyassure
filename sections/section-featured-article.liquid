{%- liquid
  assign show_top_divider = section.settings.show_top_divider

  case section.settings.image_width
    when '33.3333%'
      assign image_width = '500'
    when '50%'
      assign image_width = '750'
    when '66.6666%'
      assign image_width = '1000'
  endcase

  if section.settings.latest_blog_post != blank
    assign article = blogs[section.settings.latest_blog_post.handle].articles.first
  else
    assign article = section.settings.article
  endif

  if section.settings.image != blank
    assign image = section.settings.image
  else
    assign image = article.image
  endif

-%}

{%- style -%}
  {% if section.settings.show_accent_image and section.settings.accent_image %}
    {% render 'styling-section',
      section_id: section.id,
      accent_image: section.settings.accent_image,
      accent_vertical_anchor: section.settings.accent_vertical_anchor,
      accent_horizontal_anchor: section.settings.accent_horizontal_anchor,
      accent_size: section.settings.accent_size,
      hide_accent_on_mobile: section.settings.hide_accent_on_mobile,
      accent_cover: section.settings.accent_cover
    %}
  {% endif %}
  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} .featured-article-image {
      width: {{ section.settings.image_width }};
    }
    #shopify-section-{{ section.id }} .featured-article-text {
      width: calc(100% - {{ section.settings.image_width }});
    }
  }
  {%- if section.settings.image_position == "right" -%}
    #shopify-section-{{ section.id }} .featured-article {
      flex-direction: row-reverse;
    }
  {%- endif -%}
{%- endstyle -%}

{% if article != blank %}
  {%- if show_top_divider -%}
    <div class="top-divider color-{{ section.settings.divider_color_scheme }}"></div>
  {%- endif -%}

  <div class="section-outer{% if show_top_divider %} has-divider{% endif %}">
    <div class="section-standard section--featured-article section-content bg-default color-{{ section.settings.color_scheme }}"{% if section.settings.override_default_styles %} style="--override-padding-top: {{ section.settings.override_space_above }}px; --override-padding-bottom: {{ section.settings.override_space_below }}px;"{% endif %}>
      <div class="contained-section">
        <div class="featured-article flex">
          <div class="featured-article-image">
            {%- if image != blank -%}
              {% assign widths = '600, ' | append: image_width %}
              {{ image | image_url: width: image_width | image_tag: loading: 'lazy', widths: widths }}
            {%- else -%}
              {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}
          </div>
          <div class="featured-article-text contained-inner-section">
            {%- for block in section.blocks -%}
              {%- case block.type -%}
                {%- when 'title' -%}
                  {%- if article.title != blank -%}
                    <{{ block.settings.header_tag }} {{ block.shopify_attributes }}>
                      {{- article.title -}}
                    </{{ block.settings.header_tag }}>
                  {%- endif -%}
                {%- when 'date' -%}
                  <div class="featured-post__date h5" {{ block.shopify_attributes }}>
                    <p>{{ article.published_at | time_tag: format: 'date' }}</p>
                  </div>
                {%- when 'author' -%}
                  <div class="featured-post__author h5" {{ block.shopify_attributes }}>
                    <p>{{ article.author }}</p>
                  </div>
                {%- when 'post_content' -%}
                  <div class="featured-article__post_excerpt rte" {{ block.shopify_attributes }}>
                    {{ article.excerpt_or_content | strip_html | truncatewords: block.settings.excerpt_length }}
                  </div>
                {%- when 'read_more_button' -%}
                  {%- if block.settings.button_text != blank -%}
                    <a
                      href="{{ article.url }}"
                      class="{{ block.settings.button_style }} button--styled{% unless block.settings.button_style == "link" %} button{% endunless %}"
                      {{ block.shopify_attributes }}
                    >
                      {{ block.settings.button_text }}
                    </a>
                  {%- endif -%}
                {%- when 'comments' -%}
                  {%- if article.comments_count > 0 and blog.comments_enabled? -%}
                    <div class="featured-post__comments" {{ block.shopify_attributes }}>
                      {{ 'blogs.article.comments' | t: count: article.comments_count }}
                    </div>
                  {%- endif -%}
                {%- when 'text' -%}
                  {%- if block.settings.text != blank -%}
                    <div {{ block.shopify_attributes }}>{{ block.settings.text }}</div>
                  {%- endif -%}
              {%- endcase -%}
            {%- endfor -%}
          </div>
        </div>
      </div>
    </div>
  </div>
{% endif %}

{% schema %}
{
  "name": "t:sections.featured-article.name",
  "tag": "section",
  "class": "section section-featured-article",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.all.section_content"
    },
    {
      "type": "article",
      "id": "article",
      "label": "t:sections.featured-article.settings.article.label"
    },
    {
      "type": "blog",
      "id": "latest_blog_post",
      "label": "t:sections.featured-article.settings.latest_blog_post.label",
      "info": "t:sections.featured-article.settings.latest_blog_post.info"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:sections.all.image.label",
      "info": "t:sections.featured-article.settings.image.info"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "t:sections.featured-article.settings.image_position.label",
      "options": [
        {
          "value": "left",
          "label": "t:sections.featured-article.settings.image_position.left.label"
        },
        {
          "value": "right",
          "label": "t:sections.featured-article.settings.image_position.right.label"
        }
      ],
      "default": "left"
    },
    {
      "type": "select",
      "id": "image_width",
      "label": "t:sections.featured-article.settings.image_width.label",
      "info": "t:sections.featured-article.settings.image_width.info",
      "options": [
        {
          "value": "33.3333%",
          "label": "t:sections.featured-article.settings.image_width.one_third.label"
        },
        {
          "value": "50%",
          "label": "t:sections.featured-article.settings.image_width.one_half.label"
        },
        {
          "value": "66.6666%",
          "label": "t:sections.featured-article.settings.image_width.two_thirds.label"
        }
      ],
      "default": "50%"
    },
    {
      "type": "header",
      "content": "t:sections.all.section_styling"
    },
    {
      "type": "checkbox",
      "id": "show_top_divider",
      "label": "t:sections.all.show_top_divider.label",
      "default": false
    },
    {
      "type": "color_scheme",
      "id": "divider_color_scheme",
      "default": "scheme-2",
      "label": "t:sections.all.top_divider_color_scheme.label",
      "info": "t:sections.all.top_divider_color_scheme.info",
      "visible_if": "{{ section.settings.show_top_divider }}"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "default": "scheme-1",
      "label": "t:sections.all.color_scheme.label"
    },
    {
      "type": "header",
      "content": "t:sections.all.accent_image.header.content"
    },
    {
      "type": "checkbox",
      "id": "show_accent_image",
      "label": "t:sections.all.accent_image.show_image.label",
      "default": false
    },
    {
      "type": "image_picker",
      "id": "accent_image",
      "label": "t:sections.all.image.label",
      "info": "t:sections.all.image.info",
      "visible_if": "{{ section.settings.show_accent_image }}"
    },
    {
      "type": "range",
      "id": "accent_horizontal_anchor",
      "label": "t:sections.all.accent_image.horizontal_anchor.label",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 0,
      "visible_if": "{{ section.settings.show_accent_image }}"
    },
    {
      "type": "range",
      "id": "accent_vertical_anchor",
      "label": "t:sections.all.accent_image.vertical_anchor.label",
      "info": "t:sections.all.accent_image.vertical_anchor.info",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 0,
      "visible_if": "{{ section.settings.show_accent_image }}"
    },
    {
      "type": "range",
      "id": "accent_size",
      "min": 10,
      "max": 100,
      "step": 1,
      "unit": "%",
      "label": "t:sections.all.accent_image.image_size.label",
      "info": "t:sections.all.accent_image.image_size.info",
      "default": 30,
      "visible_if": "{{ section.settings.show_accent_image }}"
    },
    {
      "type": "checkbox",
      "id": "hide_accent_on_mobile",
      "label": "t:sections.all.accent_image.hide_on_mobile.label",
      "default": true,
      "visible_if": "{{ section.settings.show_accent_image }}"
    },
    {
      "type": "checkbox",
      "id": "accent_cover",
      "label": "t:sections.all.accent_image.image_cover.label",
      "info": "t:sections.all.accent_image.image_cover.info",
      "default": false,
      "visible_if": "{{ section.settings.show_accent_image }}"
    },
    {
      "type": "header",
      "content": "t:sections.all.overrides.header"
    },
    {
      "type": "checkbox",
      "id": "override_default_styles",
      "label": "t:sections.all.overrides.override_default_styles.label",
      "info": "t:sections.all.overrides.override_default_styles.info",
      "default": false
    },
    {
      "type": "header",
      "content": "t:sections.all.overrides.header_section.label",
      "visible_if": "{{ section.settings.override_default_styles }}"
    },
    {
      "type": "range",
      "id": "override_space_above",
      "min": -50,
      "max": 100,
      "step": 10,
      "default": 0,
      "label": "t:sections.all.overrides.override_space_above.label",
      "visible_if": "{{ section.settings.override_default_styles }}"
    },
    {
      "type": "range",
      "id": "override_space_below",
      "min": -50,
      "max": 100,
      "step": 10,
      "default": 0,
      "label": "t:sections.all.overrides.override_space_below.label",
      "visible_if": "{{ section.settings.override_default_styles }}"
    }
  ],
  "blocks": [
    {
      "type": "title",
      "name": "t:sections.featured-article.blocks.title.name",
      "limit": 1,
      "settings": [
        {
          "type": "select",
          "id": "header_tag",
          "label": "t:sections.all.header.header_tag.label",
          "options": [
            {
              "value": "h1",
              "label": "t:sections.all.header.header_tag.h1.label"
            },
            {
              "value": "h2",
              "label": "t:sections.all.header.header_tag.h2.label"
            },
            {
              "value": "h3",
              "label": "t:sections.all.header.header_tag.h3.label"
            },
            {
              "value": "h4",
              "label": "t:sections.all.header.header_tag.h4.label"
            },
            {
              "value": "h5",
              "label": "t:sections.all.header.header_tag.h5.label"
            },
            {
              "value": "h6",
              "label": "t:sections.all.header.header_tag.h6.label"
            }
          ],
          "default": "h2"
        }
      ]
    },
    {
      "type": "date",
      "name": "t:sections.featured-article.blocks.date.name",
      "limit": 1
    },
    {
      "type": "author",
      "name": "t:sections.featured-article.blocks.author.name",
      "limit": 1
    },
    {
      "type": "post_content",
      "name": "t:sections.featured-article.blocks.post_content.name",
      "limit": 1,
      "settings": [
        {
          "type": "range",
          "id": "excerpt_length",
          "min": 10,
          "max": 200,
          "step": 10,
          "label": "t:sections.featured-article.blocks.post_content.settings.excerpt_length.label",
          "default": 50
        }
      ]
    },
    {
      "type": "read_more_button",
      "name": "t:sections.featured-article.blocks.read_more_button.name",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "button_text",
          "default": "Read more",
          "label": "t:sections.all.buttons.button_text.label"
        },
        {
          "type": "select",
          "id": "button_style",
          "label": "t:sections.all.buttons.style.label",
          "options": [
            {
              "value": "solid",
              "label": "t:sections.all.buttons.solid.label"
            },
            {
              "value": "outline",
              "label": "t:sections.all.buttons.outline.label"
            },
            {
              "value": "link",
              "label": "t:sections.all.buttons.link.label"
            }
          ],
          "default": "link"
        }
      ]
    },
    {
      "type": "comments",
      "name": "t:sections.featured-article.blocks.comments.name",
      "limit": 1
    },
    {
      "type": "text",
      "name": "t:sections.featured-article.blocks.text.name",
      "limit": 1,
      "settings": [
        {
          "type": "richtext",
          "id": "text",
          "default": "<p>Highlight what makes your brand special, a new product range, or maybe a sale.</p>",
          "label": "t:sections.all.text.label"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.featured-article.presets.name",
      "category": "t:settings_schema.groups.blog",
      "blocks": [
        {
          "type": "date"
        },
        {
          "type": "title"
        },
        {
          "type": "post_content"
        },
        {
          "type": "read_more_button"
        }
      ]
    }
  ]
}
{% endschema %}
