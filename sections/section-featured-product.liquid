{%- render 'product',
  section: section,
  product: section.settings.product
-%}

{% schema %}
{
  "name": "t:sections.main-product.name",
  "tag": "section",
  "class": "section",
  "blocks": [
    {
      "type": "@app"
    },
    {
      "type": "text",
      "name": "t:sections.all.text.label",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "default": "Text block",
          "label": "t:sections.all.text.label"
        },
        {
          "type": "select",
          "id": "background",
          "options": [
            {
              "value": "default",
              "label": "t:sections.all.colors.default.label"
            },
            {
              "value": "accent",
              "label": "t:sections.all.colors.accent.label"
            },
            {
              "value": "contrast",
              "label": "t:sections.all.colors.contrast.label"
            }
          ],
          "default": "default",
          "label": "t:sections.all.colors.color.label"
        },
        {
          "id": "show_as_badge",
          "type": "checkbox",
          "default": false,
          "label": "t:sections.main-product.blocks.text.settings.show_as_badge.label"
        }
      ]
    },
    {
      "type": "title",
      "name": "t:sections.main-product.blocks.title.name",
      "limit": 1, 
      "settings": [
        {
          "type": "select",
          "id": "header_tag",
          "label": "t:sections.all.header.header_tag.label",
          "options": [
            {
              "value": "h1",
              "label": "t:sections.all.header.header_tag.h1.label"
            },
            {
              "value": "h2",
              "label": "t:sections.all.header.header_tag.h2.label"
            },
            {
              "value": "h3",
              "label": "t:sections.all.header.header_tag.h3.label"
            },
            {
              "value": "h4",
              "label": "t:sections.all.header.header_tag.h4.label"
            },
            {
              "value": "h5",
              "label": "t:sections.all.header.header_tag.h5.label"
            },
            {
              "value": "h6",
              "label": "t:sections.all.header.header_tag.h6.label"
            }
          ],
          "default": "h2"
        }
      ]
    },
    {
      "type": "price",
      "name": "t:sections.main-product.blocks.price.name",
      "limit": 1
    },
    {
      "type": "variant_picker",
      "name": "t:sections.main-product.blocks.variant_picker.name",
      "limit": 1,
      "settings": [
        {
          "type": "select",
          "id": "picker_type",
          "options": [
            {
              "value": "dropdown",
              "label": "t:sections.main-product.blocks.variant_picker.settings.picker_type.options__1.label"
            },
            {
              "value": "button",
              "label": "t:sections.main-product.blocks.variant_picker.settings.picker_type.options__2.label"
            }
          ],
          "default": "button",
          "label": "t:sections.main-product.blocks.variant_picker.settings.picker_type.label"
        },
        {
          "type": "header",
          "content": "t:sections.main-product.blocks.variant_picker.settings.header.content",
          "info": "t:sections.main-product.blocks.variant_picker.settings.header.info"
        },
        {
          "type": "text",
          "id": "option_names",
          "label": "t:sections.main-product.blocks.linked_products.settings.option_name.label",
          "default": "color, colour"
        },
        {
          "type": "select",
          "id": "swatch_style",
          "label": "t:sections.main-product.blocks.linked_products.settings.swatch_style.label",
          "options": [
            {
              "value": "color_swatch",
              "label": "t:sections.main-product.blocks.linked_products.settings.swatch_style.options.color_swatch.label"
            },
            {
              "value": "image_swatch",
              "label": "t:sections.main-product.blocks.linked_products.settings.swatch_style.options.image_swatch.label"
            }
          ],
          "default": "color_swatch"
        }
      ]
    },
    {
      "type": "buy_buttons",
      "name": "t:sections.main-product.blocks.buy_buttons.name",
      "limit": 1,
      "settings": [
        {
          "type": "checkbox",
          "id": "show_quantity_selector",
          "default": true,
          "label": "t:sections.main-product.blocks.buy_buttons.settings.show_quantity_selector.label"
        },
        {
          "type": "checkbox",
          "id": "show_dynamic_checkout",
          "default": true,
          "label": "t:sections.main-product.blocks.buy_buttons.settings.show_dynamic_checkout.label",
          "info": "t:sections.main-product.blocks.buy_buttons.settings.show_dynamic_checkout.info"
        }
      ]
    },
    {
      "type": "description",
      "name": "t:sections.main-product.blocks.description.name",
      "limit": 1
    },
    {
      "type": "custom_liquid",
      "name": "t:sections.all.custom_liquid.name",
      "settings": [
        {
          "type": "liquid",
          "id": "custom_liquid",
          "label": "t:sections.all.custom_liquid.custom_liquid.label",
          "info": "t:sections.all.custom_liquid.custom_liquid.info"
        }
      ]
    },
    {
      "type": "collapsible_tab",
      "name": "t:sections.all.collapsible_row.name",
      "limit": 10,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "default": "Row header",
          "label": "t:sections.all.collapsible_row.heading.label"
        },
        {
          "type": "richtext",
          "id": "content",
          "default": "<p>Row content</p>",
          "label": "t:sections.all.collapsible_row.content.label"
        },
        {
          "type": "page",
          "id": "page",
          "label": "t:sections.all.collapsible_row.page.label"
        },
        {
          "type": "checkbox",
          "id": "open_tab",
          "label": "t:sections.all.collapsible_row.open_tab.label"
        },
        {
          "type": "checkbox",
          "id": "show_in_front_of_accent_image",
          "label": "t:sections.all.accent_image.show_in_front_of_image.label",
          "default": true
        }
      ]
    },
    {
      "type": "rating",
      "name": "t:sections.main-product.blocks.rating.name",
      "settings": [
        {
          "type": "paragraph",
          "content": "t:sections.main-product.blocks.rating.settings.paragraph.content"
        }
      ]
    },
    {
      "type": "divider",
      "name": "t:sections.all.divider.name",
      "settings": [
        {
          "type": "select",
          "id": "color",
          "label": "t:sections.all.divider.settings.color.label",
          "options": [
            {
              "value": "accent",
              "label": "t:sections.all.divider.settings.color.accent.label"
            },
            {
              "value": "contrast",
              "label": "t:sections.all.divider.settings.color.contrast.label"
            }
          ],
          "default": "contrast"
        },
        {
          "type": "checkbox",
          "id": "contain_width",
          "label": "t:sections.all.contain_width.label",
          "default": false
        }
      ]
    },
    {
      "type": "low_stock",
      "name": "t:sections.main-product.blocks.low_stock.name",
      "settings": [
        {
          "type": "range",
          "id": "threshold",
          "min": 1,
          "max": 10,
          "step": 1,
          "label": "t:sections.main-product.blocks.low_stock.settings.threshold.label",
          "info": "t:sections.main-product.blocks.low_stock.settings.threshold.info",
          "default": 2
        }
      ]
    },
    {
      "type": "payment_icons",
      "name": "t:sections.main-product.blocks.payment_icons.name"
    },
    {
      "type": "linked_products",
      "name": "t:sections.main-product.blocks.linked_products.name",
      "limit": 1,
      "settings": [
        {
          "type": "paragraph",
          "content": "t:sections.main-product.blocks.linked_products.settings.content"
        },
        {
          "type": "text",
          "id": "delimiter",
          "label": "t:sections.main-product.blocks.linked_products.settings.delimiter.label",
          "info": "t:sections.main-product.blocks.linked_products.settings.delimiter.info",
          "default": "|"
        },
        {
          "type": "text",
          "id": "option_name",
          "label": "t:sections.main-product.blocks.linked_products.settings.option_name.label",
          "default": "Color"
        },
        {
          "type": "checkbox",
          "id": "hide_for_sold_out_products",
          "label": "t:sections.main-product.blocks.linked_products.settings.hide_for_sold_out_products.label",
          "default": true
        },
        {
          "type": "checkbox",
          "id": "allow_oos_link",
          "label": "t:sections.main-product.blocks.linked_products.settings.allow_oos_link.label",
          "info": "t:sections.main-product.blocks.linked_products.settings.allow_oos_link.info",
          "default": true
        },
        {
          "type": "select",
          "id": "swatch_style",
          "label": "t:sections.main-product.blocks.linked_products.settings.swatch_style.label",
          "info": "t:sections.main-product.blocks.linked_products.settings.swatch_style.info",
          "options": [
            {
              "value": "text_link",
              "label": "t:sections.main-product.blocks.linked_products.settings.swatch_style.options.text_link.label"
            },
            {
              "value": "color_swatch",
              "label": "t:sections.main-product.blocks.linked_products.settings.swatch_style.options.color_swatch.label"
            },
            {
              "value": "image_swatch",
              "label": "t:sections.main-product.blocks.linked_products.settings.swatch_style.options.image_swatch.label"
            }
          ],
          "default": "text_link"
        }
      ]
    },
    {
      "type": "button",
      "name": "t:sections.all.buttons.heading",
      "settings": [
        {
          "type": "text",
          "id": "button_text",
          "default": "Learn more",
          "label": "t:sections.all.buttons.button_text.label"
        },
        {
          "type": "url",
          "id": "button_link",
          "default": "/collections",
          "label": "t:sections.all.buttons.button_link.label"
        },
        {
          "type": "select",
          "id": "button_style",
          "label": "t:sections.all.buttons.style.label",
          "options": [
            {
              "value": "solid",
              "label": "t:sections.all.buttons.solid.label"
            },
            {
              "value": "outline",
              "label": "t:sections.all.buttons.outline.label"
            },
            {
              "value": "link",
              "label": "t:sections.all.buttons.link.label"
            }
          ],
          "default": "solid"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "header",
      "content": "t:sections.main-product.settings.header.content",
      "info": "t:sections.main-product.settings.header.info"
    },
    {
      "type": "product",
      "id": "product",
      "label": "t:sections.featured-product.settings.product.label"
    },
    {
      "type": "select",
      "id": "media_size",
      "options": [
        {
          "value": "small",
          "label": "t:sections.main-product.settings.media_size.options__1.label"
        },
        {
          "value": "medium",
          "label": "t:sections.main-product.settings.media_size.options__2.label"
        },
        {
          "value": "large",
          "label": "t:sections.main-product.settings.media_size.options__3.label"
        }
      ],
      "default": "large",
      "label": "t:sections.main-product.settings.media_size.label",
      "info": "t:sections.main-product.settings.media_size.info"
    },
    {
      "type": "select",
      "id": "desktop_media_layout",
      "options": [
        {
          "value": "stacked",
          "label": "t:sections.all.layout.stacked.label"
        },
        {
          "value": "slider",
          "label": "t:sections.all.layout.slider.label"
        }
      ],
      "default": "stacked",
      "label": "t:sections.main-product.settings.desktop_media_layout.label",
    },
    {
      "type": "checkbox",
      "id": "mobile_show_arrows",
      "default": false,
      "label": "t:sections.main-product.settings.mobile_show_arrows.label",
    },
    {
      "type": "select",
      "id": "mobile_pagination",
      "options": [
        {
          "value": "dots",
          "label": "t:sections.main-product.settings.mobile_pagination.dots.label"
        },
        {
          "value": "thumbnails",
          "label": "t:sections.main-product.settings.mobile_pagination.thumbnails.label"
        }
      ],
      "default": "dots",
      "label": "t:sections.main-product.settings.mobile_pagination.label",
    },
    {
      "type": "header",
      "content": "t:sections.all.section_styling"
    },
    {
      "type": "checkbox",
      "id": "show_top_divider",
      "label": "t:sections.all.show_top_divider.label",
      "default": false
    },
    {
      "type": "color_scheme",
      "id": "divider_color_scheme",
      "default": "scheme-2",
      "label": "t:sections.all.top_divider_color_scheme.label",
      "info": "t:sections.all.top_divider_color_scheme.info",
      "visible_if": "{{ section.settings.show_top_divider }}"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "default": "scheme-1",
      "label": "t:sections.all.color_scheme.label"
    },
    {
      "type": "text_alignment",
      "id": "section_alignment",
      "label": "t:sections.all.section_alignment.label",
      "default": "center"
    },
    {
      "type": "header",
      "content": "t:sections.all.accent_image.header.content"
    },
    {
      "type": "checkbox",
      "id": "show_accent_image",
      "label": "t:sections.all.accent_image.show_image.label",
      "default": false
    },
    {
      "type": "image_picker",
      "id": "accent_image",
      "label": "t:sections.all.image.label",
      "info": "t:sections.all.image.info",
      "visible_if": "{{ section.settings.show_accent_image }}"
    },
    {
      "type": "range",
      "id": "accent_horizontal_anchor",
      "label": "t:sections.all.accent_image.horizontal_anchor.label",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 0,
      "visible_if": "{{ section.settings.show_accent_image }}"
    },
    {
      "type": "range",
      "id": "accent_vertical_anchor",
      "label": "t:sections.all.accent_image.vertical_anchor.label",
      "info": "t:sections.all.accent_image.vertical_anchor.info",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 0,
      "visible_if": "{{ section.settings.show_accent_image }}"
    },
    {
      "type": "range",
      "id": "accent_size",
      "min": 10,
      "max": 100,
      "step": 1,
      "unit": "%",
      "label": "t:sections.all.accent_image.image_size.label",
      "info": "t:sections.all.accent_image.image_size.info",
      "default": 30,
      "visible_if": "{{ section.settings.show_accent_image }}"
    },
    {
      "type": "checkbox",
      "id": "hide_accent_on_mobile",
      "label": "t:sections.all.accent_image.hide_on_mobile.label",
      "default": true,
      "visible_if": "{{ section.settings.show_accent_image }}"
    },
    {
      "type": "checkbox",
      "id": "accent_cover",
      "label": "t:sections.all.accent_image.image_cover.label",
      "info": "t:sections.all.accent_image.image_cover.info",
      "default": false,
      "visible_if": "{{ section.settings.show_accent_image }}"
    }
  ],
  "presets": [
    {
      "name": "t:sections.featured-product.presets.name",
      "category": "t:settings_schema.groups.product",
      "blocks": [
        {
          "type": "title"
        },
        {
          "type": "divider"
        },
        {
          "type": "price"
        },
        {
          "type": "divider"
        },
        {
          "type": "variant_picker"
        },
        {
          "type": "buy_buttons"
        },
        {
          "type": "description"
        }
      ]
    }
  ],
  "disabled_on": {
    "templates": ["password"]
  }
}
{% endschema %}
