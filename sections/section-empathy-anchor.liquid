{{ 'section-empathy-anchor.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div
  class="da-stats da-bg-cream section-{{ section.id }}-padding{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
>
  <div class="page-width">
    <div class="da-stats__header">
      <h2 class="da-stats__heading">{{ section.settings.heading }}</h2>
      <p class="da-stats__subheading">{{ section.settings.subheading }}</p>
    </div>

    <div class="da-stats__grid">
      {%- for block in section.blocks -%}
        <div
          class="da-stats__item{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
          {{ block.shopify_attributes }}
          {% if settings.animations_reveal_on_scroll %}
            data-cascade
            style="--animation-order: {{ forloop.index }};"
          {% endif %}
        >
          <p class="da-stats__number">{{ block.settings.number }}</p>
          <p class="da-stats__description">{{ block.settings.description }}</p>
        </div>
      {%- endfor -%}
    </div>

    {%- if section.settings.source_text != blank -%}
      <p class="da-stats__source">{{ section.settings.source_text }}</p>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "DA Stat Callout",
  "tag": "section",
  "class": "section section--empathy-anchor",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Life's Best Moments Happen Around Dairy." },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "But for millions of Americans, those moments come with anxiety about what happens next." },
    { "type": "text", "id": "source_text", "label": "Source citation", "default": "¹NIH  ²Survey data" },
    { "type": "header", "content": "Section padding" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding top", "default": 64 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding bottom", "default": 64 }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Stat",
      "limit": 4,
      "settings": [
        { "type": "text", "id": "number", "label": "Stat number", "default": "30-50M" },
        { "type": "textarea", "id": "description", "label": "Stat description", "default": "Americans affected by lactose sensitivity" }
      ]
    }
  ],
  "presets": [
    {
      "name": "DA Stat Callout",
      "blocks": [
        { "type": "stat", "settings": { "number": "30-50M", "description": "Americans affected by lactose sensitivity" } },
        { "type": "stat", "settings": { "number": "68%", "description": "have skipped meals they wanted to enjoy" } },
        { "type": "stat", "settings": { "number": "79%", "description": "say current solutions are too inconvenient" } }
      ]
    }
  ],
  "enabled_on": { "templates": ["index"] }
}
{% endschema %}
