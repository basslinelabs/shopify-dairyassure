{%- liquid
  assign block_count = section.blocks | size
  assign show_top_divider = section.settings.show_top_divider

  assign wave_text_blocks = section.blocks | where: "type", "wave_text"
-%}
{%- if block_count > 0 -%}
  {%- style -%}
    #section-{{ section.id }} .section-banner {
      {% if section.settings.image_dt != blank and section.settings.video_dt == blank %}
        background-image: url({{ section.settings.image_dt.src | image_url: width: 2000 }});
        {%- if section.settings.image_dt.presentation.focal_point -%}
          background-position: {{ section.settings.image_dt.presentation.focal_point }};
        {%- endif -%}
      {% endif %}
      justify-content: {{ section.settings.horizontal_alignment_dt }};
      {% if wave_text_blocks.size > 0 %}
        {% if section.settings.wave_position == 'top' %}
          align-items: flex-end;
        {% else %}
          align-items: flex-start;
        {% endif %}
      {% else %}
        align-items: center;
      {% endif %}
      min-height: {{ section.settings.height_dt }}vh;
    }
    #section-{{ section.id }} .banner-content {
      text-align: {{ section.settings.horizontal_alignment_dt }};
    }
    #section-{{ section.id }} .section-banner .countdown {
      justify-content: {{ section.settings.horizontal_alignment_dt }};
    }
    #section-{{ section.id }} .section-banner .sticker {
      justify-content: {{ section.settings.horizontal_alignment_dt }};
    }
    #section-{{ section.id }} .section-banner  .two-buttons {
      justify-content: {{ section.settings.horizontal_alignment_dt }};
    }
    {% if section.settings.horizontal_alignment_dt != "center" %}
      #section-{{ section.id }} .section-banner .block {
        margin-{{ section.settings.horizontal_alignment_dt }}: 0;
      }
      {% if section.settings.horizontal_alignment_dt == "right" %}
        #section-{{ section.id }} .section-banner .block.icon-with-text {
          flex-direction: row-reverse;
        }
        #section-{{ section.id }} .section-banner .block.icon-with-text .block-icon-with-text__content {
          text-align: right;
        }
        #section-{{ section.id }} .section-banner .block.accordion summary {
          flex-direction: row-reverse;
        }
        #section-{{ section.id }} .section-banner .block.accordion summary .icon-caret {
          transform: rotate(180deg);
          left: -1rem;
          right: auto;
        }
        #section-{{ section.id }} .section-banner .block.accordion .accordion__content {
          text-align: right;
        }
      {% endif %}
    {% endif %}
    {% if section.settings.overlay_dt != blank and section.settings.video_dt == blank %}
      #section-{{ section.id }} .section-banner::before {
        background: {{ section.settings.overlay_dt }};
      }
    {% endif %}
    @media screen and (max-width: 749px) {
      #section-{{ section.id }} .section-banner {
        {% if section.settings.image_mob != blank and section.settings.video_mob == blank %}
          background-image: url({{ section.settings.image_mob.src | image_url: width: 750 }});
          background-position: {{ section.settings.image_mob.presentation.focal_point }};
        {% endif %}
        {% if wave_text_blocks.size > 0 %}
          {% if section.settings.wave_position == 'top' %}
            justify-content: flex-end;
          {% else %}
            justify-content: flex-start;
          {% endif %}
        {% else %}
          justify-content: {{ section.settings.horizontal_alignment_mob }};
        {% endif %}
        align-items: center;
        min-height: {{ section.settings.height_mob }}vh;
        flex-direction: column;
      }
      #section-{{ section.id }} .banner-content {
        text-align: {{ section.settings.horizontal_alignment_mob }};
      }
      #section-{{ section.id }} .section-banner .countdown {
        justify-content: {{ section.settings.horizontal_alignment_mob }};
      }
      #section-{{ section.id }} .section-banner .sticker {
        justify-content: {{ section.settings.horizontal_alignment_mob }};
      }
      #section-{{ section.id }} .section-banner .two-buttons {
          justify-content: {{ section.settings.horizontal_alignment_mob }};
        }
      {% if section.settings.horizontal_alignment_mob != "center" %}
        #section-{{ section.id }} .section-banner .block {
          margin-{{ section.settings.horizontal_alignment_mob }}: 0;
        }
        {% if section.settings.horizontal_alignment_mob == "right" %}
          #section-{{ section.id }} .section-banner .block.icon-with-text {
            flex-direction: row-reverse;
          }
          #section-{{ section.id }} .section-banner .block.icon-with-text .block-icon-with-text__content {
            text-align: right;
          }
          #section-{{ section.id }} .section-banner .block.accordion summary {
            flex-direction: row-reverse;
          }
          #section-{{ section.id }} .section-banner .block.accordion summary .icon-caret {
            transform: rotate(180deg);
            left: -1rem;
            right: auto;
          }
          #section-{{ section.id }} .section-banner .block.accordion .accordion__content {
            text-align: right;
          }
        {% endif %}
      {% endif %}
      {% if section.settings.overlay_mob != blank and section.settings.video_mob == blank %}
        #section-{{ section.id }} .section-banner::before {
          background: {{ section.settings.overlay_mob }};
        }
      {% endif %}
    }
    @media screen and (min-width: 750px) {
      #section-{{ section.id }} .banner-content {
        width: {{ section.settings.content_width_dt }}%;
      }
    }
  {%- endstyle -%}

  <section id="section-{{ section.id }}">
    {%- if show_top_divider -%}
      <div class="top-divider color-{{ section.settings.divider_color_scheme }}"></div>
    {%- endif -%}
    <div class="section-banner bg-default color-{{ section.settings.color_scheme }} no-color-scheme-conflict{% if show_top_divider %} has-divider{% endif %}{%- if wave_text_blocks.size > 0 %} relative{% endif -%}">
      {%- if section.settings.video_dt != blank or section.settings.video_mob != blank -%}
        {%- assign video_classes = 'banner-video' -%}
        {%- if section.settings.video_dt != blank -%}
          {%- if section.settings.video_mob != blank -%}
            {%- assign video_dt_classes = video_classes | append: ' small-hide' -%}
          {%- else -%}
            {%- assign video_dt_classes = video_classes -%}
          {%- endif -%}
          {{
            section.settings.video_dt
            | video_tag:
            image_size: '2000x',
            autoplay: true,
            loop: true,
            muted: true,
            controls: false,
            class: video_dt_classes
          }}
        {%- endif -%}
        {%- if section.settings.video_mob != blank -%}
          {%- assign video_mob_classes = video_classes | append: ' medium-up-hide' -%}\
          {{
            section.settings.video_mob
            | video_tag:
            image_size: '750x',
            autoplay: true,
            loop: true,
            muted: true,
            controls: false,
            class: video_mob_classes
          }}
        {%- endif -%}
      {%- endif -%}
      <div class="banner-content contained-inner-section">
        {%- for block in section.blocks -%}
          {%- case block.type -%}
            {%- when "header" -%}
              {%- if block.settings.header != blank -%}
                <{{ block.settings.header_tag }} class="banner__block"{% if block.settings.override_default_styles %} style="--override-font-size: {{ block.settings.override_font_size }}px;"{% endif %} {{ block.shopify_attributes }}>
                  {{ block.settings.header }}
                </{{ block.settings.header_tag }}>
              {%- endif -%}
            {%- when "text" -%}
              {%- if block.settings.text != blank -%}
                <div class="rte banner__block"{% if block.settings.override_default_styles %} style="--override-font-size: {{ block.settings.override_font_size }}px;"{% endif %} {{ block.shopify_attributes }}>{{ block.settings.text }}</div>
              {%- endif -%}
            {%- when "liquid" -%}
              {%- if block.settings.liquid != blank -%}
                <div class="banner__block" {{ block.shopify_attributes }}>{{ block.settings.liquid }}</div>
              {%- endif -%}
            {%- when "button" -%}
              {% if block.settings.button_text != blank or block.settings.button_two_text != blank %}
                <div class="banner__block two-buttons" {{ block.shopify_attributes }}>
                  {%- if block.settings.button_link != blank and block.settings.button_text != blank -%}
                    <a href="{{ block.settings.button_link }}" class="button--styled {{ block.settings.button_style }}{% unless block.settings.button_style == "link" %} button{% endunless %}">
                      {{ block.settings.button_text }}
                    </a>
                  {%- endif -%}
                  {%- if block.settings.button_two_link != blank and block.settings.button_two_text != blank -%}
                    <a href="{{ block.settings.button_two_link }}" class="button--styled {{ block.settings.button_two_style }}{% unless block.settings.button_two_style == "link" %} button{% endunless %}">
                      {{ block.settings.button_two_text }}
                    </a>
                  {%- endif -%}
                </div>
              {% endif %}
              {% liquid
                if block.settings.button_link != blank and block.settings.link_image == true
                  assign banner_link = block.settings.button_link
                endif
              %}
            {%- when 'countdown' -%}
              {%- liquid
                if block.settings.override_default_styles
                  assign countdown_number_font_size = block.settings.override_number_font_size
                  assign countdown_text_font_size = block.settings.override_text_font_size
                else
                  assign countdown_number_font_size = 0
                  assign countdown_text_font_size = 0
                endif
              -%}
              <div class="banner__block countdown" {{ block.shopify_attributes }}>
                {% render 'block-countdown',
                  end_date: block.settings.end_date,
                  end_time: block.settings.end_time,
                  show_after: block.settings.show_after,
                  after_message: block.settings.after_message,
                  number_font_size: countdown_number_font_size,
                  text_font_size: countdown_text_font_size
                %}
              </div>
            {%- when 'collapsible-row' -%}
              {%- liquid
                if block.settings.override_default_styles
                  assign collapsible_header_font_size = block.settings.override_header_font_size
                  assign collapsible_content_font_size = block.settings.override_content_font_size
                else
                  assign collapsible_header_font_size = 0
                  assign collapsible_content_font_size = 0
                endif
              -%}
              {% assign custom_id = section.id | append: "-" | append: block.id %}
              <div class="banner__block accordion {% if block.settings.contain_width %} block--contained{% endif %}" {{ block.shopify_attributes }}>
                {% render 'block-accordion',
                    heading: block.settings.heading,
                    row_content: block.settings.row_content,
                    page_content: block.settings.page.content,
                    open_tab: block.settings.open_tab,
                    id: custom_id,
                    question_font_size: collapsible_header_font_size,
                    answer_font_size: collapsible_content_font_size
                %}
              </div>
            {%- when 'icon-with-text' -%}
              {%- liquid
                if block.settings.override_default_styles
                  assign icon_header_font_size = block.settings.override_header_font_size
                  assign icon_text_font_size = block.settings.override_text_font_size
                else
                  assign icon_header_font_size = 0
                  assign icon_text_font_size = 0
                endif
              -%}
              <div class="banner__block icon-with-text{% if block.settings.contain_width %} block--contained{% endif %}" {{ block.shopify_attributes }}>
                {% render 'block-icon-with-text',
                  icon: block.settings.icon,
                  header: block.settings.header,
                  text: block.settings.text,
                  header_font_size: icon_header_font_size,
                  text_font_size: icon_text_font_size
                %}
              </div>
            {%- when 'divider' -%}
              <hr class="banner__block border-{{ block.settings.color }}" {{ block.shopify_attributes }}>
            {%- when 'sticker' -%}
              <div
                class="block sticker{% unless block.settings.animation_style == "static" %} sticker-animated{% endunless %}"
                id="sticker-{{ block.id }}"
                {{ block.shopify_attributes }}
              >
                {%- unless block.settings.animation_style == "static" -%}
                  {%- liquid
                    case block.settings.animation_style
                      when 'bounce'
                        case block.settings.animation_speed
                          when 'slow'
                            assign animation_speed = 4
                          when 'medium'
                            assign animation_speed = 3
                          when 'fast'
                            assign animation_speed = 2
                        endcase

                        assign animation = "stickerBounce " | append: animation_speed | append: "s step-end infinite normal"
                      when 'rotate_clockwise', 'rotate_anticlockwise'
                        case block.settings.animation_speed
                          when 'slow' 
                            assign animation_speed = 25
                          when 'medium'
                            assign animation_speed = 15
                          when 'fast'
                            assign animation_speed = 7
                        endcase

                        if block.settings.animation_style == 'rotate_clockwise'
                          assign animation_direction = 'normal'
                        else
                          assign animation_direction = 'reverse'
                        endif

                        assign animation = "rotate " | append: animation_speed | append: "s linear infinite " | append: animation_direction
                    endcase
                  -%}
                {%- endunless -%}

                {% style %}
                  #shopify-section-{{ section.id }} #sticker-{{ block.id }} .sticker-wrapper {
                    width: {{ block.settings.size | append: 'px'}};
                    {%- unless block.settings.animation_style == "static" -%}
                      margin: {{ block.settings.size | divided_by: 10 | append: 'px'}};
                    {%- endunless -%}
                  }

                  {%- unless block.settings.animation_style == "static" -%}
                    #shopify-section-{{ section.id }} #sticker-{{ block.id }} img,
                    #shopify-section-{{ section.id }} #sticker-{{ block.id }} svg {
                      animation: {{ animation }};
                    }
                  {%- endunless -%}
                {% endstyle %}

                <div class="sticker-wrapper">
                  {%- if block.settings.image != blank -%}
                    {% assign widths = '' | append: block.settings.size %}
                    {{ block.settings.image | image_url: width: block.settings.size | image_tag: loading: 'lazy', widths: widths }}
                  {%- else -%}
                    {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                  {%- endif -%}
                </div>
              </div>
            {% when 'custom_liquid' %}
              <div {{ block.shopify_attributes }}>
                {{ block.settings.custom_liquid }}
              </div>
            {% when '@app' %}
              {% render block %}
          {%- endcase -%}
        {%- endfor -%}
      </div>
      {% if banner_link %}
        <a href="{{ banner_link }}" aria-hidden="true" class="banner__image-link"></a>
      {% endif %}

      {%- if wave_text_blocks.size > 0 -%}
        {%- liquid
          case section.settings.scroll_speed
            when 'slow'
              assign animation_duration = 20
            when 'medium'
              assign animation_duration = 15
            when 'fast'
              assign animation_duration = 10
          endcase
      
          if section.settings.font_style == "body"
            assign font_class = 'p'
          else
            assign font_class = 'h4'
          endif
  
          if section.settings.font_size > 110
            assign wave_height = 2
          else
            assign wave_height = 2.5
          endif
        -%}
  
        {% style %}
          #shopify-section-{{ section.id }} textPath {
            font-size: {{ section.settings.font_size }}%;
          }
  
          {% if section.settings.font_style == "body" %}
            /* body */
            #shopify-section-{{ section.id }} .horizontally-scrolling-content--wavy use {
              stroke-width: calc(1.5rem * {{ section.settings.font_size | divided_by: 100.0 }} * {{ wave_height }});
            }
  
            @media screen and (min-width: 750px) {
              #shopify-section-{{ section.id }} .horizontally-scrolling-content--wavy use {
                stroke-width: calc(1.6rem * {{ section.settings.font_size | divided_by: 100.0 }} * {{ wave_height }});
              }
            }
          {% else %}
            #shopify-section-{{ section.id }} .horizontally-scrolling-content--wavy use {
              /* .h4 */
              stroke-width: calc(var(--font-header-scale) * 1.8rem * {{ section.settings.font_size | divided_by: 100.0 }} * {{ wave_height }});
            }
          {% endif %}
        {% endstyle %}
      
        {%- assign total_chars = 0 -%}
        {%- capture wavy_scrolling_content -%}
          {% unless section.settings.wave_custom_text_separator == blank %}
            {% assign separator = section.settings.wave_custom_text_separator %}
          {% else %}
            {% assign separator = "" %}
            {% if section.settings.wave_text_separator == 'vertical_line' %}
              {% assign separator = '|' %}
            {% elsif section.settings.wave_text_separator == 'horizontal_line' %}
              {% assign separator = '-' %}
            {% endif %}
          {% endunless %}
  
          {%- for block in wave_text_blocks -%}
            {%- if block.settings.text -%}
              {%- assign total_chars = total_chars | plus: block.settings.text.size -%}
              {%- if block.settings.link -%}<a href="{{ block.settings.link }}" class="link-reduce"  {{ block.shopify_attributes }}>{%- endif -%}
                {{ block.settings.text | append: " " | append: separator | append: " " }}
              {%- if block.settings.link -%}</a>{%- endif -%}
            {%- endif -%}
          {%- endfor -%}
        {%- endcapture -%}
      
        {%- if wave_text_blocks.size < 5 -%}
          {%- assign num = 70 | times: 100 | divided_by: section.settings.font_size | divided_by: total_chars | round | times: 3 -%}
      
          {%- capture wavy_scrolling_content -%}
            {{- wavy_scrolling_content -}}
            {%- for i in (1..num) -%}
              {{- wavy_scrolling_content -}}
            {%- endfor -%}
          {%- endcapture -%}
        {%- endif -%}
      
        <div class="wave-component color-{{ section.settings.color_scheme }} align-{{ section.settings.wave_position }}">
          {% if section.settings.wave_animation_style == "play_on_scroll" or section.settings.wave_animation_style == "pause_on_hover" %}
            <wave-scrolling-content data-animation-style="{{ section.settings.wave_animation_style }}" data-direction="{{ section.settings.scroll_direction }}" data-speed="10" class="horizontally-scrolling-content--wrapper {{ section.settings.scroll_direction }}">
          {% else %}
            <div class="horizontally-scrolling-content--wrapper">
          {% endif %}
            <div class="horizontally-scrolling-content--wavy">
              <svg xmlns="http://www.w3.org/2000/svg" width="100%" height="100%" viewBox="0 0 1090 100" class="wave wave-bg-{{ section.settings.color }}">
                <defs>
                  <path id="curve" fill="transparent" d="M -10 28 S 97 64 262.46 71.2 S 508 18 667.589 31.448 C 859.631 40.177 860 101 1095 54.366"></path>
                </defs>
  
                <use href="#curve" xlink:href="#curve" fill="none"/>
  
                <text dominant-baseline="middle">
                  <textPath href="#curve" alignment-baseline="middle" startOffset="{%- if section.settings.scroll_direction == "reverse" -%}0%{%- else -%}-100%{%- endif -%}" lengthAdjust="spacing" class="{{ font_class }}">
                    {{ wavy_scrolling_content }}
                    {% unless section.settings.wave_animation_style == "play_on_scroll" %}
                      <animate attributeName="startOffset" from="{%- if section.settings.scroll_direction == "reverse" -%}0%{%- else -%}-100%{%- endif -%}" to ="{%- if section.settings.scroll_direction == "reverse" -%}-100%{%- else -%}0%{%- endif -%}" begin="0s" dur="{{ animation_duration }}s" repeatCount="indefinite" calcMode="linear" />
                    {% endunless %}
                  </textPath>
                </text>
              </svg>
            </div>
          {% if section.settings.wave_animation_style == "play_on_scroll" or section.settings.wave_animation_style == "pause_on_hover" %}
            </wave-scrolling-content>
          {% else %}
            </div>
          {% endif %}
        </div>
      {%- endif -%}
      
      {% if section.settings.wave_animation_style == "play_on_scroll" or section.settings.wave_animation_style == "pause_on_hover" %}
        <script src="{{ 'wave-scrolling-content.js' | asset_url }}" defer="defer"></script>
      {% endif %}
    </div>
  </section>
{%- endif -%}

{% schema %}
{
  "name": "t:sections.banner-and-wave.name",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_top_divider",
      "label": "t:sections.all.show_top_divider.label",
      "default": false
    },
    {
      "type": "color_scheme",
      "id": "divider_color_scheme",
      "default": "scheme-2",
      "label": "t:sections.all.top_divider_color_scheme.label",
      "info": "t:sections.all.top_divider_color_scheme.info",
      "visible_if": "{{ section.settings.show_top_divider }}"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "default": "scheme-1",
      "label": "t:sections.all.color_scheme.label"
    },
    {
      "type": "header",
      "content": "t:sections.all.desktop.label"
    },
    {
      "type": "image_picker",
      "id": "image_dt",
      "label": "t:sections.banner.settings.image_dt.label",
      "info": "t:sections.banner.settings.image_dt.info"
    },
    {
      "type": "video",
      "id": "video_dt",
      "label": "t:sections.banner.settings.video_dt.label"
    },
    {
      "type": "color_background",
      "id": "overlay_dt",
      "label": "t:sections.banner.settings.overlay_dt.label",
      "info": "t:sections.banner.settings.overlay_dt.info"
    },
    {
      "type": "range",
      "id": "height_dt",
      "label": "t:sections.banner.settings.height_dt.label",
      "info": "t:sections.banner.settings.height_dt.info",
      "min": 25,
      "max": 100,
      "unit": "%",
      "default": 65
    },
    {
      "type": "select",
      "id": "horizontal_alignment_dt",
      "label": "t:sections.banner.settings.horizontal_alignment_dt.label",
      "options": [
        {
          "value": "left",
          "label": "t:sections.banner.settings.horizontal_alignment_dt.left.label"
        },
        {
          "value": "center",
          "label": "t:sections.banner.settings.horizontal_alignment_dt.middle.label"
        },
        {
          "value": "right",
          "label": "t:sections.banner.settings.horizontal_alignment_dt.right.label"
        }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "content_width_dt",
      "min": 30,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "t:sections.banner.settings.content_width_dt.label",
      "info": "t:sections.banner.settings.content_width_dt.info",
      "default": 50
    },
    {
      "type": "header",
      "content": "t:sections.all.mobile.label"
    },
    {
      "type": "image_picker",
      "id": "image_mob",
      "label": "t:sections.banner.settings.image_mob.label",
      "info": "t:sections.banner.settings.image_mob.info"
    },
    {
      "type": "video",
      "id": "video_mob",
      "label": "t:sections.banner.settings.video_mob.label"
    },
    {
      "type": "color_background",
      "id": "overlay_mob",
      "label": "t:sections.banner.settings.overlay_mob.label",
      "info": "t:sections.banner.settings.overlay_mob.info"
    },
    {
      "type": "range",
      "id": "height_mob",
      "label": "t:sections.banner.settings.height_mob.label",
      "info": "t:sections.banner.settings.height_mob.info",
      "min": 25,
      "max": 100,
      "unit": "%",
      "default": 55
    },
    {
      "type": "select",
      "id": "horizontal_alignment_mob",
      "label": "t:sections.banner.settings.horizontal_alignment_mob.label",
      "options": [
        {
          "value": "left",
          "label": "t:sections.banner.settings.horizontal_alignment_mob.left.label"
        },
        {
          "value": "center",
          "label": "t:sections.banner.settings.horizontal_alignment_mob.middle.label"
        },
        {
          "value": "right",
          "label": "t:sections.banner.settings.horizontal_alignment_mob.right.label"
        }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "t:sections.all.wave.header"
    },
    {
      "type": "select",
      "id": "scroll_direction",
      "label": "t:sections.all.horizontally_scrolling_content.scroll_direction.label",
      "options": [
        {
          "value": "normal",
          "label": "t:sections.all.horizontally_scrolling_content.scroll_direction.options__1.label"
        },
        {
          "value": "reverse",
