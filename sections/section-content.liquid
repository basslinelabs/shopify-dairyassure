          "label": "t:sections.all.overrides.override_text_font_size.label",
          "default": 0,
          "visible_if": "{{ block.settings.override_default_styles }}"
        }
      ]
    },
    {
      "type": "button",
      "name": "t:sections.all.buttons.heading",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "button_text",
          "default": "Shop Now",
          "label": "t:sections.all.buttons.button_text.label"
        },
        {
          "type": "url",
          "id": "button_link",
          "default": "/collections/all",
          "label": "t:sections.all.buttons.button_link.label"
        },
        {
          "type": "checkbox",
          "id": "show_in_front_of_accent_image",
          "label": "t:sections.all.accent_image.show_in_front_of_image.label",
          "default": true
        }
      ]
    },
    {
      "type": "countdown",
      "name": "t:sections.all.countdown.name",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "end_date",
          "default": "01/01/2026",
          "label": "t:sections.all.countdown.end_date.label",
          "info": "t:sections.all.countdown.end_date.info"
        },
        {
          "type": "text",
          "id": "end_time",
          "default": "23:45",
          "label": "t:sections.all.countdown.end_time.label",
          "info": "t:sections.all.countdown.end_time.info"
        },
        {
          "type": "checkbox",
          "id": "show_after",
          "label": "t:sections.all.countdown.show_after.label",
          "default": true
        },
        {
          "type": "textarea",
          "id": "after_message",
          "label": "t:sections.all.countdown.after_message.label",
          "info": "t:sections.all.countdown.after_message.info",
          "default": "Our sale has started! Browse the products below."
        },
        {
          "type": "checkbox",
          "id": "show_in_front_of_accent_image",
          "label": "t:sections.all.accent_image.show_in_front_of_image.label",
          "default": true
        },
        {
          "type": "header",
          "content": "t:sections.all.overrides.header"
        },
        {
          "type": "checkbox",
          "id": "override_default_styles",
          "label": "t:sections.all.overrides.override_default_styles.label",
          "default": false
        },
        {
          "type": "range",
          "id": "override_number_font_size",
          "min": -6,
          "max": 20,
          "step": 2,
          "label": "t:sections.all.countdown.overrides.number_font_size.label",
          "default": 0,
          "visible_if": "{{ block.settings.override_default_styles }}"
        },
        {
          "type": "range",
          "id": "override_text_font_size",
          "min": -6,
          "max": 20,
          "step": 2,
          "label": "t:sections.all.countdown.overrides.text_font_size.label",
