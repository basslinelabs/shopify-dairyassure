{{ 'section-faq.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div
  class="da-faq section-{{ section.id }}-padding{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
>
  {%- if section.settings.decorative_icon != blank -%}
    {{
      section.settings.decorative_icon
      | image_url: width: 160
      | image_tag:
        class: 'da-faq__decorative',
        loading: 'lazy',
        alt: ''
    }}
  {%- endif -%}

  <div class="page-width">
    <div class="da-faq__header">
      <h2 class="da-faq__heading">{{ section.settings.heading }}</h2>
    </div>

    <div class="da-faq__list">
      {%- for block in section.blocks -%}
        <details class="da-faq__item" {{ block.shopify_attributes }}>
          <summary class="da-faq__question">
            <span>{{ block.settings.question }}</span>
            <svg class="da-faq__chevron" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path d="M5 7.5L10 12.5L15 7.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </summary>
          <div class="da-faq__answer rte">
            {{ block.settings.answer }}
          </div>
        </details>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "DA FAQ",
  "tag": "section",
  "class": "section section--faq",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Questions? We've Got Answers." },
    { "type": "image_picker", "id": "decorative_icon", "label": "Decorative icon (top-right)" },
    { "type": "header", "content": "Section padding" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding top", "default": 64 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding bottom", "default": 64 }
  ],
  "blocks": [
    {
      "type": "faq_item",
      "name": "FAQ Item",
      "limit": 12,
      "settings": [
        { "type": "text", "id": "question", "label": "Question" },
        { "type": "richtext", "id": "answer", "label": "Answer" }
      ]
    }
  ],
  "presets": [
    {
      "name": "DA FAQ",
      "blocks": [
        { "type": "faq_item", "settings": { "question": "What exactly is DairyAssure?", "answer": "<p>A pure lactase enzyme powder that helps your body digest dairy. One ingredient, no fillers, no preservatives. Just sprinkle it on your food or mix it into your drink.</p>" } },
        { "type": "faq_item", "settings": { "question": "How do I use it?", "answer": "<p>Sprinkle it on your food or mix it into your drink right before you eat. That's it. No pills to swallow, no timing to worry about.</p>" } },
        { "type": "faq_item", "settings": { "question": "Is DairyAssure safe for children?", "answer": "<p>Yes. DairyAssure is a single-ingredient powder suitable for children, adults, and seniors. It simply supplements the lactase enzyme your body doesn't produce enough of.</p>" } },
        { "type": "faq_item", "settings": { "question": "What makes it different from pills?", "answer": "<p>Pills are loaded with fillers and preservatives — stuff your body doesn't need (and that can cause its own stomach issues). DairyAssure is just the enzyme, in powder form, so you can add it directly to food without planning ahead.</p>" } },
        { "type": "faq_item", "settings": { "question": "How long does it last?", "answer": "<p>DairyAssure provides 90+ minutes of effectiveness — enough to last through your entire meal and beyond.</p>" } },
        { "type": "faq_item", "settings": { "question": "Can I use it with any dairy product?", "answer": "<p>Yes. Coffee, pizza, ice cream, cheese, yogurt, protein shakes — DairyAssure works with all dairy. It's completely flavorless, so it won't change the taste of your food.</p>" } },
        { "type": "faq_item", "settings": { "question": "Is it really just one ingredient?", "answer": "<p>Yes. DairyAssure contains only lactase — the enzyme your body needs to digest dairy. Nothing else. No preservatives, no fillers, no additives, no artificial flavors.</p>" } }
      ]
    }
  ],
  "enabled_on": { "templates": ["index"] }
}
{% endschema %}
