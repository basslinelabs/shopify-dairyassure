{%- liquid
  assign show_top_divider = section.settings.show_top_divider
  assign highlight_column = section.settings.highlight_column | plus: 0
  assign highlight_column_color = section.settings.highlight_column_color

-%}

{%- style -%}
  {% if section.settings.show_accent_image and section.settings.accent_image %}
    {% render 'styling-section',
      section_id: section.id,
      accent_image: section.settings.accent_image,
      accent_vertical_anchor: section.settings.accent_vertical_anchor,
      accent_horizontal_anchor: section.settings.accent_horizontal_anchor,
      accent_size: section.settings.accent_size,
      hide_accent_on_mobile: section.settings.hide_accent_on_mobile,
      accent_cover: section.settings.accent_cover
    %}
  {% endif %}
{%- endstyle -%}

{%- if show_top_divider -%}
  <div class="top-divider color-{{ section.settings.divider_color_scheme }}"></div>
{%- endif -%}

<div class="section-outer{% if show_top_divider %} has-divider{% endif %}">
  <div class="section-standard--narrow section--comparison-table section-content bg-default color-{{ section.settings.color_scheme }}"{% if section.settings.override_default_styles %} style="--override-padding-top: {{ section.settings.override_space_above }}px; --override-padding-bottom: {{ section.settings.override_space_below }}px;"{% endif %}>
    <div class="contained-section alignment in-front-of-accent-image">
      <div class="section-intro">
        {%- if section.settings.header != blank -%}
          <{{ section.settings.header_tag }}{% if section.settings.override_default_styles %} style="--override-font-size: {{ section.settings.override_header_font_size }}px;"{% endif %}>
            {{ section.settings.header | escape }}
          </{{ section.settings.header_tag }}>
        {%- endif -%}
        
        {%- if section.settings.text != blank -%}
          <div class="rte"{% if section.settings.override_default_styles %} style="--override-font-size: {{ section.settings.override_text_font_size }}px;"{% endif %}>{{ section.settings.text }}</div>
        {%- endif -%}
      </div>

      {%- if section.blocks.size > 0 -%}
        <div class="comparison-table__table">
          <table role="table">
            <thead role="rowgroup">
              <tr role="row">
                <th role="columnheader">
                </th>
                {% for i in (1..3) %}
                  {% assign col_header_key = 'column_' | append: i | append: '_header' %}
                  {% assign col_image_key = 'column_' | append: i | append: '_image' %}
                  {% if section.settings[col_header_key] != blank or section.settings[col_image_key] != blank %}
                    <th role="columnheader" class="{% if highlight_column == i %}bg-{{ highlight_column_color }}{% endif %}">
                      {% if section.settings[col_image_key] != blank %}
                        {{ section.settings[col_image_key] | image_url: width: 300 | image_tag: class: 'comparison-table__header-image' }}
                      {% endif %}
                      {{ section.settings[col_header_key] }}
                    </th>
                  {% endif %}
                {% endfor %}
              </tr>
            </thead>
            <tbody role="rowgroup">
              {% for block in section.blocks %}
                <tr role="row" class="border-top-{{ highlight_column_color }}-fade" {{ block.shopify_attributes }}>
                  <td role="cell">
                    <h4>{{ block.settings.header | escape }}</h4>
                    {%- if block.settings.text != blank -%}
                      <div class="rte{% if block.settings.hide_text_on_mobile %} small-hide{% endif %}">
                        {{ block.settings.text }}
                      </div>
                    {%- endif -%}
                  </td>
                  {% for i in (1..3) %}
                    {% assign col_state_key = 'column_' | append: i | append: '_state' %}
                    {% assign col_header_key = 'column_' | append: i | append: '_header' %}
                    {% assign col_image_key = 'column_' | append: i | append: '_image' %}
                    {% if section.settings[col_header_key] != blank or section.settings[col_image_key] != blank %}
                      <td role="cell" class="{% if highlight_column == i %}bg-{{ highlight_column_color }}{% endif %}">
                        {% render 'icons-main', icon: block.settings[col_state_key] %}
                      </td>
                    {% endif %}
                  {% endfor %}
                </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
      {%- endif -%}
    </div>
  </div>
</div>

{% schema %}
{
