{%- liquid
  assign show_top_divider = section.settings.show_top_divider
  assign title = section.settings.title | escape

-%}

{%- style -%}
  {% if section.settings.show_accent_image and section.settings.accent_image %}
    {% render 'styling-section',
      section_id: section.id,
      accent_image: section.settings.accent_image,
      accent_vertical_anchor: section.settings.accent_vertical_anchor,
      accent_horizontal_anchor: section.settings.accent_horizontal_anchor,
      accent_size: section.settings.accent_size,
      hide_accent_on_mobile: section.settings.hide_accent_on_mobile,
      accent_cover: section.settings.accent_cover
    %}
  {% endif %}
{%- endstyle -%}

{%- if show_top_divider -%}
  <div class="top-divider color-{{ section.settings.divider_color_scheme }}"></div>
{%- endif -%}

<div class="section-outer{% if show_top_divider %} has-divider{% endif %}">
  <div class="section-standard section--form section-content bg-default color-{{ section.settings.color_scheme }}"{% if section.settings.override_default_styles %} style="--override-padding-top: {{ section.settings.override_space_above }}px; --override-padding-bottom: {{ section.settings.override_space_below }}px;"{% endif %}>
    <div class="contained-section contained-section--narrow alignment in-front-of-accent-image">
      <div class="section-intro">
        {%- if title != blank -%}
          <{{ section.settings.header_tag }}{% if section.settings.override_default_styles %} style="--override-font-size: {{ section.settings.override_header_font_size }}px;"{% endif %}>{{ title }}</{{ section.settings.header_tag }}>
        {%- endif -%}
        {%- if section.settings.text != blank -%}
          <div class="rte"{% if section.settings.override_default_styles %} style="--override-font-size: {{ section.settings.override_text_font_size }}px;"{% endif %}>{{ section.settings.text }}</div>
        {%- endif -%}
      </div>
      {%- form 'contact', id: 'ContactForm' -%}
        {%- if form.posted_successfully? -%}
          <div class="form-status form-status-list form__message" tabindex="-1" autofocus>{% render 'icons-main', icon: 'tick' %} {{ 'templates.contact.form.post_success' | t }}</div>
        {%- elsif form.errors -%}
          <div class="form__message">
            <h2 class="form-status caption-large text-body" role="alert" tabindex="-1" autofocus>{% render 'icons-main', icon: 'cross' %} {{ 'templates.contact.form.error_heading' | t }}</h2>
          </div>
          <ul class="form-status-list caption-large" role="list">
            <li>
              <a href="#ContactForm-email" class="link">
                {{ form.errors.translated_fields['email'] | capitalize }} {{ form.errors.messages['email'] }}
              </a>
            </li>
          </ul>
        {%- endif -%}
        <div class="contact-form__fields">
          {%- assign has_email = false -%}
          {%- for block in section.blocks -%}
            {%- case block.type -%}
              {%- when 'text' -%}
                <div class="field{% if block.settings.half_width %} field--one-half{% endif %}" {{ block.shopify_attributes }}>
                  <input {% if block.settings.required %}required {% endif %}class="field__input" type="text" id="ContactForm-{{ block.id }}" name="contact[{{ block.settings.text }}]" placeholder="{{ block.settings.text }}">
                  <label class="field__label" for="ContactForm-{{ block.id }}">{{ block.settings.text }}{% if block.settings.required %}*{% endif %}</label>
                </div>
              {%- when 'email' -%}
                {%- assign has_email = true -%}
                <div class="field field--with-error{% if block.settings.half_width %} field--one-half{% endif %}">
                  <input
                    autocomplete="email"
                    type="email"
                    id="ContactForm-email"
                    class="field__input"
                    name="contact[email]"
                    spellcheck="false"
                    autocapitalize="off"
                    value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}"
                    aria-required="true"
                    {% if form.errors contains 'email' %}
                      aria-invalid="true"
                      aria-describedby="ContactForm-email-error"
                    {% endif %}
                    placeholder="{{ 'templates.contact.form.email' | t }}"
                    required
                  >
                  <label class="field__label" for="ContactForm-email">{{ 'templates.contact.form.email' | t }}<span aria-hidden="true">*</span></label>
                  {%- if form.errors contains 'email' -%}
                    <small class="contact__field-error" id="ContactForm-email-error">
                      <span class="visually-hidden">{{ 'accessibility.error' | t }}</span>
                      <span class="form__message">{% render 'icons-main', icon: 'cross' %}{{ form.errors.translated_fields['email'] | capitalize }} {{ form.errors.messages['email'] }}</span>
                    </small>
                  {%- endif -%}
                </div>
              {%- when 'phone' -%}
                <div class="field{% if block.settings.half_width %} field--one-half{% endif %}">
                  <input {% if block.settings.required %}required {% endif %}type="tel" id="ContactForm-phone" class="field__input" autocomplete="tel" name="contact[{{ 'templates.contact.form.phone' | t }}]" pattern="[0-9\-]*" value="{% if form.phone %}{{ form.phone }}{% elsif customer %}{{ customer.phone }}{% endif %}" placeholder="{{ 'templates.contact.form.phone' | t }}">
                  <label class="field__label" for="ContactForm-phone">{{ 'templates.contact.form.phone' | t }}{% if block.settings.required %}*{% endif %}</label>
                </div>
              {%- when 'textarea' -%}
                <div class="field">
                  <textarea
                    rows="10"
                    id="ContactForm-{{ block.id }}"
                    class="text-area field__input"
                    name="contact[{{ block.settings.text }}]"
                    placeholder="{{ block.settings.text }}"
                    {% if block.settings.required %}required{% endif %}
                  >
                    {{- form.body -}}
                  </textarea>
                  <label class="form__label field__label" for="ContactForm-{{ block.id }}">{{ block.settings.text }}{% if block.settings.required %}*{% endif %}</label>
                </div>
              {% when 'checkbox' %}
                <div class="field field--checkbox">
                  <input {% if block.settings.required %}required {% endif %}id="ContactForm-{{ block.id }}" type="checkbox" value="true" name="contact[{{ block.settings.text }}]">
                  <label for="ContactForm-{{ block.id }}">{{ block.settings.text }}{% if block.settings.required %}*{% endif %}</label>
                </div>
              {%- when 'radio' -%}
                {% if block.settings.option_one != blank %}
                  <div class="field field--radio{% if block.settings.half_width %} field--one-half{% endif %}">
                    <label for="ContactForm-{{ block.id }}">{{ block.settings.text }}{% if block.settings.required %}*{% endif %}</label>
                    <div class="field--radio-options">
                      <div class="field--radio-option">
                        <label for="{{ block.id }}-option_one"><input {% if block.settings.required %}required {% endif %}type="radio" name="ContactForm-{{ block.id }}" id="{{ block.id }}-option_one"><span>{{ block.settings.option_one }}</span></label>
                      </div>
                      {% if block.settings.option_two != blank %}
                        <div class="field--radio-option">
                          <label for="{{ block.id }}-option_two"><input {% if block.settings.required %}required {% endif %}type="radio" name="ContactForm-{{ block.id }}" id="{{ block.id }}-option_two"><span>{{ block.settings.option_two }}</span></label>
                        </div>
                      {% endif %}
                      {% if block.settings.option_three != blank %}
                        <div class="field--radio-option">
                          <label for="{{ block.id }}-option_three"><input {% if block.settings.required %}required {% endif %}type="radio" name="ContactForm-{{ block.id }}" id="{{ block.id }}-option_three"><span>{{ block.settings.option_three }}</span></label>
                        </div>
                      {% endif %}
                    </div>
                  </div>
                {% endif %}
              {%- when 'select' -%}
                {% if block.settings.option_one != blank %}
                  <div class="field field--select{% if block.settings.half_width %} field--one-half{% endif %}">
                    <label for="ContactForm-{{ block.id }}">{{ block.settings.text }}{% if block.settings.required %}*{% endif %}</label>
                    <div class="field--select-container select">
                      <select {% if block.settings.required %}required {% endif %}id="ContactForm-{{ block.id }}" name="contact[{{ block.settings.text }}]" class="field__input select__select">
                        <option>{{ block.settings.option_one }}</option>
                        {% if block.settings.option_two != blank %}
                          <option>{{ block.settings.option_two }}</option>
                        {% endif %}
                        {% if block.settings.option_three != blank %}
                          <option>{{ block.settings.option_three }}</option>
                        {% endif %}
                        {% if block.settings.option_four != blank %}
                          <option>{{ block.settings.option_four }}</option>
                        {% endif %}
                        {% if block.settings.option_five != blank %}
                          <option>{{ block.settings.option_five }}</option>
                        {% endif %}
                      </select>
                      {% render 'icons-main', icon: 'caret' %}
                    </div>
                  </div>
                {% endif %}
            {%- endcase -%}
          {%- endfor -%}
          {%- if has_email == false -%}
            <div class="field field--with-error">
              <input
                autocomplete="email"
                type="email"
                id="ContactForm-email"
                class="field__input"
                name="contact[email]"
                spellcheck="false"
                autocapitalize="off"
                value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}"
                aria-required="true"
                {% if form.errors contains 'email' %}
                  aria-invalid="true"
                  aria-describedby="ContactForm-email-error"
                {% endif %}
                placeholder="{{ 'templates.contact.form.email' | t }}"
                required
              >
              <label class="field__label" for="ContactForm-email">{{ 'templates.contact.form.email' | t }}<span aria-hidden="true">*</span></label>
              {%- if form.errors contains 'email' -%}
                <small class="contact__field-error" id="ContactForm-email-error">
                  <span class="visually-hidden">{{ 'accessibility.error' | t }}</span>
                  <span class="form__message">{% render 'icons-main', icon: 'cross' %}{{ form.errors.translated_fields['email'] | capitalize }} {{ form.errors.messages['email'] }}</span>
                </small>
              {%- endif -%}
            </div>
          {%- endif -%}
        </div>
        <div class="contact__button">
          <button type="submit" class="button solid">
            {{ 'templates.contact.form.send' | t }}
          </button>
        </div>
      {%- endform -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "t:sections.contact-form.presets.name",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.all.section_content"
    },
    {
      "type": "text",
      "id": "title",
      "default": "Get in touch",
      "label": "t:sections.all.header.label"
    },
    {
      "type": "select",
      "id": "header_tag",
      "label": "t:sections.all.header.header_tag.label",
      "options": [
        {
          "value": "h1",
          "label": "t:sections.all.header.header_tag.h1.label"
        },
        {
          "value": "h2",
          "label": "t:sections.all.header.header_tag.h2.label"
        },
        {
          "value": "h3",
          "label": "t:sections.all.header.header_tag.h3.label"
        },
        {
          "value": "h4",
          "label": "t:sections.all.header.header_tag.h4.label"
        },
        {
          "value": "h5",
          "label": "t:sections.all.header.header_tag.h5.label"
        },
        {
          "value": "h6",
          "label": "t:sections.all.header.header_tag.h6.label"
        }
      ],
      "default": "h2"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "t:sections.all.text.label"
    },
    {
      "type": "header",
      "content": "t:sections.all.section_styling"
    },
    {
      "type": "checkbox",
      "id": "show_top_divider",
      "label": "t:sections.all.show_top_divider.label",
      "default": false
    },
    {
      "type": "color_scheme",
      "id": "divider_color_scheme",
      "default": "scheme-2",
      "label": "t:sections.all.top_divider_color_scheme.label",
      "info": "t:sections.all.top_divider_color_scheme.info",
      "visible_if": "{{ section.settings.show_top_divider }}"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "default": "scheme-1",
      "label": "t:sections.all.color_scheme.label"
    },
    {
      "type": "header",
      "content": "t:sections.all.accent_image.header.content"
    },
    {
      "type": "checkbox",
      "id": "show_accent_image",
      "label": "t:sections.all.accent_image.show_image.label",
      "default": false
    },
    {
      "type": "image_picker",
      "id": "accent_image",
      "label": "t:sections.all.image.label",
      "info": "t:sections.all.image.info",
      "visible_if": "{{ section.settings.show_accent_image }}"
    },
    {
      "type": "range",
      "id": "accent_horizontal_anchor",
      "label": "t:sections.all.accent_image.horizontal_anchor.label",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 0,
      "visible_if": "{{ section.settings.show_accent_image }}"
    },
    {
      "type": "range",
      "id": "accent_vertical_anchor",
      "label": "t:sections.all.accent_image.vertical_anchor.label",
      "info": "t:sections.all.accent_image.vertical_anchor.info",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 0,
      "visible_if": "{{ section.settings.show_accent_image }}"
    },
    {
      "type": "range",
      "id": "accent_size",
      "min": 10,
      "max": 100,
      "step": 1,
      "unit": "%",
      "label": "t:sections.all.accent_image.image_size.label",
      "info": "t:sections.all.accent_image.image_size.info",
      "default": 30,
      "visible_if": "{{ section.settings.show_accent_image }}"
    },
    {
      "type": "checkbox",
      "id": "hide_accent_on_mobile",
      "label": "t:sections.all.accent_image.hide_on_mobile.label",
      "default": true,
      "visible_if": "{{ section.settings.show_accent_image }}"
    },
    {
      "type": "checkbox",
      "id": "accent_cover",
      "label": "t:sections.all.accent_image.image_cover.label",
      "info": "t:sections.all.accent_image.image_cover.info",
      "default": false,
      "visible_if": "{{ section.settings.show_accent_image }}"
    },
    {
      "type": "header",
      "content": "t:sections.all.overrides.header"
    },
    {
      "type": "checkbox",
      "id": "override_default_styles",
      "label": "t:sections.all.overrides.override_default_styles.label",
      "info": "t:sections.all.overrides.override_default_styles.info",
      "default": false
    },
    {
      "type": "header",
      "content": "t:sections.all.overrides.header_section.label",
      "visible_if": "{{ section.settings.override_default_styles }}"
    },
    {
      "type": "range",
      "id": "override_space_above",
      "min": -50,
      "max": 100,
      "step": 10,
      "default": 0,
      "label": "t:sections.all.overrides.override_space_above.label",
      "visible_if": "{{ section.settings.override_default_styles }}"
    },
    {
      "type": "range",
      "id": "override_space_below",
      "min": -50,
      "max": 100,
      "step": 10,
      "default": 0,
      "label": "t:sections.all.overrides.override_space_below.label",
      "visible_if": "{{ section.settings.override_default_styles }}"
    },
    {
      "type": "header",
      "content": "t:sections.all.overrides.header_intro.label",
      "visible_if": "{{ section.settings.override_default_styles }}"
    },
    {
      "type": "range",
      "id": "override_header_font_size",
      "min": -10,
      "max": 30,
      "step": 2,
      "default": 0,
      "label": "t:sections.all.overrides.override_header_font_size.label",
      "visible_if": "{{ section.settings.override_default_styles }}"
    },
    {
      "type": "range",
      "id": "override_text_font_size",
      "min": -6,
      "max": 20,
      "step": 2,
      "default": 0,
      "label": "t:sections.all.overrides.override_text_font_size.label",
      "visible_if": "{{ section.settings.override_default_styles }}"
    },
  ],
  "blocks": [
    {
      "type": "text",
      "name": "t:sections.contact-form.blocks.text.name",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "default": "Name",
          "label": "t:sections.contact-form.blocks.text.settings.text.label"
        },
        {
          "type": "checkbox",
          "id": "required",
          "default": false,
          "label": "t:sections.contact-form.blocks.all.settings.required"
        },
        {
          "type": "checkbox",
          "id": "half_width",
          "default": false,
          "label": "t:sections.contact-form.blocks.all.settings.half_width"
        }
      ]
    },
    {
      "type": "email",
      "name": "t:sections.contact-form.blocks.email.name",
      "limit": 1,
      "settings": [
        {
          "type": "paragraph",
          "content": "t:sections.contact-form.blocks.email.settings.paragraph.content"
        },
        {
          "type": "checkbox",
          "id": "half_width",
          "default": false,
          "label": "t:sections.contact-form.blocks.all.settings.half_width"
        }
      ]
    },
    {
      "type": "phone",
      "limit": 1,
      "name": "t:sections.contact-form.blocks.phone.name",
      "settings": [
        {
          "type": "checkbox",
          "id": "required",
          "default": false,
          "label": "t:sections.contact-form.blocks.all.settings.required"
        },
        {
          "type": "checkbox",
          "id": "half_width",
          "default": false,
          "label": "t:sections.contact-form.blocks.all.settings.half_width"
        }
      ]
    },
    {
      "type": "textarea",
      "name": "t:sections.contact-form.blocks.textarea.name",
      "settings": [
        {
          "type": "checkbox",
          "id": "required",
          "default": false,
          "label": "t:sections.contact-form.blocks.all.settings.required"
        },
        {
          "type": "text",
          "id": "text",
          "default": "Message",
          "label": "t:sections.contact-form.blocks.textarea.settings.text.label"
        }
      ]
    },
    {
      "type": "checkbox",
      "name": "t:sections.contact-form.blocks.checkbox.name",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "default": "I'm happy to be contacted via email in response to this message.",
          "label": "t:sections.contact-form.blocks.checkbox.settings.text.label"
        },
        {
          "type": "checkbox",
          "id": "required",
          "default": false,
          "label": "t:sections.contact-form.blocks.all.settings.required"
        },
        {
          "type": "checkbox",
          "id": "half_width",
          "default": false,
          "label": "t:sections.contact-form.blocks.all.settings.half_width"
        }
      ]
    },
    {
      "type": "radio",
      "name": "t:sections.contact-form.blocks.radio.name",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "default": "How can we help?",
          "label": "t:sections.contact-form.blocks.radio.settings.text.label"
        },
        {
          "type": "checkbox",
          "id": "required",
          "default": false,
          "label": "t:sections.contact-form.blocks.all.settings.required"
        },
        {
          "type": "text",
          "id": "option_one",
          "default": "Pre-purchase support",
          "label": "t:sections.contact-form.blocks.radio.settings.option_one.label"
        },
        {
          "type": "text",
          "id": "option_two",
          "default": "Post-purchase support",
          "label": "t:sections.contact-form.blocks.radio.settings.option_two.label"
        },
        {
          "type": "text",
          "id": "option_three",
          "default": "Something else",
          "label": "t:sections.contact-form.blocks.radio.settings.option_three.label"
        },
        {
          "type": "checkbox",
          "id": "half_width",
          "default": false,
          "label": "t:sections.contact-form.blocks.all.settings.half_width"
        }
      ]
    },
    {
      "type": "select",
      "name": "t:sections.contact-form.blocks.select.name",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "default": "Where did you hear about us",
          "label": "t:sections.contact-form.blocks.select.settings.text.label"
        },
        {
          "type": "checkbox",
          "id": "required",
          "default": false,
          "label": "t:sections.contact-form.blocks.all.settings.required"
        },
        {
          "type": "text",
          "id": "option_one",
          "default": "A friend",
          "label": "t:sections.contact-form.blocks.select.settings.option_one.label"
        },
        {
          "type": "text",
          "id": "option_two",
          "default": "Social media",
          "label": "t:sections.contact-form.blocks.select.settings.option_two.label"
        },
        {
          "type": "text",
          "id": "option_three",
          "default": "Google search",
          "label": "t:sections.contact-form.blocks.select.settings.option_three.label"
        },
        {
          "type": "text",
          "id": "option_four",
          "default": "Event",
          "label": "t:sections.contact-form.blocks.select.settings.option_four.label"
        },
        {
          "type": "text",
          "id": "option_five",
          "default": "Other",
          "label": "t:sections.contact-form.blocks.select.settings.option_five.label"
        },
        {
          "type": "checkbox",
          "id": "half_width",
          "default": false,
          "label": "t:sections.contact-form.blocks.all.settings.half_width"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.contact-form.presets.name",
      "category": "t:settings_schema.groups.specialized",
      "blocks": [
        {
          "type": "text"
        },
        {
          "type": "email"
        },
        {
          "type": "phone"
        },
        {
          "type": "textarea"
        }
      ]
    }
  ]
}
{% endschema %}