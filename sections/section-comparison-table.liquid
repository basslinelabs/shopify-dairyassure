    },
    {
      "type": "text",
      "id": "column_2_header",
      "default": "Column 2",
      "label": "t:sections.comparison-table.settings.column_2_header.label"
    },
    {
      "type": "image_picker",
      "id": "column_2_image",
      "label": "t:sections.comparison-table.settings.column_2_image.label"
