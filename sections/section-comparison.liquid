{{ 'section-comparison.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div
  class="da-comp da-bg-dark section-{{ section.id }}-padding{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
>
  <div class="page-width">
    <div class="da-comp__header">
      <h2 class="da-comp__heading">{{ section.settings.heading }}</h2>
      {%- if section.settings.subheading != blank -%}
        <p class="da-comp__subheading">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>

    <div class="da-comp__table-wrapper">
      <table class="da-comp__table" role="table">
        <thead>
          <tr>
            <th class="da-comp__th da-comp__th--feature" scope="col">Feature</th>
            <th class="da-comp__th da-comp__th--hero" scope="col">
              <span class="da-comp__th-brand">DairyAssure</span>
            </th>
            <th class="da-comp__th" scope="col">Lactase Pills</th>
            <th class="da-comp__th" scope="col">Dairy Alternatives</th>
            <th class="da-comp__th da-comp__th--last" scope="col">Avoiding Dairy</th>
          </tr>
        </thead>
        <tbody>
          {%- for block in section.blocks -%}
            <tr class="da-comp__row" {{ block.shopify_attributes }}>
              <td class="da-comp__td da-comp__td--feature">{{ block.settings.feature }}</td>
              <td class="da-comp__td da-comp__td--hero">
                {%- if block.settings.da_value == 'yes' -%}
                  <span class="da-comp__check" aria-label="Yes">✓</span>
                {%- elsif block.settings.da_value == 'no' -%}
                  <span class="da-comp__x" aria-label="No">✗</span>
                {%- else -%}
                  <span class="da-comp__text-val">{{ block.settings.da_value }}</span>
                {%- endif -%}
              </td>
              <td class="da-comp__td">
                {%- if block.settings.pills_value == 'yes' -%}
                  <span class="da-comp__check da-comp__check--muted" aria-label="Yes">✓</span>
                {%- elsif block.settings.pills_value == 'no' -%}
                  <span class="da-comp__x" aria-label="No">✗</span>
                {%- else -%}
                  <span class="da-comp__text-val da-comp__text-val--muted">{{ block.settings.pills_value }}</span>
                {%- endif -%}
              </td>
              <td class="da-comp__td">
                {%- if block.settings.alts_value == 'yes' -%}
                  <span class="da-comp__check da-comp__check--muted" aria-label="Yes">✓</span>
                {%- elsif block.settings.alts_value == 'no' -%}
                  <span class="da-comp__x" aria-label="No">✗</span>
                {%- else -%}
                  <span class="da-comp__text-val da-comp__text-val--muted">{{ block.settings.alts_value }}</span>
                {%- endif -%}
              </td>
              <td class="da-comp__td da-comp__td--last">
                {%- if block.settings.avoid_value == 'yes' -%}
                  <span class="da-comp__check da-comp__check--muted" aria-label="Yes">✓</span>
                {%- elsif block.settings.avoid_value == 'no' -%}
                  <span class="da-comp__x" aria-label="No">✗</span>
                {%- else -%}
                  <span class="da-comp__text-val da-comp__text-val--muted">{{ block.settings.avoid_value }}</span>
                {%- endif -%}
              </td>
            </tr>
          {%- endfor -%}
        </tbody>
      </table>
    </div>

    {%- if section.settings.button_label != blank -%}
      <div class="da-comp__cta">
        {%- render 'da-button', label: section.settings.button_label, url: section.settings.button_link -%}
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "DA Comparison Table",
  "tag": "section",
  "class": "section section--comparison",
  "settings": [
    { "type": "inline_richtext", "id": "heading", "label": "Heading", "default": "One Ingredient. Zero Compromise." },
    { "type": "textarea", "id": "subheading", "label": "Subheading" },
    { "type": "text", "id": "button_label", "label": "CTA button label" },
    { "type": "url", "id": "button_link", "label": "CTA button link" },
    { "type": "header", "content": "Section padding" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding top", "default": 64 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding bottom", "default": 64 }
  ],
  "blocks": [
    {
      "type": "row",
      "name": "Comparison Row",
      "limit": 10,
      "settings": [
        { "type": "text", "id": "feature", "label": "Feature name", "default": "Ingredients" },
        { "type": "text", "id": "da_value", "label": "DairyAssure", "default": "yes", "info": "Use 'yes', 'no', or custom text" },
        { "type": "text", "id": "pills_value", "label": "Lactase Pills", "default": "no" },
        { "type": "text", "id": "alts_value", "label": "Dairy Alternatives", "default": "no" },
        { "type": "text", "id": "avoid_value", "label": "Avoiding Dairy", "default": "no" }
      ]
    }
  ],
  "presets": [
    {
      "name": "DA Comparison Table",
      "blocks": [
        { "type": "row", "settings": { "feature": "Single ingredient", "da_value": "yes", "pills_value": "no", "alts_value": "no", "avoid_value": "no" } },
        { "type": "row", "settings": { "feature": "No planning required", "da_value": "yes", "pills_value": "no", "alts_value": "yes", "avoid_value": "yes" } },
        { "type": "row", "settings": { "feature": "Works with real dairy", "da_value": "yes", "pills_value": "yes", "alts_value": "no", "avoid_value": "no" } },
        { "type": "row", "settings": { "feature": "Flavorless", "da_value": "yes", "pills_value": "yes", "alts_value": "no", "avoid_value": "no" } },
        { "type": "row", "settings": { "feature": "Portable", "da_value": "yes", "pills_value": "no", "alts_value": "no", "avoid_value": "yes" } },
        { "type": "row", "settings": { "feature": "90+ min relief", "da_value": "yes", "pills_value": "30-45 min", "alts_value": "N/A", "avoid_value": "N/A" } },
        { "type": "row", "settings": { "feature": "Zero fillers", "da_value": "yes", "pills_value": "no", "alts_value": "yes", "avoid_value": "yes" } }
      ]
    }
  ],
  "enabled_on": { "templates": ["index"] }
}
{% endschema %}
