      "default": "Column 3",
      "label": "t:sections.comparison-table.settings.column_3_header.label"
    },
    {
      "type": "image_picker",
      "id": "column_3_image",
      "label": "t:sections.comparison-table.settings.column_3_image.label"
    },
    {
      "type": "select",
      "id": "highlight_column",
      "options": [
        {
          "value": "1",
          "label": "t:sections.comparison-table.settings.highlight_column.options__1.label"
        },
        {
          "value": "2",
          "label": "t:sections.comparison-table.settings.highlight_column.options__2.label"
        },
        {
          "value": "3",
          "label": "t:sections.comparison-table.settings.highlight_column.options__3.label"
        }
      ],
