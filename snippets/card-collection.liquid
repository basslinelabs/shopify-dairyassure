{% comment %}
    Renders a collection card with options for a custom collection image, 
    and to specify the number of columns on desktop.

    Accepts:
    - card_collection: {Object} Collection Liquid object
    - collection_image: {Image} Image to overwrite the collection image (optional)
    - columns: {Number} Number of columns on desktop
    
    Usage:
    {% render 'card-collection', 
      card_collection: collection, 
      collection_image: collection.featured_image,
      columns: section.settings.columns_desktop %}
{% endcomment %}

{%- liquid

  if collection_image == blank 
    assign collection_image = card_collection.featured_image
  endif

  assign ratio = 1
  if settings.image_ratio == 'portrait'
    assign ratio = 0.8
  elsif settings.image_ratio == 'adapt' and collection_image != blank
    assign ratio = collection_image.aspect_ratio
  endif
  if ratio == 0 or ratio == nil
    assign ratio = 1
  endif
-%}
<a href="{{ card_collection.url }}" class="link-reduce card__link">
  <div class="card-wrapper">
    <div class="card
      card--standard
      {% if collection_image %} card--media{% else %} card--text{% endif %} card--extend-height
      {% if collection_image == nil %} ratio{% endif %}"
      style="--ratio-percent: {{ 1 | divided_by: ratio | times: 100 }}%;"
    >
      <div class="card__inner {% if collection_image %} ratio{% endif %}" style="--ratio-percent: {{ 1 | divided_by: ratio | times: 100 }}%;">
        {%- if collection_image -%}
          <div class="card__media">
            <div class="media media--transparent">
              <img
                srcset="{%- if collection_image.width >= 165 -%}{{ collection_image | image_url: width: 165 }} 165w,{%- endif -%}
                  {%- if collection_image.width >= 330 -%}{{ collection_image | image_url: width: 330 }} 330w,{%- endif -%}
                  {%- if collection_image.width >= 535 -%}{{ collection_image | image_url: width: 535 }} 535w,{%- endif -%}
                  {%- if collection_image.width >= 750 -%}{{ collection_image | image_url: width: 750 }} 750w,{%- endif -%}
                  {%- if collection_image.width >= 1000 -%}{{ collection_image | image_url: width: 1000 }} 1000w,{%- endif -%}
                  {%- if collection_image.width >= 1500 -%}{{ collection_image | image_url: width: 1500 }} 1500w,{%- endif -%}
                  {%- if collection_image.width >= 3000 -%}{{ collection_image | image_url: width: 3000 }} 3000w,{%- endif -%}
                  {{ collection_image | image_url }} {{ collection_image.width }}w"
                src="{{ collection_image | image_url: width: 1500 }}"
                sizes="
                (min-width: 1400px) 1400px,
                (min-width: 750px) {% if columns > 1 %}calc((100vw - 10rem) / 2){% else %}calc(100vw - 10rem){% endif %},
                calc(100vw - 3rem)"
                alt="{{ card_collection.title | escape }}"
                height="{{ collection_image.height }}"
                width="{{ collection_image.width }}"
                loading="lazy"
                class="motion-reduce"
              >
            </div>
          </div>
        {%- endif -%}
        <div class="card__content">        
          <div class="card__information">
            <h3 class="card__heading"{% if content_font_size and content_font_size != 0 %} style="--override-font-size: {{ content_font_size }}px;"{% endif %}>
              {%- if card_collection.title != blank -%}
                {{- card_collection.title | escape -}}
              {%- else -%}
                {{ 'onboarding.collection_title' | t }}
              {%- endif -%}
            </h3>
          </div>   
        </div>
      </div>
      {% if collection_image %} 
        <div class="card__content">
          <div class="card__information">
            <h3 class="card__heading"{% if content_font_size and content_font_size != 0 %} style="--override-font-size: {{ content_font_size }}px;"{% endif %}>
              {%- if card_collection.title != blank -%}
                {{- card_collection.title | escape -}}
              {%- else -%}
                {{ 'onboarding.collection_title' | t }}
              {%- endif -%}
            </h3>
          </div>
        </div>
      {% endif %} 
    </div>
  </div>
</a>