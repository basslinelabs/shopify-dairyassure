{{ 'section-reviews.css' | asset_url | stylesheet_tag }}
<script src="{{ 'section-reviews.js' | asset_url }}" defer="defer"></script>

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div
  class="da-reviews section-{{ section.id }}-padding{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
>
  <div class="page-width">
    <div class="da-reviews__header">
      <h2 class="da-reviews__heading">{{ section.settings.heading }}</h2>
    </div>

    {%- comment -%} Rating summary {%- endcomment -%}
    <div class="da-reviews__summary">
      <div class="da-reviews__score">
        <p class="da-reviews__score-number">{{ section.settings.average_rating }}</p>
        <div>{%- render 'da-star-rating', rating: 5, size: 'small' -%}</div>
        <p class="da-reviews__score-label">{{ section.settings.total_reviews }} reviews</p>
      </div>

      <div class="da-reviews__bars">
        <div class="da-reviews__bar-row">
          <span class="da-reviews__bar-label">5</span>
          <div class="da-reviews__bar-track"><div class="da-reviews__bar-fill" style="width: 100%;"></div></div>
        </div>
        <div class="da-reviews__bar-row">
          <span class="da-reviews__bar-label">4</span>
          <div class="da-reviews__bar-track"><div class="da-reviews__bar-fill" style="width: 0%;"></div></div>
        </div>
        <div class="da-reviews__bar-row">
          <span class="da-reviews__bar-label">3</span>
          <div class="da-reviews__bar-track"><div class="da-reviews__bar-fill" style="width: 0%;"></div></div>
        </div>
        <div class="da-reviews__bar-row">
          <span class="da-reviews__bar-label">2</span>
          <div class="da-reviews__bar-track"><div class="da-reviews__bar-fill" style="width: 0%;"></div></div>
        </div>
        <div class="da-reviews__bar-row">
          <span class="da-reviews__bar-label">1</span>
          <div class="da-reviews__bar-track"><div class="da-reviews__bar-fill" style="width: 0%;"></div></div>
        </div>
      </div>
    </div>

    {%- comment -%} Filter tabs {%- endcomment -%}
    <div class="da-reviews__tabs" role="tablist" aria-label="Filter reviews by product strength">
      <button type="button" class="da-reviews__tab da-reviews__tab--active" data-variant="all" role="tab" aria-selected="true" aria-controls="da-reviews-list">All</button>
      <button type="button" class="da-reviews__tab" data-variant="single" role="tab" aria-selected="false" aria-controls="da-reviews-list">{{ section.settings.tab_1_label }}</button>
      <button type="button" class="da-reviews__tab" data-variant="extra" role="tab" aria-selected="false" aria-controls="da-reviews-list">{{ section.settings.tab_2_label }}</button>
    </div>

    {%- comment -%} Review cards {%- endcomment -%}
    <div class="da-reviews__list" id="da-reviews-list" role="tabpanel">
      {%- for block in section.blocks -%}
        <div
          class="da-reviews__card{% if forloop.index > 3 %} da-reviews__card--hidden{% endif %}"
          data-variant="{{ block.settings.variant }}"
          {{ block.shopify_attributes }}
        >
          <div class="da-reviews__card-header">
            <div>
              {%- render 'da-star-rating', rating: block.settings.stars, size: 'small' -%}
            </div>
            <div style="display: flex; align-items: center; gap: 8px;">
              <span class="da-reviews__card-author">{{ block.settings.author }}</span>
              {%- if block.settings.verified -%}
                <span class="da-reviews__card-verified">
                  <svg viewBox="0 0 16 16" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <path d="M8 0a8 8 0 110 16A8 8 0 018 0zm3.41 5.29a1 1 0 00-1.41 0L7 8.29 6 7.29a1 1 0 00-1.41 1.42l1.7 1.7a1 1 0 001.42 0l3.7-3.7a1 1 0 000-1.42z"/>
                  </svg>
                  Verified
                </span>
              {%- endif -%}
            </div>
          </div>
          <p class="da-reviews__card-text">{{ block.settings.text }}</p>
        </div>
      {%- endfor -%}
    </div>

    {%- if section.blocks.size > 3 -%}
      <div class="da-reviews__show-more">
        <button type="button" class="da-reviews__show-more-btn">See More Reviews</button>
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "DA Customer Reviews",
  "tag": "section",
  "class": "section section--reviews",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "What Real Customers Are Saying." },
    { "type": "text", "id": "average_rating", "label": "Average rating", "default": "5.00" },
    { "type": "text", "id": "total_reviews", "label": "Total reviews", "default": "127" },
    { "type": "header", "content": "Filter Tabs" },
    { "type": "text", "id": "tab_1_label", "label": "Tab 1 label", "default": "Single Strength" },
    { "type": "text", "id": "tab_2_label", "label": "Tab 2 label", "default": "Extra Strength" },
    { "type": "header", "content": "Section padding" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding top", "default": 64 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding bottom", "default": 64 }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "limit": 20,
      "settings": [
        { "type": "range", "id": "stars", "min": 1, "max": 5, "step": 1, "label": "Star rating", "default": 5 },
        { "type": "textarea", "id": "text", "label": "Review text" },
        { "type": "text", "id": "author", "label": "Author name" },
        { "type": "checkbox", "id": "verified", "label": "Verified customer", "default": true },
        { "type": "select", "id": "variant", "label": "Product variant", "options": [
          { "value": "single", "label": "Single Strength" },
          { "value": "extra", "label": "Extra Strength" }
        ], "default": "single" }
      ]
    }
  ],
  "presets": [
    { "name": "DA Customer Reviews" }
  ],
  "enabled_on": { "templates": ["index"] }
}
{% endschema %}
