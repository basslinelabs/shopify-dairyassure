                                                {%- for grandchildlink in childlink.links -%}
                                                  <li>
                                                    <a href="{{ grandchildlink.url }}" class="mega-menu__link link-reduce"{% if grandchildlink.current %} aria-current="page"{% endif %}>
                                                      {{ grandchildlink.title | escape }}
                                                    </a>
                                                  </li>
                                                {%- endfor -%}
                                              </ul>
                                            {%- endif -%}
                                          {%- if current_menu_item.show_second_level_links -%}
                                            </li>
                                          {%- endif -%}
                                        {%- endfor -%}
                                      </ul>
                                    </div>
