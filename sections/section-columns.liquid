{%- liquid
  assign button_style = section.settings.button_style
  assign grid_class = 'grid--' | append: section.settings.columns_desktop
  assign grid_class = grid_class | append: ' grid--'
  assign columns_mobile = section.settings.columns_mobile
  if columns_mobile == 'default'
    assign columns_mobile = settings.columns_mobile
  endif
  assign grid_class = grid_class | append: columns_mobile
  assign grid_class = grid_class | append: '-mobile'

  assign show_top_divider = section.settings.show_top_divider

  if section.settings.title != blank
    assign title = section.settings.title | escape
  else
    assign title = section.settings.collection.title
  endif

  case section.settings.image_ratio
    when 'adapt'
      assign aspect_ratio = 'auto'
    when 'square'
      assign aspect_ratio = '1 / 1'
    when 'portrait'
      assign aspect_ratio = '2 / 3'
    when 'landscape'
      assign aspect_ratio = '3 / 2'
  endcase

  if section.settings.layout_mobile == "slider" or section.settings.layout_desktop == "slider"
    assign build_slider = true
  endif

-%}

{% if build_slider %}
  <script src="{{ 'vendor.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'slider.js' | asset_url }}" defer="defer"></script>
  {{ 'slider.css' | asset_url | stylesheet_tag }}
{% endif %}

{%- style -%}
  {% if section.settings.show_accent_image and section.settings.accent_image %}
    {% render 'styling-section',
      section_id: section.id,
      accent_image: section.settings.accent_image,
      accent_vertical_anchor: section.settings.accent_vertical_anchor,
      accent_horizontal_anchor: section.settings.accent_horizontal_anchor,
      accent_size: section.settings.accent_size,
      hide_accent_on_mobile: section.settings.hide_accent_on_mobile,
      accent_cover: section.settings.accent_cover
    %}
  {% endif %}
  {% if section.settings.show_background_shape %}
    {% render 'styling-background-shape',
      section_id: section.id,
      background_shape_top: section.settings.background_shape_top,
      background_shape_right: section.settings.background_shape_right,
      background_shape_bottom: section.settings.background_shape_bottom,
      background_shape_left: section.settings.background_shape_left,
    %}
  {% endif %}
  section#shopify-section-{{ section.id }} .columns-card__image-container img,
  section#shopify-section-{{ section.id }} .columns-card__image-container svg {
    aspect-ratio: {{ aspect_ratio }};
  }
  section#shopify-section-{{ section.id }} .columns-card__image-container {
    width: {{ section.settings.image_width }}%;
  }
{%- endstyle -%}

{%- if show_top_divider -%}
  <div class="top-divider color-{{ section.settings.divider_color_scheme }}"></div>
{%- endif -%}

<div class="section-outer{% if show_top_divider %} has-divider{% endif %}">
  <div class="section-standard section--columns section-content bg-default color-{{ section.settings.color_scheme }}"{% if section.settings.override_default_styles %} style="--override-padding-top: {{ section.settings.override_space_above }}px; --override-padding-bottom: {{ section.settings.override_space_below }}px;"{% endif %}>
    <div class="contained-section alignment in-front-of-accent-image">
      <div class="section-intro">
        <{{ section.settings.header_tag }}{% if section.settings.override_default_styles %} style="--override-font-size: {{ section.settings.override_header_font_size }}px;"{% endif %}>{{ title }}</{{ section.settings.header_tag }}>
        {%- if section.settings.text != blank -%}
          <div class="rte"{% if section.settings.override_default_styles %} style="--override-font-size: {{ section.settings.override_text_font_size }}px;"{% endif %}>{{ section.settings.text }}</div>
        {%- endif -%}
      </div>
      {% if build_slider %}
        <column-slider data-mobile-layout="{{ section.settings.layout_mobile }}" data-mobile-slides-per-view="{{ columns_mobile }}" data-desktop-layout="{{ section.settings.layout_desktop }}" data-desktop-slides-per-view="{{ section.settings.columns_desktop }}" id="column-slider-{{ section.id }}">
          <div class="swiper swiper-column-slider" id="swiper-{{ section.id }}">
            <div class="columns-content swiper-wrapper grid {{ grid_class }}">
      {% else %}
        <div class="columns-content grid {{ grid_class }}">
        {% endif %}
        {%- for block in section.blocks -%}
          <div class="columns__column{% if build_slider %} swiper-slide{% endif %}" {{ block.shopify_attributes }}>
            {%- if block.settings.button_link -%}
              <a href="{{ block.settings.button_link }}" class="columns-card__image-link">
            {%- endif -%}
            {%- if block.settings.image != blank -%}
              <div class="columns-card__image-container {% if section.settings.show_background_shape %}bg-shape bg-shape--{{ section.settings.background_shape_color }} bg-shape--{{ section.settings.background_shape_style }}{% endif %}">
                <img
                  class="columns-card__image"
                  srcset="
                    {%- if block.settings.image.width >= 275 -%}{{ block.settings.image | image_url: width: 275 }} 275w,{%- endif -%}
                    {%- if block.settings.image.width >= 550 -%}{{ block.settings.image | image_url: width: 550 }} 550w,{%- endif -%}
                    {%- if block.settings.image.width >= 710 -%}{{ block.settings.image | image_url: width: 710 }} 710w,{%- endif -%}
                    {%- if block.settings.image.width >= 1420 -%}{{ block.settings.image | image_url: width: 1420 }} 1420w,{%- endif -%}
                    {{ block.settings.image | image_url }} {{ block.settings.image.width }}w
                  "
                  src="{{ block.settings.image | image_url: width: 550 }}"
                  sizes="
                    (min-width: 990px) {% if section.blocks.size <= 2 %}710px{% else %}550px{% endif %},
                    (min-width: 750px) {% if section.blocks.size == 1 %}710px{% else %}550px{% endif %},
                    calc(100vw - 30px)
                  "
                  alt="{{ block.settings.image.alt }}"
                  height="{{ block.settings.image.height }}"
                  width="{{ block.settings.image.width }}"
                  loading="lazy"
                >
              </div>
            {%- endif -%}
            {%- if block.settings.button_link -%}
              </a>
            {%- endif -%}
            {% if block.settings.header != blank %}
              <{{ block.settings.header_tag }}{% if section.settings.override_default_styles %} style="--override-font-size: {{ section.settings.override_content_header_font_size }}px;"{% endif %}>{{ block.settings.header }}</{{ block.settings.header_tag }}>
            {% endif %}
            {%- if block.settings.text != blank -%}
              <div class="rte"{% if section.settings.override_default_styles %} style="--override-font-size: {{ section.settings.override_content_text_font_size }}px;"{% endif %}>
                {{ block.settings.text }}
              </div>
            {%- endif -%}
            {%- if block.settings.button_text != blank and block.settings.button_link -%}
              <a
                href="{{ block.settings.button_link }}"
                class="{{ button_style }}{% unless button_style == "link" %} button{% endunless %}"
              >
                {{ block.settings.button_text }}
              </a>
            {%- endif -%}
          </div>
        {%- endfor -%}
      {% if build_slider %}
            </div>
          </div>
          <div class="swiper-pagination column-slider--pagination"></div>
          <div class="swiper-button-prev column-slider--navigation">{% render 'icons-main', icon: 'caret' %}</div>
          <div class="swiper-button-next column-slider--navigation">{% render 'icons-main', icon: 'caret' %}</div>
        </column-slider>
      {% else %}
        </div>
      {% endif %}
    </div>
  </div>
</div
>
{% schema %}
