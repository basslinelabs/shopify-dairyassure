                                              loading: 'lazy',
                                              alt: current_menu_item.image_one.alt
                                            }}
                                            <h4 class="mega-menu__text-one">
                                              {{ current_menu_item.text_one }}
                                            </h4>
                                          </div>
                                          {%- if current_menu_item.link_one -%}
                                            </a>
                                          {%- endif -%}
                                        {%- endif -%}
                                        {%- if current_menu_item.image_two -%}
                                          {%- if current_menu_item.link_two -%}
