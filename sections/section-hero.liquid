{{ 'section-hero.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div
  class="da-hero da-cow-print section-{{ section.id }}-padding"
>
  <div class="page-width da-hero__container">
    <div class="da-hero__text">
      <div class="da-hero__star-line">
        {%- render 'da-star-rating', rating: 5, size: 'small' -%}
        <p class="da-hero__star-text">{{ section.settings.star_text }}</p>
      </div>

      <h1 class="da-hero__heading">{{ section.settings.heading }}</h1>

      <p class="da-hero__subheading">{{ section.settings.subheading }}</p>

      <div class="da-hero__cta">
        {%- render 'da-button', label: section.settings.button_label, url: section.settings.button_link -%}
      </div>

      <div class="da-hero__trust-wrap">
        {%- render 'da-trust-badges', text: section.settings.trust_text -%}
      </div>
    </div>

    <div class="da-hero__media" id="da-hero-media">
      {%- if section.settings.image != blank -%}
        {%- if section.settings.image_mobile != blank -%}
          <div class="da-hero__media-mobile">
            {{
              section.settings.image_mobile
              | image_url: width: 750
              | image_tag:
                loading: 'eager',
                fetchpriority: 'high',
                sizes: '100vw',
                widths: '375, 550, 750',
                alt: section.settings.image_mobile.alt | default: section.settings.heading
            }}
          </div>
          <div class="da-hero__media-desktop">
            {{
              section.settings.image
              | image_url: width: 800
              | image_tag:
                loading: 'eager',
                fetchpriority: 'high',
                sizes: '(min-width: 750px) 50vw, 100vw',
                widths: '375, 550, 750, 800',
                alt: section.settings.image.alt | default: section.settings.heading
            }}
          </div>
        {%- else -%}
          {{
            section.settings.image
            | image_url: width: 800
            | image_tag:
              loading: 'eager',
              fetchpriority: 'high',
              sizes: '(min-width: 750px) 50vw, 100vw',
              widths: '375, 550, 750, 800',
              alt: section.settings.image.alt | default: section.settings.heading
          }}
        {%- endif -%}
      {%- else -%}
        <div class="da-hero__media-mobile">
          <img
            src="{{ 'da-hero-product-mobile.jpg' | asset_url }}"
            loading="eager"
            fetchpriority="high"
            width="900"
            height="1200"
            alt="{{ section.settings.heading }}"
          >
        </div>
        <div class="da-hero__media-desktop">
          <img
            src="{{ 'da-hero-product.jpg' | asset_url }}"
            loading="eager"
            fetchpriority="high"
            width="1600"
            height="1600"
            alt="{{ section.settings.heading }}"
          >
        </div>
      {%- endif -%}
    </div>
  </div>
</div>

<script>
  (function() {
    var reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (reducedMotion) return;

    var media = document.getElementById('da-hero-media');
    if (!media) return;

    /* Start breathing float after entrance animation finishes */
    media.addEventListener('animationend', function handler() {
      media.removeEventListener('animationend', handler);
      /* Only add breathing on mobile/tablet — desktop gets mouse parallax */
      if (window.innerWidth < 990) {
        media.classList.add('da-hero__media--breathing');
      }
    });

    /* Mouse parallax: desktop only */
    if (window.innerWidth < 990) return;

    media.classList.add('da-hero__media--parallax');

    var rect, cx, cy;
    var tiltX = 0, tiltY = 0, targetX = 0, targetY = 0;
    var floating = true;
    var raf;

    function updateRect() {
      rect = media.getBoundingClientRect();
      cx = rect.left + rect.width / 2;
      cy = rect.top + rect.height / 2;
    }

    function lerp(a, b, t) { return a + (b - a) * t; }

    function animate() {
      tiltX = lerp(tiltX, targetX, 0.08);
      tiltY = lerp(tiltY, targetY, 0.08);

      if (Math.abs(tiltX - targetX) > 0.01 || Math.abs(tiltY - targetY) > 0.01) {
        media.style.transform = 'perspective(800px) rotateY(' + tiltX + 'deg) rotateX(' + tiltY + 'deg)';
        raf = requestAnimationFrame(animate);
      } else {
        media.style.transform = 'perspective(800px) rotateY(' + targetX + 'deg) rotateX(' + targetY + 'deg)';
      }
    }

    /* Wait for entrance animation, then enable parallax */
    media.addEventListener('animationend', function handler2() {
      media.removeEventListener('animationend', handler2);
      updateRect();

      document.addEventListener('mousemove', function(e) {
        /* Stop breathing if it was added, parallax takes over */
        if (floating) {
          floating = false;
          media.classList.remove('da-hero__media--breathing');
        }
        if (!rect) updateRect();
        var dx = (e.clientX - cx) / (rect.width / 2);
        var dy = (e.clientY - cy) / (rect.height / 2);
        targetX = dx * 3;   /* max 3 degrees */
        targetY = dy * -2;  /* max 2 degrees, inverted */
        cancelAnimationFrame(raf);
        raf = requestAnimationFrame(animate);
      });

      /* Reset on mouse leave */
      document.addEventListener('mouseleave', function() {
        targetX = 0;
        targetY = 0;
        cancelAnimationFrame(raf);
        raf = requestAnimationFrame(animate);
      });

      /* Recalculate position on scroll/resize */
      var debounce;
      window.addEventListener('scroll', function() {
        clearTimeout(debounce);
        debounce = setTimeout(updateRect, 100);
      }, { passive: true });
      window.addEventListener('resize', updateRect, { passive: true });
    });
  })();
</script>

{% schema %}
{
  "name": "DA Hero",
  "tag": "section",
  "class": "section section--hero",
  "settings": [
    { "type": "header", "content": "Content" },
    { "type": "text", "id": "star_text", "label": "Star rating text", "default": "5.0 Stars from 127 Reviews" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Enjoy Dairy Without the Drama." },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "A single-ingredient lactase powder you sprinkle on any food or drink. No pills. No planning. No compromise." },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "TRY DAIRYASSURE TODAY" },
    { "type": "url", "id": "button_link", "label": "Button link" },
    { "type": "text", "id": "trust_text", "label": "Trust line", "default": "✔ Money-Back Guarantee | Free Shipping on $50+" },
    { "type": "header", "content": "Image" },
    { "type": "image_picker", "id": "image", "label": "Hero product image" },
    { "type": "image_picker", "id": "image_mobile", "label": "Mobile hero image (optional)" },
    { "type": "header", "content": "Section padding" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding top", "default": 64 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding bottom", "default": 64 }
  ],
  "presets": [
    { "name": "DA Hero" }
  ],
  "enabled_on": { "templates": ["index"] }
}
{% endschema %}
