      {
        "type": "header",
        "content": "t:settings_schema.typography.settings.header__body.content"
      },
      {
        "type": "font_picker",
        "id": "body_font",
        "default": "jost_n4",
        "label": "t:settings_schema.typography.settings.body_font.label",
        "info": "t:settings_schema.typography.settings.body_font.info"
