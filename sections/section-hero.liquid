{{ 'section-hero.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div
  class="da-hero da-cow-print section-{{ section.id }}-padding{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
>
  <div class="page-width da-hero__container">
    <div class="da-hero__text">
      <div class="da-hero__star-line">
        {%- render 'da-star-rating', rating: 5, size: 'small' -%}
        <p class="da-hero__star-text">{{ section.settings.star_text }}</p>
      </div>

      <h1 class="da-hero__heading">{{ section.settings.heading }}</h1>

      <p class="da-hero__subheading">{{ section.settings.subheading }}</p>

      <div class="da-hero__cta">
        {%- render 'da-button', label: section.settings.button_label, url: section.settings.button_link -%}
      </div>

      {%- render 'da-trust-badges', text: section.settings.trust_text -%}
    </div>

    <div class="da-hero__media">
      {%- if section.settings.image != blank -%}
        {%- if section.settings.image_mobile != blank -%}
          <div class="da-hero__media-mobile">
            {{
              section.settings.image_mobile
              | image_url: width: 750
              | image_tag:
                loading: 'eager',
                fetchpriority: 'high',
                sizes: '100vw',
                widths: '375, 550, 750',
                alt: section.settings.image_mobile.alt | default: section.settings.heading
            }}
          </div>
          <div class="da-hero__media-desktop">
            {{
              section.settings.image
              | image_url: width: 800
              | image_tag:
                loading: 'eager',
                fetchpriority: 'high',
                sizes: '(min-width: 750px) 50vw, 100vw',
                widths: '375, 550, 750, 800',
                alt: section.settings.image.alt | default: section.settings.heading
            }}
          </div>
        {%- else -%}
          {{
            section.settings.image
            | image_url: width: 800
            | image_tag:
              loading: 'eager',
              fetchpriority: 'high',
              sizes: '(min-width: 750px) 50vw, 100vw',
              widths: '375, 550, 750, 800',
              alt: section.settings.image.alt | default: section.settings.heading
          }}
        {%- endif -%}
      {%- else -%}
        <div class="da-hero__media-mobile">
          <img
            src="{{ 'da-hero-product-mobile.jpg' | asset_url }}"
            loading="eager"
            fetchpriority="high"
            width="900"
            height="1200"
            alt="{{ section.settings.heading }}"
          >
        </div>
        <div class="da-hero__media-desktop">
          <img
            src="{{ 'da-hero-product.jpg' | asset_url }}"
            loading="eager"
            fetchpriority="high"
            width="1600"
            height="1600"
            alt="{{ section.settings.heading }}"
          >
        </div>
      {%- endif -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "DA Hero",
  "tag": "section",
  "class": "section section--hero",
  "settings": [
    { "type": "header", "content": "Content" },
    { "type": "text", "id": "star_text", "label": "Star rating text", "default": "5.0 Stars from 127 Reviews" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Enjoy Dairy Without the Drama." },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "A single-ingredient lactase powder you sprinkle on any food or drink. No pills. No planning. No compromise." },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "TRY DAIRYASSURE TODAY" },
    { "type": "url", "id": "button_link", "label": "Button link" },
    { "type": "text", "id": "trust_text", "label": "Trust line", "default": "✔ Money-Back Guarantee | Free Shipping on $50+" },
    { "type": "header", "content": "Image" },
    { "type": "image_picker", "id": "image", "label": "Hero product image" },
    { "type": "image_picker", "id": "image_mobile", "label": "Mobile hero image (optional)" },
    { "type": "header", "content": "Section padding" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding top", "default": 64 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding bottom", "default": 64 }
  ],
  "presets": [
    { "name": "DA Hero" }
  ],
  "enabled_on": { "templates": ["index"] }
}
{% endschema %}
