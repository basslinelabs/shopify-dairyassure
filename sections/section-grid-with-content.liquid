{%- liquid
  assign show_top_divider = section.settings.show_top_divider
  assign grid_class = "grid--" | append: section.settings.columns_desktop 
  assign grid_class = grid_class | append: ' grid--' 
  assign columns_mobile = section.settings.columns_mobile
  if columns_mobile == 'default'
    assign columns_mobile = settings.columns_mobile
  endif
  assign grid_class = grid_class | append: columns_mobile
  assign grid_class = grid_class | append: '-mobile'
  -%}

{%- if show_top_divider -%}
  <div class="top-divider color-{{ section.settings.divider_color_scheme }}"></div>
{%- endif -%}

<div class="section-outer{% if show_top_divider %} has-divider{% endif %}">
  <div class="section--grid-with-content section-content bg-default color-{{ section.settings.color_scheme }}">
    <div class="grid-with-content__container grid {{ grid_class }}" alignment>
      {%- for block in section.blocks -%}
        <div class="grid-with-content__grid-item bg-default color-{{ block.settings.color_scheme }}" {{ block.shopify_attributes }}>
          {%- case block.type -%}
            {%- when 'content' -%}
              {% if block.settings.header != blank or block.settings.text != blank or block.settings.button_text != blank %}
                  <div class="grid-with-content__grid-content">
                    {% if block.settings.header != blank %}
                      <h4>{{ block.settings.header | escape }}</h4>
                    {% endif %}
                    {%- if block.settings.text != blank -%}
                      <div class="rte">{{ block.settings.text }}</div>
                    {%- endif -%}
                    {%- if block.settings.button_link != blank and block.settings.button_text != blank -%}
                      <a
                          href="{{ block.settings.button_link }}"
                          class="{{ block.settings.button_style }} button--styled{% unless block.settings.button_style == "link" %} button{% endunless %}"
                      >
                          {{ block.settings.button_text }}
                      </a>
                    {%- endif -%}
                  </div>
              {% endif %}
            {%- when 'image' -%}
              <div class="grid-with-content__grid-image">
                {% if block.settings.image != blank %}
                  {% assign width = 2800 | divided_by: section.settings.columns_desktop %}
                  {{ block.settings.image | image_url: width: width | image_tag:
                    loading: 'lazy',
                    alt: block.settings.image.alt,
                    class: 'no-border-radius'
                  }}
                {% else %}
                  {{ 'image' | placeholder_svg_tag: 'placeholder-svg no-border-radius' }}
                {% endif %}
              </div>
            {%- when 'icon' -%}
              <div class="grid-with-content__grid-icon">
                {% if block.settings.icon != blank %}
                  {% assign width = 2800 | divided_by: section.settings.columns_desktop | divided_by: 2 %}
                  {{ block.settings.icon | image_url: width: width | image_tag:
                    loading: 'lazy',
                    alt: block.settings.icon.alt,
                    class: 'no-border-radius'
                  }}
                {% else %}
                  {{ 'image' | placeholder_svg_tag: 'placeholder-svg no-border-radius' }}
                {% endif %}
              </div>
          {%- endcase -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>


{% schema %}
{
  "name": "t:sections.grid-with-content.name",
  "tag": "section",
  "class": "section section-grid-with-content",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.all.section_content"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2,
      "max": 5,
      "step": 1,
      "default": 4,
      "label": "t:sections.all.columns_desktop.label"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "default": "default",
      "label": "t:settings_schema.layout.settings.columns_mobile.label",
      "options": [
        {
          "value": "default",
          "label": "t:sections.all.default.label"
        },
        {
          "value": "1",
          "label": "t:settings_schema.layout.settings.columns_mobile.options__1.label"
        },
        {
          "value": "2",
          "label": "t:settings_schema.layout.settings.columns_mobile.options__2.label"
        }
      ]
    },
    {
      "type": "header",
      "content": "t:sections.all.section_styling"
    },
    {
      "type": "checkbox",
      "id": "show_top_divider",
      "label": "t:sections.all.show_top_divider.label",
      "default": false
    },
    {
      "type": "color_scheme",
      "id": "divider_color_scheme",
      "default": "scheme-2",
      "label": "t:sections.all.top_divider_color_scheme.label",
      "info": "t:sections.all.top_divider_color_scheme.info",
      "visible_if": "{{ section.settings.show_top_divider }}"
    }
  ],
  "blocks": [
    {
      "type": "content",
      "name": "t:sections.grid-with-content.blocks.content.name",
      "settings": [
        {
          "type": "text",
          "id": "header",
          "default": "Sustainably made",
          "label": "t:sections.all.header.label"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "t:sections.all.text.label"
        },
        {
          "type": "text",
          "id": "button_text",
          "default": "Shop now",
          "label": "t:sections.all.buttons.button_text.label"
        },
        {
          "type": "url",
          "id": "button_link",
          "default": "/collections",
          "label": "t:sections.all.buttons.button_link.label"
        },
        {
          "type": "select",
          "id": "button_style",
          "label": "t:sections.all.buttons.style.label",
          "options": [
            {
              "value": "solid",
              "label": "t:sections.all.buttons.solid.label"
            },
            {
              "value": "outline",
              "label": "t:sections.all.buttons.outline.label"
            },
            {
              "value": "link",
              "label": "t:sections.all.buttons.link.label"
            }
          ],
          "default": "link"
        },
        {
          "type": "color_scheme",
          "id": "color_scheme",
          "default": "scheme_1",
          "label": "t:sections.all.color_scheme.label"
        }
      ]
    },
    {
      "type": "icon",
      "name": "t:sections.grid-with-content.blocks.icon.name",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "t:sections.grid-with-content.blocks.icon.settings.icon.label",
          "info": "t:sections.grid-with-content.blocks.icon.settings.icon.info"
        },
        {
          "type": "color_scheme",
          "id": "color_scheme",
          "default": "scheme_1",
          "label": "t:sections.all.color_scheme.label"
        }
      ]
    },
    {
      "type": "image",
      "name": "t:sections.grid-with-content.blocks.image.name",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:sections.grid-with-content.blocks.image.settings.image.label",
          "info": "t:sections.grid-with-content.blocks.image.settings.image.info"
        },
        {
          "type": "color_scheme",
          "id": "color_scheme",
          "default": "scheme_1",
          "label": "t:sections.all.color_scheme.label"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.grid-with-content.presets.name",
      "category": "t:settings_schema.groups.content",
      "settings": {
        "columns_desktop": 3
      },
      "blocks": [
        {
          "type": "image"
        },
        {
          "type": "content"
        },
        {
          "type": "image"
        }
      ]
    }
  ]
}
{% endschema %}
