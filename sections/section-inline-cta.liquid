{% comment %}
  Inline CTA strip — placed between sections to provide frequent purchase opportunities.
  Inspired by AG1's pattern of a CTA every 2-3 sections.
{% endcomment %}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="da-inline-cta section-{{ section.id }}-padding">
  <div class="page-width">
    <div class="da-inline-cta__inner">
      {%- if section.settings.text != blank -%}
        <p class="da-inline-cta__text">{{ section.settings.text }}</p>
      {%- endif -%}
      {%- if section.settings.button_label != blank -%}
        {%- render 'da-button', label: section.settings.button_label, url: section.settings.button_link -%}
      {%- endif -%}
    </div>
  </div>
</div>

<style>
  .da-inline-cta {
    background-color: var(--da-color-cream);
  }

  .da-inline-cta__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    text-align: center;
  }

  @media screen and (min-width: 750px) {
    .da-inline-cta__inner {
      flex-direction: row;
      justify-content: center;
      gap: 24px;
    }
  }

  .da-inline-cta__text {
    font-family: "Plus Jakarta Sans", "Helvetica Neue", Helvetica, Arial, sans-serif;
    font-size: 18px;
    font-weight: 700;
    color: var(--da-color-text);
    margin: 0;
  }

  @media screen and (min-width: 750px) {
    .da-inline-cta__text {
      font-size: 20px;
    }
  }

  @media screen and (max-width: 749px) {
    .da-inline-cta .da-btn {
      display: block;
      width: 100%;
    }
  }
</style>

{% schema %}
{
  "name": "DA Inline CTA",
  "tag": "section",
  "class": "section section--inline-cta",
  "settings": [
    { "type": "text", "id": "text", "label": "Prompt text", "default": "Ready to enjoy dairy again?" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "TRY DAIRYASSURE TODAY" },
    { "type": "url", "id": "button_link", "label": "Button link" },
    { "type": "header", "content": "Section padding" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding top", "default": 32 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding bottom", "default": 32 }
  ],
  "presets": [
    { "name": "DA Inline CTA" }
  ]
}
{% endschema %}
