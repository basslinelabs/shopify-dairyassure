{{ 'section-trust-chorus.css' | asset_url | stylesheet_tag }}
<script src="{{ 'section-trust-chorus.js' | asset_url }}" defer="defer"></script>

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{%- liquid
  assign quotes = section.blocks | where: 'type', 'quote'
  assign photos = section.blocks | where: 'type', 'photo'
-%}

<div
  class="da-trust-section section-{{ section.id }}-padding{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
>
  <div class="page-width">
    <div class="da-trust-section__header">
      <div class="da-trust-section__stars">
        {%- render 'da-star-rating', rating: 5, size: 'large' -%}
      </div>
      <h2 class="da-trust-section__heading">{{ section.settings.heading }}</h2>
    </div>

    {%- if quotes.size > 0 -%}
      {%- comment -%} Desktop: grid {%- endcomment -%}
      <div class="da-trust-section__quotes">
        {%- for block in quotes -%}
          <div {{ block.shopify_attributes }}>
            {%- render 'da-quote-card',
              quote: block.settings.quote,
              author: block.settings.author,
              verified: block.settings.verified,
              stars: 5
            -%}
          </div>
        {%- endfor -%}
      </div>

      {%- comment -%} Mobile: Swiper carousel {%- endcomment -%}
      <div class="da-trust-section__quotes-mobile" aria-roledescription="carousel" aria-label="Customer testimonials">
        <div class="swiper da-trust-section__swiper">
          <div class="swiper-wrapper">
            {%- for block in quotes -%}
              <div class="swiper-slide" {{ block.shopify_attributes }}>
                {%- render 'da-quote-card',
                  quote: block.settings.quote,
                  author: block.settings.author,
                  verified: block.settings.verified,
                  stars: 5
                -%}
              </div>
            {%- endfor -%}
          </div>
          <div class="swiper-pagination da-trust-section__swiper-pagination"></div>
        </div>
      </div>
    {%- endif -%}

    {%- if photos.size > 0 -%}
      <div class="da-trust-section__photos">
        {%- for block in photos -%}
          <div class="da-trust-section__photo" {{ block.shopify_attributes }}>
            {%- if block.settings.image != blank -%}
              {{
                block.settings.image
                | image_url: width: 400
                | image_tag:
                  loading: 'lazy',
                  sizes: '(min-width: 750px) 25vw, 50vw',
                  widths: '200, 300, 400',
                  alt: block.settings.alt | default: 'Lifestyle photo'
              }}
            {%- else -%}
              {%- assign photo_index = forloop.index -%}
              {%- case photo_index -%}
                {%- when 1 -%}
                  <img src="{{ 'da-trust-photo-1.jpg' | asset_url }}" loading="lazy" width="800" height="800" alt="Gelato in Italy — travel without limits">
                {%- when 2 -%}
                  <img src="{{ 'da-trust-photo-2.jpg' | asset_url }}" loading="lazy" width="800" height="800" alt="Saying yes to tiramisu at a dinner party">
                {%- when 3 -%}
                  <img src="{{ 'da-trust-photo-3.jpg' | asset_url }}" loading="lazy" width="800" height="800" alt="Kids enjoying ice cream at a birthday party">
                {%- when 4 -%}
                  <img src="{{ 'da-trust-photo-4.jpg' | asset_url }}" loading="lazy" width="800" height="800" alt="Pizza night is back — couple sharing real pizza">
                {%- else -%}
                  {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
              {%- endcase -%}
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "DA Social Proof",
  "tag": "section",
  "class": "section section--trust-chorus",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Trusted by Thousands." },
    { "type": "header", "content": "Section padding" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding top", "default": 64 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding bottom", "default": 64 }
  ],
  "blocks": [
    {
      "type": "quote",
      "name": "Testimonial",
      "limit": 6,
      "settings": [
        { "type": "textarea", "id": "quote", "label": "Quote text" },
        { "type": "text", "id": "author", "label": "Author name" },
        { "type": "checkbox", "id": "verified", "label": "Verified customer", "default": true }
      ]
    },
    {
      "type": "photo",
      "name": "Lifestyle Photo",
      "limit": 8,
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Photo" },
        { "type": "text", "id": "alt", "label": "Alt text" }
      ]
    }
  ],
  "presets": [
    {
      "name": "DA Social Proof",
      "blocks": [
        { "type": "quote", "settings": { "quote": "I brought DairyAssure to Italy. Gelato every day. Zero issues.", "author": "Maria L.", "verified": true } },
        { "type": "quote", "settings": { "quote": "No more declining dessert at dinner parties. Freedom.", "author": "James T.", "verified": true } },
        { "type": "quote", "settings": { "quote": "My kids can have ice cream at birthday parties again.", "author": "Rachel S.", "verified": true } }
      ]
    }
  ],
  "enabled_on": { "templates": ["index"] }
}
{% endschema %}
