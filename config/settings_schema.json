      {
        "type": "range",
        "id": "body_scale",
        "min": 80,
        "max": 200,
        "step": 5,
        "unit": "%",
        "label": "t:settings_schema.typography.settings.scale.label",
        "default": 100
      },
      {
        "type": "range",
        "id": "body_line_height",
        "min": 100,
        "max": 150,
        "step": 5,
        "unit": "%",
        "label": "t:settings_schema.typography.settings.line_height.label",
        "default": 100
      },
      {
        "type": "range",
        "id": "body_letter_spacing",
        "min": 0,
        "max": 10,
        "step": 1,
        "unit": "px",
        "label": "t:settings_schema.typography.settings.letter_spacing.label",
        "default": 0
